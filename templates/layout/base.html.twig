<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LVL UP - {% block title %}{% endblock %}</title>

    {# ── Metas génériques LVL UP ── #}
    <meta name="author" content="LVL UP">
    <meta name="language" content="French">
    <meta name="subject" content="Logiciel de gestion pour école de danse">
    <meta name="classification" content="SaaS, Sport, Danse, Logiciel">
    <meta name="category" content="Logiciel école de danse">
    <meta name="coverage" content="France">
    <meta name="distribution" content="Global">
    <meta name="target" content="all">
    <meta property="og:site_name" content="LVL UP">
    <meta property="og:locale" content="fr_FR">
    <meta property="article:author" content="LVL UP">
    <meta name="publish_date" content="2026-06-25T00:00:00+01:00">
    <meta property="article:published_time" content="2026-06-25">

    {% block head %}{% endblock %}
    <link rel="icon" type="image/png" href="{{ asset('favicon-96x96.png') }}" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}" />
    <link rel="shortcut icon" href="{{ asset('favicon.ico') }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}" />
    <meta name="apple-mobile-web-app-title" content="LVL UP" />
    <link rel="manifest" href="{{ asset('site.webmanifest') }}" />
    {% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/app.css') }}">
    {% endblock %}
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
    {% block body %}{% endblock %}
    {% block scripts %}{% endblock %}
</body>
</html>
