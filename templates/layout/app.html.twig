{% extends 'layout/base.html.twig' %}

{% block body %}
{% set currentTeamProfile = current_team_profile() %}
{% set currentTeam = currentTeamProfile ? currentTeamProfile.team : null %}

<div class="min-h-screen flex flex-col" x-data="{ userMenuOpen: false }">

    {# ── Top Navbar ── #}
    <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
        <div class="flex items-center justify-between h-14 px-4 md:px-6">

            {# Logo #}
            <a href="{{ path(is_granted('ROLE_SCHOOL') ? 'app_admin' : 'app_home') }}" class="flex items-center gap-2">
                <img src="{{ asset('assets/logo_lvl_up.png') }}" alt="LVL UP" class="h-8 w-auto">
                <span class="font-bold text-indigo-600 text-xl tracking-tight">LVL UP</span>
            </a>

            {# Team name (center, desktop only) #}
            {% if currentTeam %}
            <span class="hidden md:block text-sm font-medium text-gray-600 truncate max-w-xs">
                {{ currentTeam.name }}
            </span>
            {% endif %}

            {# User menu #}
            <div class="relative">
                {% set _navProfile = primary_profile() %}
                <button
                    @click="userMenuOpen = !userMenuOpen"
                    class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 transition focus:outline-none"
                >
                    {% if _navProfile and _navProfile.avatarPath %}
                        <img src="{{ _navProfile.avatarPath | imagine_filter('profile_avatar') }}" alt="" class="w-7 h-7 rounded-full object-cover shrink-0">
                    {% else %}
                        <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-semibold text-xs select-none shrink-0">
                            {{ app.user ? app.user.email|first|upper : '?' }}
                        </span>
                    {% endif %}
                    <span class="hidden md:inline truncate max-w-[140px]">{{ app.user ? app.user.email : '' }}</span>
                    <svg class="w-4 h-4 text-gray-400 transition-transform" :class="userMenuOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div
                    x-show="userMenuOpen"
                    @click.outside="userMenuOpen = false"
                    x-transition:enter="transition ease-out duration-100"
                    x-transition:enter-start="opacity-0 scale-95"
                    x-transition:enter-end="opacity-100 scale-100"
                    x-transition:leave="transition ease-in duration-75"
                    x-transition:leave-start="opacity-100 scale-100"
                    x-transition:leave-end="opacity-0 scale-95"
                    class="absolute right-0 mt-2 w-52 bg-white border border-gray-200 rounded-lg shadow-lg py-1 z-40"
                    style="display: none;"
                >
                    <a href="{{ path('app_profile') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        Mon profil
                    </a>
                    {% if is_granted('ROLE_SCHOOL') %}
                    <a href="{{ path('app_admin') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Administration
                    </a>
                    {% endif %}
                    <div class="border-t border-gray-100 my-1"></div>
                    <a href="{{ path('app_signout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Se déconnecter
                    </a>
                </div>
            </div>
        </div>
    </header>

    {# ── Impersonation banner ── #}
    {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
    <div class="bg-amber-50 border-b border-amber-200 px-4 py-2 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <span>Impersonation active — <strong>{{ app.user.email }}</strong></span>
        </div>
        <a href="{{ path('app_admin_switch_back') }}"
           class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-700 bg-amber-100 hover:bg-amber-200 border border-amber-300 px-3 py-1.5 rounded-lg transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
            Revenir
        </a>
    </div>
    {% endif %}

    {# ── Flash messages ── #}
    {% include 'components/_flash.html.twig' %}

    {# ── Page content ── #}
    <main class="flex-1">
        {% block app_content %}{% block admin_content %}{% endblock %}{% endblock %}
    </main>

</div>
{% endblock %}

{% block scripts %}
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
{% endblock %}
