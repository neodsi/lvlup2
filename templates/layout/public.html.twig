{% extends 'layout/base.html.twig' %}

{% block stylesheets %}
<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    brand: { DEFAULT: '#9136F2', dark: '#7a1fd4' }
                }
            }
        }
    }
</script>
<style>
    .btn-demo { background: linear-gradient(98deg, #F704FE 24%, #9136F2 100%); }
    .text-brand { color: #9136F2; }
    .bg-brand { background-color: #9136F2; }
    details[open] summary .icon-plus { display: none; }
    details:not([open]) summary .icon-minus { display: none; }
</style>
{% endblock %}

