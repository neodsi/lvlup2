{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="min-h-screen flex flex-col">

    {# ── Minimal header ── #}
    <header class="bg-white border-b border-gray-200">
        <div class="max-w-5xl mx-auto px-4 h-14 flex items-center">
            <a href="/" class="flex items-center gap-2">
                <img src="/assets/logo_lvl_up.png" alt="LVL UP" class="h-8 w-auto">
                <span class="font-bold text-indigo-600 text-xl tracking-tight">LVL UP</span>
            </a>
        </div>
    </header>

    {# ── Flash messages ── #}
    {% include 'components/_flash.html.twig' %}

    {# ── Main content ── #}
    <main class="flex-1">
        {% block public_content %}{% endblock %}
    </main>

    {# ── Minimal footer ── #}
    <footer class="bg-white border-t border-gray-200 py-4">
        <div class="max-w-5xl mx-auto px-4 text-center text-xs text-gray-400">
            &copy; {{ "now"|date("Y") }} LVL UP
        </div>
    </footer>

</div>
{% endblock %}
