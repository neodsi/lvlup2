{% extends 'layout/app.html.twig' %}
{% block app_content %}
<div class="p-4 md:p-6">
    {% set _bc %}{% block breadcrumb %}{% endblock %}{% endset %}
    {% if _bc | trim is not empty %}
    <nav class="flex items-center gap-1.5 text-sm text-gray-500 mb-4">
        {{ _bc | raw }}
    </nav>
    {% endif %}
    {% block school_content %}{% endblock %}
</div>
{% endblock %}
