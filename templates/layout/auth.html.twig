<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LVL UP{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50:  '#eef2ff',
                            100: '#e0e7ff',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                        }
                    }
                }
            }
        }
    </script>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen bg-slate-50 flex flex-col">

    <div class="flex flex-1 flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">

        <div class="sm:mx-auto sm:w-full sm:max-w-md">
            <a href="/" class="flex flex-col items-center gap-2">
                <img src="/assets/logo_lvl_up.png" alt="LVL UP" class="h-14 w-auto">
                <span class="text-2xl font-black tracking-tight text-indigo-600">LVL UP</span>
            </a>
            {% block heading %}{% endblock %}
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">

            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 rounded-md p-4 {% if type == 'error' %}bg-red-50 border border-red-200{% elseif type == 'success' %}bg-green-50 border border-green-200{% else %}bg-blue-50 border border-blue-200{% endif %}">
                        <p class="text-sm {% if type == 'error' %}text-red-700{% elseif type == 'success' %}text-green-700{% else %}text-blue-700{% endif %}">
                            {{ message }}
                        </p>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="bg-white py-8 px-6 shadow-sm rounded-xl border border-slate-200">
                {% block content %}{% endblock %}
            </div>
        </div>
    </div>

    {% block javascripts %}{% endblock %}
</body>
</html>
