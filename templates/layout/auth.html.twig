{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="flex flex-col lg:flex-row lg:min-h-screen">

    {# Form panel #}
    <div class="flex flex-col bg-white lg:w-1/2 lg:min-h-screen">

        <div class="px-8 pt-7">
            <a href="/">
                <img src="{{ asset('assets/logo_lvl_up.png') }}" alt="LVL UP" class="h-8 w-auto">
            </a>
        </div>

        <div class="flex flex-1 items-center justify-center px-8 py-12">
            <div class="w-full max-w-sm">

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mb-5 rounded-lg border px-4 py-3 text-sm
                            {% if type == 'error' %}bg-red-50 border-red-200 text-red-700
                            {% elseif type == 'success' %}bg-green-50 border-green-200 text-green-700
                            {% else %}bg-blue-50 border-blue-200 text-blue-700{% endif %}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block heading %}{% endblock %}
                {% block content %}{% endblock %}

            </div>
        </div>
    </div>

    {# Illustration — sous le formulaire sur mobile, panneau droit sur desktop #}
    <div class="h-52 lg:h-auto lg:w-1/2">
        <img src="{{ asset('assets/auth.jpg') }}" alt="" class="h-full w-full object-cover">
    </div>

</div>
{% endblock %}
