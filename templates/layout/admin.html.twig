{% extends 'layout/app.html.twig' %}

{% block app_content %}
{% set currentRoute = app.request.attributes.get('_route') %}

<div class="flex min-h-[calc(100vh-3.5rem)]" x-data="{ sidebarOpen: false }">

    {# ── Mobile sidebar overlay ── #}
    <div
        x-show="sidebarOpen"
        @click="sidebarOpen = false"
        class="fixed inset-0 z-20 bg-black/40 md:hidden"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        style="display: none;"
    ></div>

    {# ── Admin Sidebar ── #}
    <aside
        class="fixed inset-y-14 left-0 z-20 w-56 bg-white border-r border-gray-200 flex flex-col transform transition-transform duration-200
               -translate-x-full md:translate-x-0 md:static md:inset-y-0"
        :class="sidebarOpen ? 'translate-x-0' : ''"
    >
        <div class="px-4 py-3 border-b border-gray-100">
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Administration</span>
        </div>

        {# User info / impersonation indicator #}
        {% set _adminProfile = primary_profile() %}
        <a href="{{ path('app_profile') }}" class="block px-4 py-4 border-b border-gray-100 hover:bg-gray-50 transition">
            <div class="flex items-center gap-3">
                {% if _adminProfile and _adminProfile.avatarPath %}
                    <img src="{{ _adminProfile.avatarPath | imagine_filter('profile_avatar') }}" alt="" class="w-10 h-10 rounded-full object-cover shrink-0">
                {% else %}
                    <span class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-base shrink-0">
                        {{ app.user ? app.user.email|first|upper : '?' }}
                    </span>
                {% endif %}
                <div class="flex-1 min-w-0">
                    {% if _adminProfile %}
                        <p class="text-sm font-semibold text-gray-800 truncate leading-tight">
                            {{ _adminProfile.firstName }} {{ _adminProfile.lastName }}
                        </p>
                    {% endif %}
                    <p class="text-xs text-gray-400 truncate leading-tight mt-0.5">{{ app.user ? app.user.email : '' }}</p>
                    {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                        <p class="text-xs text-amber-600 font-medium flex items-center gap-1 mt-1">
                            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            Impersonation active
                        </p>
                    {% endif %}
                </div>
                {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                    <a href="{{ path('app_admin_switch_back') }}" title="Revenir à mon compte"
                       class="shrink-0 p-1.5 rounded-lg text-amber-600 hover:bg-amber-100 transition"
                       onclick="event.stopPropagation()">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                    </a>
                {% endif %}
            </div>
        </a>

        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">

            {# Dashboard #}
            <a href="{{ path('app_admin') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition
                      {{ currentRoute == 'app_admin' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-100 hover:text-indigo-600' }}">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                Dashboard
            </a>

            {# Écoles #}
            <a href="{{ path('app_admin_schools') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition
                      {{ currentRoute starts with 'app_admin_school' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-100 hover:text-indigo-600' }}">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                Écoles
            </a>

            {# Utilisateurs #}
            <a href="{{ path('app_admin_users') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition
                      {{ currentRoute == 'app_admin_users' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-100 hover:text-indigo-600' }}">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                Utilisateurs
            </a>

        </nav>

    </aside>

    {# ── Mobile hamburger bottom bar ── #}
    <div class="md:hidden fixed bottom-0 left-0 right-0 z-10 bg-white border-t border-gray-200 flex justify-start px-4 py-2">
        <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-lg text-gray-600 hover:bg-gray-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </div>

    {# ── Main content area ── #}
    <div class="flex-1 min-w-0">
        <div class="p-4 md:p-6 pb-16 md:pb-6">
            {% block admin_content %}{% endblock %}
        </div>
    </div>

</div>
{% endblock %}
