{% extends 'layout/school.html.twig' %}

{% block title %}Mon profil — LVL UP{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mon profil</h1>
        <a href="{{ path('app_profile_edit') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Modifier
        </a>
    </div>

    {% if profiles is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-10 text-center">
            <p class="text-gray-500 text-sm">Aucun profil trouvé.</p>
            <a href="{{ path('app_setup_profile') }}" class="mt-4 inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
                Créer mon profil
            </a>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for profile in profiles %}
                <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                    <div class="flex items-start gap-5 p-6">
                        {# Avatar #}
                        <div class="shrink-0">
                            {% if profile.avatarPath is defined and profile.avatarPath %}
                                <img src="{{ profile.avatarPath }}" alt="{{ profile.firstName }}" class="h-16 w-16 rounded-full object-cover border border-gray-200">
                            {% else %}
                                <div class="h-16 w-16 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-2xl">
                                    {{ profile.firstName|first|upper }}
                                </div>
                            {% endif %}
                        </div>

                        {# Info #}
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <h2 class="text-lg font-semibold text-gray-900">
                                    {{ profile.firstName }} {{ profile.lastName }}
                                </h2>
                                {% if profile.isPrimary() %}
                                    <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700">
                                        Principal
                                    </span>
                                {% endif %}
                            </div>

                            <dl class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
                                {% if profile.dob %}
                                    <div>
                                        <dt class="text-gray-500">Date de naissance</dt>
                                        <dd class="text-gray-900">{{ profile.dob|date('d/m/Y') }}</dd>
                                    </div>
                                {% endif %}
                                {% if profile.gender %}
                                    <div>
                                        <dt class="text-gray-500">Genre</dt>
                                        <dd class="text-gray-900">
                                            {% if profile.gender.value == 'male' %}Homme
                                            {% elseif profile.gender.value == 'female' %}Femme
                                            {% else %}{{ profile.gender.value }}{% endif %}
                                        </dd>
                                    </div>
                                {% endif %}
                                {% if profile.phone %}
                                    <div>
                                        <dt class="text-gray-500">Téléphone</dt>
                                        <dd class="text-gray-900">{{ profile.phone }}</dd>
                                    </div>
                                {% endif %}
                            </dl>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
