{% extends 'layout/school.html.twig' %}

{% block title %}Mon profil — LVL UP{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mon profil</h1>
    </div>

    {{ form_start(form, {action: path('app_profile_edit')}) }}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left: Avatar #}
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col items-center text-center">
                {% if profile.avatarPath %}
                    <img src="{{ profile.avatarPath | imagine_filter('profile_avatar') }}" alt="{{ profile.firstName }}" class="h-24 w-24 rounded-full object-cover border-2 border-gray-200 mb-4">
                {% else %}
                    <div class="h-24 w-24 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-3xl mb-4">
                        {{ profile.firstName|first|upper ?: '?' }}
                    </div>
                {% endif %}
                <p class="font-semibold text-gray-900">{{ profile.firstName }} {{ profile.lastName }}</p>
                <p class="text-xs text-gray-400 mt-0.5">{{ app.user.email }}</p>

                <label for="avatar-input" id="avatar-label" class="mt-4 cursor-pointer inline-flex items-center gap-2 w-full justify-center border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium px-3 py-2 rounded-lg transition">
                    <svg id="avatar-icon" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span id="avatar-label-text">Changer la photo</span>
                </label>
                <input type="file" id="avatar-input" accept="image/jpeg,image/png,image/webp" class="sr-only"
                       data-url="{{ path('app_profile_avatar_upload') }}"
                       data-token="{{ csrf_token('profile_avatar') }}">
                <p id="avatar-error" class="mt-1.5 text-xs text-red-600 hidden"></p>
                <p class="mt-1 text-xs text-gray-400">JPG, PNG, WebP — 2 Mo max.</p>
            </div>
        </div>

        {# Right: Info #}
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm divide-y divide-gray-100">

                <div class="px-6 py-5">
                    <h2 class="text-sm font-semibold text-gray-700 mb-4">Informations personnelles</h2>
                    <p class="text-xs text-gray-400 mb-4">Les champs marqués <span class="text-red-500 font-medium">*</span> sont obligatoires.</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                        <div class="sm:col-span-2" x-data="{ open: false }">
                            <p class="block text-xs text-gray-500 mb-1">E-mail</p>
                            <div class="flex items-center gap-2">
                                <p class="flex-1 rounded-lg border border-gray-200 bg-gray-100 px-3 py-2.5 text-sm text-gray-500 select-all">{{ app.user.email }}</p>
                                <button type="button" @click="open = !open"
                                        class="shrink-0 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                    Changer
                                </button>
                            </div>

                            {% if app.user.pendingEmail %}
                            <div class="mt-2 flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2.5 text-xs text-amber-800">
                                <svg class="w-4 h-4 shrink-0 mt-0.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <div>
                                    En attente de validation : <strong>{{ app.user.pendingEmail }}</strong><br>
                                    Vérifiez votre boîte mail et cliquez sur le lien de confirmation.
                                </div>
                            </div>
                            {% endif %}

                            <div x-show="open" x-transition class="mt-2">
                                <div class="flex gap-2 items-center">
                                    <input type="email" id="newEmailInput"
                                           placeholder="Nouvelle adresse e-mail"
                                           value="{{ app.user.pendingEmail ?? '' }}"
                                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                    <button type="button" id="emailChangeBtn"
                                            data-url="{{ path('app_profile_email_change') }}"
                                            class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition">
                                        Envoyer
                                    </button>
                                </div>
                                <p class="mt-1.5 text-xs text-gray-400">Un e-mail de confirmation sera envoyé à la nouvelle adresse. Le changement ne sera effectif qu'après validation.</p>
                            </div>
                        </div>

                        <div>
                            <label for="{{ form.firstName.vars.id }}" class="block text-xs text-gray-500 mb-1">Prénom <span class="text-red-500">*</span></label>
                            {{ form_widget(form.firstName) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.firstName) }}</div>
                        </div>

                        <div>
                            <label for="{{ form.lastName.vars.id }}" class="block text-xs text-gray-500 mb-1">Nom <span class="text-red-500">*</span></label>
                            {{ form_widget(form.lastName) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.lastName) }}</div>
                        </div>

                        <div>
                            <label for="{{ form.dob.vars.id }}" class="block text-xs text-gray-500 mb-1">Date de naissance <span class="text-red-500">*</span></label>
                            {{ form_widget(form.dob) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.dob) }}</div>
                        </div>

                        <div>
                            <label for="{{ form.gender.vars.id }}" class="block text-xs text-gray-500 mb-1">Genre <span class="text-red-500">*</span></label>
                            {{ form_widget(form.gender) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.gender) }}</div>
                        </div>

                        <div class="sm:col-span-2">
                            <label for="{{ form.phone.vars.id }}" class="block text-xs text-gray-500 mb-1">Téléphone <span class="text-red-500">*</span></label>
                            {{ form_widget(form.phone) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.phone) }}</div>
                        </div>

                    </div>
                </div>

                {% if is_granted('ROLE_STUDENT') %}
                <div class="px-6 py-5">
                    <div class="flex items-start gap-2 mb-4">
                        <h2 class="text-sm font-semibold text-gray-700">Tailles</h2>
                        <span class="text-xs text-gray-400 mt-0.5">Utilisées pour les galas et certains cours</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div>
                            {{ form_label(form.sizeTop) }}
                            {{ form_widget(form.sizeTop) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.sizeTop) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.sizeBottom) }}
                            {{ form_widget(form.sizeBottom) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.sizeBottom) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.sizeShoe) }}
                            {{ form_widget(form.sizeShoe) }}
                            <div class="mt-1 text-xs text-red-600">{{ form_errors(form.sizeShoe) }}</div>
                        </div>
                    </div>
                </div>
                {% else %}
                    {# Mark as rendered so form_end doesn't inject them as hidden inputs #}
                    {% do form.sizeTop.setRendered() %}
                    {% do form.sizeBottom.setRendered() %}
                    {% do form.sizeShoe.setRendered() %}
                {% endif %}

                {% if is_granted('ROLE_STUDENT') %}
                <div class="px-6 py-5">
                    <h2 class="text-sm font-semibold text-gray-700 mb-4">Contact d'urgence</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.emergencyName) }}
                            {{ form_widget(form.emergencyName) }}
                        </div>
                        <div>
                            {{ form_label(form.emergencyRelationship) }}
                            {{ form_widget(form.emergencyRelationship) }}
                        </div>
                        <div>
                            {{ form_label(form.emergencyPhone) }}
                            {{ form_widget(form.emergencyPhone) }}
                        </div>
                        <div>
                            {{ form_label(form.emergencyEmail) }}
                            {{ form_widget(form.emergencyEmail) }}
                        </div>
                        <div class="sm:col-span-2">
                            {{ form_label(form.injuryWarning) }}
                            {{ form_widget(form.injuryWarning) }}
                        </div>
                    </div>
                </div>
                {% else %}
                    {% do form.emergencyName.setRendered() %}
                    {% do form.emergencyRelationship.setRendered() %}
                    {% do form.emergencyPhone.setRendered() %}
                    {% do form.emergencyEmail.setRendered() %}
                    {% do form.injuryWarning.setRendered() %}
                {% endif %}

                <div class="px-6 py-4 flex items-center justify-end">
                    <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                        Enregistrer
                    </button>
                </div>

            </div>
        </div>

    </div>
    {{ form_end(form) }}

</div>

<script>
(function () {
    const emailBtn = document.getElementById('emailChangeBtn');
    if (emailBtn) {
        emailBtn.addEventListener('click', function () {
            const val = document.getElementById('newEmailInput').value.trim();
            if (!val) return;
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = this.dataset.url;
            const input = document.createElement('input');
            input.type  = 'hidden';
            input.name  = 'newEmail';
            input.value = val;
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        });
    }
})();

(function () {
    const input     = document.getElementById('avatar-input');
    const labelText = document.getElementById('avatar-label-text');
    const errorEl   = document.getElementById('avatar-error');

    input.addEventListener('change', async function () {
        const file = this.files[0];
        if (!file) return;

        labelText.textContent = 'Envoi…';
        input.disabled = true;
        errorEl.classList.add('hidden');

        const fd = new FormData();
        fd.append('avatar', file);
        fd.append('_token', input.dataset.token);

        try {
            const res  = await fetch(input.dataset.url, { method: 'POST', body: fd });
            const data = await res.json();

            if (!res.ok || data.error) {
                errorEl.textContent = data.error ?? 'Erreur lors de l\'envoi.';
                errorEl.classList.remove('hidden');
                labelText.textContent = 'Changer la photo';
            } else {
                const url     = data.url + '?t=' + Date.now();
                const existing = document.querySelector('img.h-24.w-24.rounded-full');
                if (existing) {
                    existing.src = url;
                } else {
                    const placeholder = document.querySelector('div.h-24.w-24.rounded-full');
                    if (placeholder) {
                        const img = document.createElement('img');
                        img.src = url;
                        img.alt = '';
                        img.className = 'h-24 w-24 rounded-full object-cover border-2 border-gray-200 mb-4';
                        placeholder.replaceWith(img);
                    }
                }
                labelText.textContent = 'Changer la photo';
            }
        } catch {
            errorEl.textContent = 'Erreur réseau.';
            errorEl.classList.remove('hidden');
            labelText.textContent = 'Changer la photo';
        }

        input.disabled = false;
        input.value = '';
    });
})();
</script>
{% endblock %}
