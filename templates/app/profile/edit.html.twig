{% extends 'layout/school.html.twig' %}

{% block title %}Mon profil — LVL UP{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mon profil</h1>
    </div>

    <form method="post" action="{{ path('app_profile_edit') }}" enctype="multipart/form-data">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            {# Left: Avatar #}
            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col items-center text-center">
                    {% if profile.avatarPath %}
                        <img src="{{ profile.avatarPath | imagine_filter('profile_avatar') }}" alt="{{ profile.firstName }}" class="h-24 w-24 rounded-full object-cover border-2 border-gray-200 mb-4">
                    {% else %}
                        <div class="h-24 w-24 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-3xl mb-4">
                            {{ formData.first_name|first|upper ?: '?' }}
                        </div>
                    {% endif %}
                    <p class="font-semibold text-gray-900">{{ formData.first_name }} {{ formData.last_name }}</p>
                    <p class="text-xs text-gray-400 mt-0.5">{{ app.user.email }}</p>

                    <label for="avatar" class="mt-4 cursor-pointer inline-flex items-center gap-2 w-full justify-center border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium px-3 py-2 rounded-lg transition">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        Changer la photo
                    </label>
                    <input type="file" id="avatar" name="avatar" accept="image/*" class="sr-only">
                    <p id="avatar-filename" class="mt-1.5 text-xs text-indigo-600 font-medium hidden"></p>
                    {% if errors.avatar is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.avatar }}</p>
                    {% endif %}
                    <p class="mt-1 text-xs text-gray-400">JPG, PNG, WebP — 2 Mo max.</p>
                </div>
            </div>

            {# Right: Info #}
            <div class="lg:col-span-2">
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm divide-y divide-gray-100">

                    <div class="px-6 py-5">
                        <h2 class="text-sm font-semibold text-gray-700 mb-4">Informations personnelles</h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                            <div>
                                <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1">Prénom <span class="text-red-500">*</span></label>
                                <input type="text" id="first_name" name="first_name" value="{{ formData.first_name }}" required
                                    class="block w-full rounded-lg border {{ errors.first_name is defined ? 'border-red-400' : 'border-gray-300' }} bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                {% if errors.first_name is defined %}
                                    <p class="mt-1 text-xs text-red-600">{{ errors.first_name }}</p>
                                {% endif %}
                            </div>

                            <div>
                                <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1">Nom <span class="text-red-500">*</span></label>
                                <input type="text" id="last_name" name="last_name" value="{{ formData.last_name }}" required
                                    class="block w-full rounded-lg border {{ errors.last_name is defined ? 'border-red-400' : 'border-gray-300' }} bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                {% if errors.last_name is defined %}
                                    <p class="mt-1 text-xs text-red-600">{{ errors.last_name }}</p>
                                {% endif %}
                            </div>

                            <div>
                                <label for="dob" class="block text-sm font-medium text-gray-700 mb-1">Date de naissance</label>
                                <input type="date" id="dob" name="dob" value="{{ formData.dob }}"
                                    class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                            </div>

                            <div>
                                <label for="gender" class="block text-sm font-medium text-gray-700 mb-1">Genre</label>
                                <select id="gender" name="gender"
                                    class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                    <option value="">— Choisir —</option>
                                    {% for gender in genders %}
                                        <option value="{{ gender.value }}" {{ formData.gender == gender.value ? 'selected' : '' }}>
                                            {% if gender.value == 'male' %}Homme
                                            {% elseif gender.value == 'female' %}Femme
                                            {% else %}Ne pas définir{% endif %}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="sm:col-span-2">
                                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Téléphone <span class="text-red-500">*</span></label>
                                <input type="tel" id="phone" name="phone" value="{{ formData.phone }}" placeholder="+33 6 12 34 56 78" required
                                    class="block w-full rounded-lg border {{ errors.phone is defined ? 'border-red-400' : 'border-gray-300' }} bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                {% if errors.phone is defined %}
                                    <p class="mt-1 text-xs text-red-600">{{ errors.phone }}</p>
                                {% endif %}
                            </div>

                        </div>
                    </div>

                    <div class="px-6 py-4 flex items-center justify-end">
                        <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                            Enregistrer
                        </button>
                    </div>

                </div>
            </div>

        </div>
    </form>

</div>

<script>
document.getElementById('avatar').addEventListener('change', function() {
    const label = document.getElementById('avatar-filename');
    if (this.files[0]) {
        label.textContent = this.files[0].name;
        label.classList.remove('hidden');
    }
});
</script>
{% endblock %}
