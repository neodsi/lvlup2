{% extends 'layout/app.html.twig' %}

{% block title %}Aucune école — LvlUp{% endblock %}

{% block app_content %}
<div class="min-h-[calc(100vh-3.5rem)] flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full text-center">

        <div class="mb-6 flex justify-center">
            <div class="h-20 w-20 rounded-full bg-amber-50 flex items-center justify-center">
                <svg class="h-10 w-10 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 mb-3">Aucune école trouvée</h1>
        <p class="text-gray-500 mb-2">
            Vous n'êtes rattaché à aucune école pour le moment.
        </p>
        <p class="text-gray-500 text-sm mb-8">
            Vous pouvez rejoindre une école via une invitation, ou en créer une si vous êtes administrateur.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
                href="{{ path('app_home') }}"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
            >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Accueil
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <a
                    href="{{ path('app_create_school') }}"
                    class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
                >
                    Créer une école
                </a>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
