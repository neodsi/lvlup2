{% extends 'layout/app.html.twig' %}

{% block title %}Accueil — LvlUp{% endblock %}

{% block app_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mes écoles</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_create_school') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Créer une école
            </a>
        {% endif %}
    </div>

    {% if teams is empty %}
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="mb-4 h-16 w-16 rounded-full bg-indigo-50 flex items-center justify-center">
                <svg class="h-8 w-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-gray-900 mb-2">Aucune école trouvée</h2>
            <p class="text-sm text-gray-500 mb-6 max-w-sm">
                Vous n'êtes membre d'aucune école pour le moment.
            </p>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_create_school') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                    Créer une école
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for team in teams %}
                <a
                    href="{{ path('app_select_school', {id: team.id}) }}"
                    class="group block rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:border-indigo-300 hover:shadow-md transition"
                >
                    <div class="flex items-center gap-4 mb-4">
                        {% if team.avatarPath is defined and team.avatarPath %}
                            <img src="{{ team.avatarPath }}" alt="{{ team.name }}" class="h-12 w-12 rounded-full object-cover border border-gray-200">
                        {% else %}
                            <div class="h-12 w-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xl shrink-0">
                                {{ team.name|first|upper }}
                            </div>
                        {% endif %}
                        <div class="min-w-0">
                            <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition truncate">
                                {{ team.name }}
                            </h3>
                            {% if team.status is defined %}
                                <span class="text-xs text-gray-400">{{ team.status.value }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center justify-between text-xs text-gray-400">
                        <span>Tableau de bord</span>
                        <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
