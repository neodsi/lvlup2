{% extends 'layout/app.html.twig' %}

{% block title %}Créer votre profil — LVL UP{% endblock %}

{% block app_content %}
<div class="py-8">

    <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-gray-900">Créer votre profil</h1>
        <p class="mt-1 text-sm text-gray-500">Renseignez vos informations personnelles pour continuer.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        {{ form_start(form, {action: path('app_setup_profile'), attr: {class: 'divide-y divide-gray-100'}}) }}

            <div class="px-6 py-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                    <div>
                        {{ form_label(form.firstName) }}
                        {{ form_widget(form.firstName) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.firstName) }}</div>
                    </div>

                    <div>
                        {{ form_label(form.lastName) }}
                        {{ form_widget(form.lastName) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.lastName) }}</div>
                    </div>

                    <div>
                        {{ form_label(form.dob) }}
                        {{ form_widget(form.dob) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.dob) }}</div>
                    </div>

                    <div>
                        {{ form_label(form.gender) }}
                        {{ form_widget(form.gender) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.gender) }}</div>
                    </div>

                    <div class="sm:col-span-2">
                        {{ form_label(form.phone) }}
                        {{ form_widget(form.phone) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.phone) }}</div>
                    </div>

                </div>
            </div>

            <div class="px-6 py-4 bg-gray-50 rounded-b-xl flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <span class="h-2 w-6 rounded-full bg-gray-200"></span>
                    <span class="h-2 w-8 rounded-full bg-indigo-600"></span>
                    <span class="h-2 w-2 rounded-full bg-gray-200"></span>
                </div>
                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                    Continuer
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </button>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
