{% extends 'layout/app.html.twig' %}

{% block title %}Créer une école — LVL UP{% endblock %}

{% block app_content %}
<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8 text-center">
        <div class="mb-4 flex justify-center">
            <div class="h-14 w-14 rounded-full bg-indigo-100 flex items-center justify-center">
                <svg class="h-7 w-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Créer votre école</h1>
        <p class="mt-1 text-sm text-gray-500">Votre espace sera disponible immédiatement après création.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        {{ form_start(form, { attr: { class: 'divide-y divide-gray-100' } }) }}

            <div class="px-6 py-5 space-y-4">

                <div>
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    <div class="mt-1 text-xs text-red-500">{{ form_errors(form.name) }}</div>
                </div>

                <div>
                    <p class="block text-sm font-medium text-gray-700 mb-2">Type de structure <span class="text-red-500">*</span></p>
                    <div class="grid grid-cols-1 gap-3" x-data="{ selected: '{{ form.type.vars.value ?: 'school' }}' }">

                        {{ form_widget(form.type, { attr: { ':value': 'selected' } }) }}

                        {% set types = [
                            { value: 'school',               icon: 'university',    label: 'École',                    desc: 'Gérez votre école, vos cours, vos élèves et vos paiements.' },
                            { value: 'independent_teacher',  icon: 'person',        label: 'Professeur indépendant',   desc: 'Créez votre structure et gérez vos cours et vos élèves.' },
                            { value: 'association',          icon: 'association',   label: 'Association',              desc: 'Gérez votre association sportive ou culturelle.' },
                        ] %}

                        {% for t in types %}
                        <label
                            class="flex items-start gap-4 p-4 rounded-xl border-2 cursor-pointer transition"
                            :class="selected === '{{ t.value }}' ? 'border-indigo-500 bg-indigo-50' : 'border-gray-200 hover:border-gray-300 bg-white'"
                            @click="selected = '{{ t.value }}'"
                        >
                            <div class="shrink-0 mt-0.5 w-10 h-10 rounded-lg flex items-center justify-center transition"
                                 :class="selected === '{{ t.value }}' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-500'">
                                {% if t.icon == 'university' %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                {% elseif t.icon == 'person' %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                {% else %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-semibold text-gray-900">{{ t.label }}</p>
                                <p class="text-xs text-gray-500 mt-0.5">{{ t.desc }}</p>
                            </div>
                            <div class="shrink-0 mt-1 w-4 h-4 rounded-full border-2 flex items-center justify-center transition"
                                 :class="selected === '{{ t.value }}' ? 'border-indigo-500' : 'border-gray-300'">
                                <div class="w-2 h-2 rounded-full bg-indigo-500 transition"
                                     :class="selected === '{{ t.value }}' ? 'opacity-100' : 'opacity-0'"></div>
                            </div>
                        </label>
                        {% endfor %}

                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.type) }}</div>

                    </div>
                </div>

            </div>

            <div class="px-6 py-4 bg-gray-50 rounded-b-xl flex items-center justify-between">
                <a href="{{ path('app_home') }}" class="text-sm font-medium text-gray-600 hover:text-gray-800 transition">
                    Annuler
                </a>
                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                    Créer mon école
                </button>
            </div>

        {{ form_end(form) }}
    </div>


</div>
{% endblock %}
