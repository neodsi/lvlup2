{% extends 'layout/app.html.twig' %}

{% block title %}Créer une école — LvlUp{% endblock %}

{% block app_content %}
<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8 text-center">
        <div class="mb-4 flex justify-center">
            <div class="h-14 w-14 rounded-full bg-indigo-100 flex items-center justify-center">
                <svg class="h-7 w-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Créer votre école</h1>
        <p class="mt-1 text-sm text-gray-500">Votre demande sera examinée par notre équipe avant activation.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <form method="post" action="{{ path('app_create_school') }}" class="divide-y divide-gray-100">

            <div class="px-6 py-5 space-y-4">

                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                        Nom de l'école <span class="text-red-500">*</span>
                    </label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        value="{{ formData.name }}"
                        required
                        autofocus
                        placeholder="Ex : Académie de danse Étoile"
                        class="block w-full rounded-lg border {{ errors.name is defined ? 'border-red-400' : 'border-gray-300' }} bg-white px-3 py-2.5 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
                    >
                    {% if errors.name is defined %}
                        <p class="mt-1 text-xs text-red-600">{{ errors.name }}</p>
                    {% endif %}
                </div>

                <div>
                    <label for="type" class="block text-sm font-medium text-gray-700 mb-1">
                        Type d'école
                    </label>
                    <select
                        id="type"
                        name="type"
                        class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
                    >
                        <option value="">— Choisir —</option>
                        <option value="dance" {{ formData.type == 'dance' ? 'selected' : '' }}>Danse</option>
                        <option value="martial_arts" {{ formData.type == 'martial_arts' ? 'selected' : '' }}>Arts martiaux</option>
                        <option value="music" {{ formData.type == 'music' ? 'selected' : '' }}>Musique</option>
                        <option value="sport" {{ formData.type == 'sport' ? 'selected' : '' }}>Sport</option>
                        <option value="other" {{ formData.type == 'other' ? 'selected' : '' }}>Autre</option>
                    </select>
                </div>

            </div>

            <div class="px-6 py-4 bg-gray-50 rounded-b-xl flex items-center justify-between">
                <a href="{{ path('app_home') }}" class="text-sm font-medium text-gray-600 hover:text-gray-800 transition">
                    Annuler
                </a>
                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                    Soumettre la demande
                </button>
            </div>

        </form>
    </div>

    <p class="mt-4 text-center text-xs text-gray-400">
        Votre école sera activée après validation par notre équipe.
    </p>

</div>
{% endblock %}
