{% extends 'layout/app.html.twig' %}

{% block title %}Bienvenue — LVL UP{% endblock %}

{% block app_content %}
<div class="min-h-[calc(100vh-3.5rem)] flex items-center justify-center px-4 py-12">
    <div class="max-w-lg w-full text-center">

        <div class="mb-6 flex justify-center">
            <div class="h-20 w-20 rounded-full bg-indigo-100 flex items-center justify-center">
                <svg class="h-10 w-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
            </div>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 mb-3">Bienvenue sur LVL UP !</h1>
        <p class="text-gray-500 mb-8 max-w-sm mx-auto">
            Pour commencer, créons votre profil. Cela ne prendra que quelques secondes.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
                href="{{ path('app_setup_profile') }}"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-3 rounded-lg transition-colors"
            >
                Créer mon profil
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
        </div>

        {# Step indicators #}
        <div class="mt-10 flex items-center justify-center gap-2">
            <span class="h-2 w-8 rounded-full bg-indigo-600"></span>
            <span class="h-2 w-2 rounded-full bg-gray-200"></span>
            <span class="h-2 w-2 rounded-full bg-gray-200"></span>
        </div>
        <p class="mt-2 text-xs text-gray-400">Étape 1 sur 3</p>

    </div>
</div>
{% endblock %}
