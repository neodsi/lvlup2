{% extends 'layout/app.html.twig' %}

{% block title %}Tableau de bord élève{% endblock %}

{% block app_content %}
<div class="px-6 py-8">

    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Tableau de bord</h1>
        <p class="text-sm text-gray-500 mt-1">Espace élève</p>
    </div>

    {% if schools is empty %}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center">
        <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        <p class="text-sm font-medium text-gray-500">Vous n'êtes inscrit dans aucune école pour le moment.</p>
    </div>
    {% else %}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for school in schools %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 flex items-center gap-4">
            {% if school.logoPath %}
            <img src="{{ school.logoPath | imagine_filter('school_logo') }}" alt="{{ school.name }}"
                 class="h-12 w-12 rounded-lg object-contain border border-gray-100 shrink-0">
            {% else %}
            <span class="h-12 w-12 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-lg shrink-0">
                {{ school.name|first|upper }}
            </span>
            {% endif %}
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 truncate">{{ school.name }}</p>
                <p class="text-xs text-indigo-400 mt-0.5">Élève</p>
            </div>
        </div>
        {% endfor %}
    </div>


    {% endif %}

</div>
{% endblock %}
