{% extends 'email/base.html.twig' %}

{% block title %}
  {% if is_new_account %}Votre compte sur {{ team.name }} – LVL UP{% else %}Vous avez été ajouté(e) à {{ team.name }} – LVL UP{% endif %}
{% endblock %}

{% block extra_styles %}
  .team-card { background: #eef2ff; border-radius: 10px; padding: 20px 24px; margin-bottom: 28px; }
  .team-card .team-name { font-size: 18px; font-weight: 700; color: #3730a3; }
{% endblock %}

{% block body %}
  {% if is_new_account %}

    <h1>Votre compte a été créé !</h1>
    <p>Bonjour,</p>
    <p>Un compte a été créé pour vous sur <strong>LVL UP</strong> par :</p>
    <div class="team-card">
      <div class="team-name">{{ team.name }}</div>
    </div>
    <p>Votre adresse e-mail de connexion est : <strong>{{ user.email }}</strong></p>
    <p>Pour accéder à votre espace, commencez par définir votre mot de passe en cliquant sur le bouton ci-dessous :</p>
    <div class="btn-wrap">
      <a class="btn" href="{{ reset_url }}">Définir mon mot de passe</a>
    </div>
    <div class="notice">
      Ce lien est valable pendant <strong>30 jours</strong>. Passé ce délai, utilisez la page de réinitialisation de mot de passe pour en demander un nouveau.
    </div>
    <p style="font-size:13px; color:#71717a;">Si vous ne vous attendiez pas à recevoir cet e-mail, vous pouvez l'ignorer.</p>

  {% else %}

    <h1>Vous avez été ajouté(e) à une école !</h1>
    <p>Bonjour,</p>
    <p>Votre profil a été ajouté à l'école suivante sur <strong>LVL UP</strong> :</p>
    <div class="team-card">
      <div class="team-name">{{ team.name }}</div>
    </div>
    <p>Vous pouvez vous connecter avec votre adresse e-mail habituelle : <strong>{{ user.email }}</strong></p>
    <p style="font-size:13px; color:#71717a;">Si vous ne vous attendiez pas à recevoir cet e-mail, vous pouvez l'ignorer.</p>

  {% endif %}
{% endblock %}
