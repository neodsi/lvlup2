{% extends 'email/base.html.twig' %}

{% block title %}
  {%- if day_offset < 0 -%}Rappel de paiement – dans {{ day_offset|abs }} jour(s) – LVL UP
  {%- elseif day_offset == 0 -%}Votre paiement est dû aujourd'hui – LVL UP
  {%- else -%}Paiement en retard – {{ day_offset }} jour(s) – LVL UP
  {%- endif -%}
{% endblock %}

{% block extra_styles %}
  .banner { padding: 14px 40px; font-weight: 700; font-size: 14px; text-align: center; }
  .banner-upcoming { background: #eef2ff; color: #3730a3; }
  .banner-today    { background: #ffedd5; color: #9a3412; }
  .banner-overdue  { background: #fee2e2; color: #991b1b; }
  .summary { border: 1px solid #e4e4e7; border-radius: 10px; overflow: hidden; margin-bottom: 28px; }
  .summary-row { display: flex; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid #f4f4f5; font-size: 14px; }
  .summary-row:last-child { border-bottom: none; }
  .summary-row .label { color: #71717a; }
  .summary-row .value { font-weight: 600; color: #18181b; }
{% endblock %}

{% block body %}
  {# Banner affiché entre le header et le body — inline via padding négatif #}
  <div style="margin: -40px -40px 32px -40px;">
    {% if day_offset < 0 %}
      <div class="banner banner-upcoming">Paiement prévu dans {{ day_offset|abs }} jour(s) – le {{ schedule.dueAt|date('d/m/Y') }}</div>
    {% elseif day_offset == 0 %}
      <div class="banner banner-today">Votre paiement est dû aujourd'hui</div>
    {% else %}
      <div class="banner banner-overdue">Paiement en retard de {{ day_offset }} jour(s) – échu le {{ schedule.dueAt|date('d/m/Y') }}</div>
    {% endif %}
  </div>

  {% if day_offset < 0 %}
    <h1>Rappel de paiement à venir</h1>
    <p>Bonjour {{ profile.firstName }},</p>
    <p>Nous vous rappelons qu'un paiement est prévu dans <strong>{{ day_offset|abs }} jour(s)</strong>. Assurez-vous que vos coordonnées bancaires sont à jour.</p>
  {% elseif day_offset == 0 %}
    <h1>Votre paiement est dû aujourd'hui</h1>
    <p>Bonjour {{ profile.firstName }},</p>
    <p>Un paiement arrive à échéance <strong>aujourd'hui</strong>. Pensez à le régler dès que possible pour éviter tout retard.</p>
  {% else %}
    <h1>Paiement en retard</h1>
    <p>Bonjour {{ profile.firstName }},</p>
    <p>Un paiement est en retard de <strong>{{ day_offset }} jour(s)</strong>. Merci de le régulariser au plus vite.</p>
  {% endif %}

  <div class="summary">
    <div class="summary-row">
      <span class="label">Référence</span>
      <span class="value">{{ schedule.id|slice(0, 8)|upper }}</span>
    </div>
    <div class="summary-row">
      <span class="label">Profil</span>
      <span class="value">{{ profile.firstName }} {{ profile.lastName }}</span>
    </div>
    <div class="summary-row">
      <span class="label">Montant dû</span>
      <span class="value">{{ (schedule.amount / 100)|number_format(2, ',', ' ') }} €</span>
    </div>
    <div class="summary-row">
      <span class="label">Date d'échéance</span>
      <span class="value">{{ schedule.dueAt|date('d/m/Y') }}</span>
    </div>
  </div>

  <div class="btn-wrap">
    <a class="btn" href="{{ app.request is defined ? app.request.schemeAndHttpHost : '' }}/mon-compte/paiements">
      Accéder à mes paiements
    </a>
  </div>

  <p>En cas de difficulté, contactez-nous et nous trouverons une solution ensemble.</p>
{% endblock %}
