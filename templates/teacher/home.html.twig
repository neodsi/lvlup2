{% extends 'layout/app.html.twig' %}

{% block title %}Tableau de bord enseignant{% endblock %}

{% block app_content %}
<div class="px-6 py-8">

    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Tableau de bord</h1>
        <p class="text-sm text-gray-500 mt-1">Espace enseignant</p>
    </div>

    {% if schools is empty %}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center">
        <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <p class="text-sm font-medium text-gray-500">Vous n'êtes rattaché à aucune école en tant qu'enseignant.</p>
    </div>
    {% else %}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for school in schools %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 flex items-center gap-4">
            {% if school.logoPath %}
            <img src="{{ school.logoPath | imagine_filter('school_logo') }}" alt="{{ school.name }}"
                 class="h-12 w-12 rounded-lg object-contain border border-gray-100 shrink-0">
            {% else %}
            <span class="h-12 w-12 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center font-bold text-lg shrink-0">
                {{ school.name|first|upper }}
            </span>
            {% endif %}
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 truncate">{{ school.name }}</p>
                <p class="text-xs text-purple-500 mt-0.5">Enseignant</p>
            </div>
        </div>
        {% endfor %}
    </div>

    {% endif %}

</div>
{% endblock %}
