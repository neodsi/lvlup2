{% extends 'layout/school.html.twig' %}

{% block title %}Comptage rapide — {{ team.name }}{% endblock %}

{% block school_content %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('school_home') }}" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Comptage rapide</h1>
            <p class="text-sm text-gray-500">Décompte des cours à la carte</p>
        </div>
    </div>

    {% if packages is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            <p class="text-gray-500 text-sm">Aucun carnet de cours à la carte actif.</p>
        </div>
    {% else %}
        <div
            class="space-y-4"
            x-data="{
                packages: {{ packages|map(p => {
                    id: p.id,
                    name: p.profile is defined ? (p.profile.firstName ~ ' ' ~ p.profile.lastName) : 'Inconnu',
                    remaining: p.remainingQty ?? p.classesQty ?? 0,
                    original: p.classesQty ?? 0
                })|json_encode|raw }},
                decrement(index) {
                    if (this.packages[index].remaining > 0) {
                        this.packages[index].remaining--;
                    }
                },
                reset(index) {
                    this.packages[index].remaining = this.packages[index].original;
                }
            }"
        >
            <template x-for="(pkg, index) in packages" :key="pkg.id">
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="flex items-center justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-gray-900" x-text="pkg.name"></p>
                            <p class="text-xs text-gray-400 mt-0.5">
                                Cours restants :
                                <span
                                    class="font-bold"
                                    :class="pkg.remaining === 0 ? 'text-red-600' : pkg.remaining <= 2 ? 'text-amber-600' : 'text-green-600'"
                                    x-text="pkg.remaining"
                                ></span>
                                / <span x-text="pkg.original"></span>
                            </p>
                        </div>

                        {# Progress bar #}
                        <div class="hidden sm:block w-24">
                            <div class="h-2 rounded-full bg-gray-100 overflow-hidden">
                                <div
                                    class="h-full rounded-full transition-all duration-300"
                                    :class="pkg.remaining === 0 ? 'bg-red-400' : pkg.remaining / pkg.original <= 0.25 ? 'bg-amber-400' : 'bg-green-400'"
                                    :style="'width: ' + (pkg.original > 0 ? Math.round(pkg.remaining / pkg.original * 100) : 0) + '%'"
                                ></div>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 shrink-0">
                            <button
                                @click="reset(index)"
                                title="Réinitialiser"
                                class="h-9 w-9 rounded-lg border border-gray-200 flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-50 transition"
                            >
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            </button>
                            <button
                                @click="decrement(index)"
                                :disabled="pkg.remaining === 0"
                                class="h-9 w-9 rounded-lg flex items-center justify-center font-bold text-white transition focus:outline-none"
                                :class="pkg.remaining === 0 ? 'bg-gray-200 text-gray-400 cursor-not-allowed' : 'bg-indigo-600 hover:bg-indigo-700'"
                            >
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4"/></svg>
                            </button>
                        </div>
                    </div>

                    <div x-show="pkg.remaining === 0" x-transition class="mt-3 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-xs text-red-700 font-medium">
                        Plus de cours disponibles.
                    </div>
                </div>
            </template>
        </div>
    {% endif %}

</div>
{% endblock %}
