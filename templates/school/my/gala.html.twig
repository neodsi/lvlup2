{% extends 'layout/school.html.twig' %}

{% block title %}Ma participation au Gala{% endblock %}

{% block school_content %}

    <header class="bg-white border-b border-gray-200">
        <div class="py-4">
            <h1 class="text-2xl font-bold text-gray-900">Participation au Gala</h1>
            <p class="text-sm text-gray-500 mt-0.5">Indiquez si vous souhaitez participer au gala de fin de saison.</p>
        </div>
    </header>

    <div class="py-8">

        {% if gala_events is not defined or gala_events is empty %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-16 text-center">
                <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
                <p class="mt-4 text-sm font-medium text-gray-700">Aucun gala programmé</p>
                <p class="mt-1 text-sm text-gray-400">Aucun événement gala n'est configuré pour la saison courante.</p>
            </div>
        {% else %}
            <div class="space-y-6">
                {% for event in gala_events %}
                    {% set participation = null %}
                    {% if participations is defined %}
                        {% for p in participations %}
                            {% if p.eventId == event.id %}{% set participation = p %}{% endif %}
                        {% endfor %}
                    {% endif %}

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                        {# Event header #}
                        <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between gap-4">
                            <div>
                                <h2 class="text-base font-semibold text-gray-900">{{ event.name }}</h2>
                                <p class="text-sm text-gray-500 mt-0.5">{{ event.startAt|date('d/m/Y à H:i') }}</p>
                            </div>
                            {% if participation %}
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium
                                    {% if participation.participates == true %}bg-green-50 text-green-700
                                    {% elseif participation.participates == false %}bg-red-50 text-red-600
                                    {% else %}bg-gray-100 text-gray-500{% endif %}">
                                    {% if participation.participates == true %}Participe
                                    {% elseif participation.participates == false %}Ne participe pas
                                    {% else %}En attente de réponse{% endif %}
                                </span>
                            {% endif %}
                        </div>

                        {# Participation form #}
                        <form method="POST" action="#" class="px-6 py-5 space-y-5">
                            <input type="hidden" name="_token" value="{{ csrf_token('gala_participation_' ~ event.id) }}">
                            <input type="hidden" name="eventId" value="{{ event.id }}">

                            <div>
                                <p class="text-sm font-medium text-gray-700 mb-3">Souhaitez-vous participer à ce gala ?</p>
                                <div class="flex flex-col sm:flex-row gap-3">
                                    {# Yes option #}
                                    <label class="flex-1 relative">
                                        <input type="radio" name="participates" value="1"
                                               {% if participation and participation.participates == true %}checked{% endif %}
                                               class="peer sr-only">
                                        <div class="flex items-center gap-3 border-2 border-gray-200 peer-checked:border-green-500 peer-checked:bg-green-50 rounded-xl px-4 py-4 cursor-pointer transition-all hover:border-green-300">
                                            <div class="w-10 h-10 rounded-full bg-green-100 peer-checked:bg-green-200 flex items-center justify-center flex-shrink-0">
                                                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-gray-900">Oui, je participe</p>
                                                <p class="text-xs text-gray-500">Je confirme ma participation au gala</p>
                                            </div>
                                        </div>
                                    </label>

                                    {# No option #}
                                    <label class="flex-1 relative">
                                        <input type="radio" name="participates" value="0"
                                               {% if participation and participation.participates == false %}checked{% endif %}
                                               class="peer sr-only">
                                        <div class="flex items-center gap-3 border-2 border-gray-200 peer-checked:border-red-400 peer-checked:bg-red-50 rounded-xl px-4 py-4 cursor-pointer transition-all hover:border-red-300">
                                            <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0">
                                                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-gray-900">Non, je ne participe pas</p>
                                                <p class="text-xs text-gray-500">Je ne pourrai pas être présent(e)</p>
                                            </div>
                                        </div>
                                    </label>

                                    {# Pending / undecided option #}
                                    <label class="flex-1 relative">
                                        <input type="radio" name="participates" value=""
                                               {% if not participation or participation.participates is null %}checked{% endif %}
                                               class="peer sr-only">
                                        <div class="flex items-center gap-3 border-2 border-gray-200 peer-checked:border-amber-400 peer-checked:bg-amber-50 rounded-xl px-4 py-4 cursor-pointer transition-all hover:border-amber-300">
                                            <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center flex-shrink-0">
                                                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-gray-900">Je ne sais pas encore</p>
                                                <p class="text-xs text-gray-500">Je répondrai plus tard</p>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            {# Notes #}
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Commentaire <span class="text-gray-400 font-normal">(facultatif)</span>
                                </label>
                                <textarea name="notes" rows="3"
                                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none"
                                          placeholder="Informations complémentaires…">{{ participation ? participation.notes : '' }}</textarea>
                            </div>

                            <div class="flex justify-end">
                                <button type="submit"
                                        class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                    Enregistrer ma réponse
                                </button>
                            </div>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

