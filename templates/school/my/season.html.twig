{% extends 'base.html.twig' %}

{% block title %}Ma saison{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    <header class="bg-white border-b border-gray-200">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <h1 class="text-2xl font-bold text-gray-900">Ma saison</h1>
            <p class="text-sm text-gray-500 mt-0.5">
                {% if season is defined and season %}{{ season.name }}{% else %}Saison courante{% endif %}
            </p>
        </div>
    </header>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
                <div class="rounded-lg px-4 py-3 text-sm font-medium
                    {% if label == 'success' %}bg-green-50 text-green-800 border border-green-200
                    {% else %}bg-red-50 text-red-800 border border-red-200{% endif %}">
                    {{ message }}
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">

        {% set registration = teamProfileSeason is defined ? teamProfileSeason : (registration is defined ? registration : null) %}
        {% if registration is null %}
            {# Not registered #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-16 text-center">
                <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="mt-4 text-sm font-medium text-gray-700">Non inscrit à cette saison</p>
                <p class="mt-1 text-sm text-gray-400">Votre inscription n'a pas encore été enregistrée pour la saison courante.</p>
            </div>
        {% else %}

            {# Registration status card #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Statut d'inscription</h2>
                </div>
                <div class="px-6 py-5">
                    {% set regStatus = registration.registrationStatus.value %}
                    <div class="flex items-center gap-4">
                        <div class="w-14 h-14 rounded-full flex items-center justify-center
                            {% if regStatus == 'registered' %}bg-green-50
                            {% elseif regStatus == 'pending' %}bg-amber-50
                            {% elseif regStatus == 'cancelled' %}bg-red-50
                            {% else %}bg-gray-100{% endif %}">
                            {% if regStatus == 'registered' %}
                                <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% elseif regStatus == 'pending' %}
                                <svg class="w-7 h-7 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% elseif regStatus == 'cancelled' %}
                                <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% else %}
                                <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% endif %}
                        </div>
                        <div>
                            <p class="text-lg font-semibold text-gray-900">
                                {% if regStatus == 'registered' %}Inscrit(e)
                                {% elseif regStatus == 'pending' %}Inscription en attente
                                {% elseif regStatus == 'cancelled' %}Inscription annulée
                                {% elseif regStatus == 'not_registered' %}Non inscrit(e)
                                {% else %}{{ regStatus }}{% endif %}
                            </p>
                            <p class="text-sm text-gray-500 mt-0.5">Mise à jour le {{ registration.updatedAt|date('d/m/Y à H:i') }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Informations saison #}
            {% if season is defined and season %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                    <div class="px-6 py-5 border-b border-gray-100">
                        <h2 class="text-base font-semibold text-gray-900">Informations saison</h2>
                    </div>
                    <dl class="px-6 py-5 grid grid-cols-2 gap-4 text-sm">
                        <div>
                            <dt class="font-medium text-gray-700">Saison</dt>
                            <dd class="mt-1 text-gray-900">{{ season.name }}</dd>
                        </div>
                        <div>
                            <dt class="font-medium text-gray-700">Période</dt>
                            <dd class="mt-1 text-gray-900">{{ season.startAt|date('d/m/Y') }} — {{ season.endAt|date('d/m/Y') }}</dd>
                        </div>
                    </dl>
                </div>
            {% endif %}

            {# Registration details #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Détails de mon inscription</h2>
                </div>
                <dl class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                    {% if registration.ageGroupId %}
                        <div>
                            <dt class="font-medium text-gray-700">Groupe d'âge</dt>
                            <dd class="mt-1 text-gray-500 font-mono text-xs">{{ registration.ageGroupId }}</dd>
                        </div>
                    {% endif %}
                    {% if registration.levelId %}
                        <div>
                            <dt class="font-medium text-gray-700">Niveau</dt>
                            <dd class="mt-1 text-gray-500 font-mono text-xs">{{ registration.levelId }}</dd>
                        </div>
                    {% endif %}
                    {% if registration.topSize %}
                        <div>
                            <dt class="font-medium text-gray-700">Taille haut</dt>
                            <dd class="mt-1 text-gray-900">{{ registration.topSize }}</dd>
                        </div>
                    {% endif %}
                    {% if registration.bottomSize %}
                        <div>
                            <dt class="font-medium text-gray-700">Taille bas</dt>
                            <dd class="mt-1 text-gray-900">{{ registration.bottomSize }}</dd>
                        </div>
                    {% endif %}
                    {% if registration.feetSize %}
                        <div>
                            <dt class="font-medium text-gray-700">Pointure</dt>
                            <dd class="mt-1 text-gray-900">{{ registration.feetSize }}</dd>
                        </div>
                    {% endif %}
                    {% if registration.injuryWarning %}
                        <div class="col-span-2">
                            <dt class="font-medium text-gray-700">Avertissement blessure</dt>
                            <dd class="mt-1 text-amber-700 bg-amber-50 rounded-lg px-3 py-2 text-xs">{{ registration.injuryWarning }}</dd>
                        </div>
                    {% endif %}
                </dl>
            </div>

            {# Emergency contact #}
            {% if registration.emergencyContact %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                    <div class="px-6 py-5 border-b border-gray-100">
                        <h2 class="text-base font-semibold text-gray-900">Contact d'urgence</h2>
                    </div>
                    <dl class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        {% for key, value in registration.emergencyContact %}
                            <div>
                                <dt class="font-medium text-gray-700 capitalize">{{ key|replace({'_': ' '}) }}</dt>
                                <dd class="mt-1 text-gray-900">{{ value }}</dd>
                            </div>
                        {% endfor %}
                    </dl>
                </div>
            {% endif %}

        {% endif %}
    </div>
</div>
{% endblock %}
