{% extends 'layout/school.html.twig' %}

{% block title %}Mes forfaits{% endblock %}

{% block school_content %}
<div class="py-8">

    <h1 class="text-2xl font-bold text-gray-900 mb-1">Mes forfaits</h1>
    <p class="text-sm text-gray-500 mb-6">Vos abonnements et pass pour la saison en cours.</p>

    {% if packages is empty %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-12 text-center">
            <svg class="mx-auto w-10 h-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <p class="text-sm font-medium text-gray-700">Aucun forfait</p>
            <p class="mt-1 text-xs text-gray-400">Vous n'avez pas encore de forfait pour la saison courante.</p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for pkg in packages %}
                {% set pkgDef = packageById[pkg.packageId] ?? null %}
                {% set typeLabel = pkg.type == 'a_la_carte' ? 'À la carte'
                    : (pkg.type == 'subscription_one_year' ? 'Abonnement annuel'
                    : (pkg.type == 'subscription_one_semester' ? 'Abonnement semestre'
                    : (pkg.type == 'trial_class' ? "Cours d'essai"
                    : pkg.type))) %}
                {% set vs = pkg.validityStatus ?? null %}
                {% set statusVal = pkg.status.value ?? '' %}

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-5 py-4">

                        {# Nom + badges #}
                        <div class="flex items-start justify-between gap-3 mb-3">
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-gray-900 truncate">
                                    {{ pkgDef ? pkgDef.name : typeLabel }}
                                </p>
                                {% if pkgDef %}
                                    <p class="text-xs text-gray-400 mt-0.5">{{ typeLabel }}</p>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-1.5 shrink-0 flex-wrap justify-end">
                                {# Statut validité #}
                                {% if vs %}
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium border
                                        {% if vs == 'valid' or vs == 'active' %}bg-green-50 text-green-700 border-green-200
                                        {% elseif vs == 'expired' %}bg-red-50 text-red-600 border-red-200
                                        {% elseif vs == 'pending' %}bg-amber-50 text-amber-700 border-amber-200
                                        {% else %}bg-gray-50 text-gray-500 border-gray-200{% endif %}">
                                        {% if vs == 'valid' or vs == 'active' %}Actif
                                        {% elseif vs == 'expired' %}Expiré
                                        {% elseif vs == 'pending' %}En attente
                                        {% else %}{{ vs }}{% endif %}
                                    </span>
                                {% endif %}
                                {# Statut forfait si pertinent #}
                                {% if statusVal and statusVal != 'active' and statusVal != 'pending' %}
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium border bg-gray-50 text-gray-500 border-gray-200">
                                        {{ statusVal }}
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        {# Barre de progression (carnet de cours) #}
                        {% if pkg.classesQty and pkg.classesQty > 0 %}
                            {% set usedPct = ((pkg.classesDone / pkg.classesQty) * 100)|round %}
                            <div class="mb-3">
                                <div class="flex justify-between text-xs text-gray-500 mb-1">
                                    <span>{{ pkg.classesDone }} cours utilisé{{ pkg.classesDone > 1 ? 's' : '' }}</span>
                                    <span>{{ pkg.classesQty - pkg.classesDone }} restant{{ (pkg.classesQty - pkg.classesDone) > 1 ? 's' : '' }}</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
                                    <div class="h-1.5 rounded-full transition-all
                                        {% if usedPct >= 100 %}bg-red-400
                                        {% elseif usedPct >= 75 %}bg-amber-400
                                        {% else %}bg-indigo-500{% endif %}"
                                         style="width: {{ min(usedPct, 100) }}%"></div>
                                </div>
                            </div>
                        {% endif %}

                        {# Dates #}
                        {% if pkg.validityStartsAt or pkg.expiresAt %}
                            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-400">
                                {% if pkg.validityStartsAt %}
                                    <span>Début : <span class="text-gray-600">{{ pkg.validityStartsAt|date('d/m/Y') }}</span></span>
                                {% endif %}
                                {% if pkg.expiresAt %}
                                    <span class="{% if vs == 'expired' %}text-red-500{% endif %}">
                                        Expire : <span class="{% if vs == 'expired' %}text-red-600 font-medium{% else %}text-gray-600{% endif %}">{{ pkg.expiresAt|date('d/m/Y') }}</span>
                                    </span>
                                {% endif %}
                            </div>
                        {% endif %}

                    </div>
                    <div class="px-5 py-2 bg-gray-50 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400">
                        <span>Attribué le {{ pkg.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
