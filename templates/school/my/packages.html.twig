{% extends 'layout/school.html.twig' %}

{% block title %}Mes forfaits{% endblock %}

{% block school_content %}

    <header class="bg-white border-b border-gray-200">
        <div class="py-4">
            <h1 class="text-2xl font-bold text-gray-900">Mes forfaits</h1>
            <p class="text-sm text-gray-500 mt-0.5">Vos abonnements et pass pour la saison en cours.</p>
        </div>
    </header>

    <div class="py-8">
        {% if packages is not defined or packages is empty %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-16 text-center">
                <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                <p class="mt-4 text-sm font-medium text-gray-700">Aucun forfait</p>
                <p class="mt-1 text-sm text-gray-400">Vous n'avez pas encore de forfait pour la saison courante.</p>
            </div>
        {% else %}
            <div class="space-y-4">
                {% for pkg in packages %}
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                        <div class="px-6 py-4 flex items-start justify-between gap-4">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="text-sm font-semibold text-gray-900">{{ pkg.type }}</h3>
                                    {# Validity status badge #}
                                    {% set validity = pkg.validityStatus ?? 'unknown' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if validity == 'valid' or validity == 'active' %}bg-green-50 text-green-700
                                        {% elseif validity == 'expired' %}bg-red-50 text-red-600
                                        {% elseif validity == 'pending' %}bg-amber-50 text-amber-700
                                        {% else %}bg-gray-100 text-gray-500{% endif %}">
                                        {% if validity == 'valid' or validity == 'active' %}Actif
                                        {% elseif validity == 'expired' %}Expiré
                                        {% elseif validity == 'pending' %}En attente
                                        {% else %}{{ validity }}{% endif %}
                                    </span>
                                    {# Package status #}
                                    {% set pkgStatus = pkg.status.value ?? '' %}
                                    {% if pkgStatus and pkgStatus != 'pending' %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                                            {{ pkgStatus }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500 mt-1">
                                    {% if pkg.classesQty %}
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                                            {{ pkg.classesDone }}/{{ pkg.classesQty }} cours
                                        </span>
                                    {% endif %}
                                    {% if pkg.validityStartsAt %}
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            Début : {{ pkg.validityStartsAt|date('d/m/Y') }}
                                        </span>
                                    {% endif %}
                                    {% if pkg.expiresAt %}
                                        <span class="flex items-center gap-1 {% if validity == 'expired' %}text-red-500{% endif %}">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            Expire : {{ pkg.expiresAt|date('d/m/Y') }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            {# Usage progress bar for class packs #}
                            {% if pkg.classesQty and pkg.classesQty > 0 %}
                                <div class="w-32 flex-shrink-0">
                                    {% set usedPct = ((pkg.classesDone / pkg.classesQty) * 100)|round %}
                                    <div class="flex justify-between text-xs text-gray-400 mb-1">
                                        <span>Progression</span>
                                        <span>{{ usedPct }}%</span>
                                    </div>
                                    <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
                                        <div class="{% if usedPct >= 100 %}bg-red-400{% elseif usedPct >= 75 %}bg-amber-400{% else %}bg-indigo-500{% endif %} h-2 rounded-full"
                                             style="width: {{ min(usedPct, 100) }}%"></div>
                                    </div>
                                    <p class="text-xs text-gray-400 mt-1 text-right">{{ pkg.classesDone }} / {{ pkg.classesQty }}</p>
                                </div>
                            {% endif %}
                        </div>
                        <div class="px-6 py-2.5 bg-gray-50 border-t border-gray-100 text-xs text-gray-400 flex items-center justify-between">
                            <span>Attribué le {{ pkg.createdAt|date('d/m/Y') }}</span>
                            <span class="font-mono">{{ pkg.id|slice(0, 8) }}…</span>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

{% endblock %}
