{% extends 'layout/school.html.twig' %}

{% block title %}Commande — {{ school.name }}{% endblock %}

{% block school_content %}
<div class="py-8">

    {# Breadcrumb #}
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="{{ path('school_home') }}" class="hover:text-indigo-600 transition">{{ school.name }}</a>
        <span>/</span>
        <a href="{{ path('school_orders_list') }}" class="hover:text-indigo-600 transition">Commandes</a>
        <span>/</span>
        <span class="text-gray-700 font-medium font-mono">{{ order.invoiceNumber ?? order.id|slice(0, 8) }}</span>
    </div>

    {# Order header #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 px-6 py-5 border-b border-gray-100">
            <div>
                <h1 class="text-xl font-bold text-gray-900">
                    Commande n° {{ order.invoiceNumber ?? order.id|slice(0, 8) }}
                </h1>
                <p class="text-sm text-gray-500 mt-0.5">Créée le {{ order.createdAt|date('d/m/Y à H:i') }}</p>
            </div>
            {% set status = order.status.value ?? order.status ?? 'unknown' %}
            <span class="self-start sm:self-auto inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold
                {% if status == 'paid' %}bg-green-50 text-green-700
                {% elseif status == 'pending' %}bg-amber-50 text-amber-700
                {% elseif status == 'cancelled' %}bg-red-50 text-red-700
                {% else %}bg-gray-100 text-gray-600{% endif %}">
                {% if status == 'paid' %}Payé
                {% elseif status == 'pending' %}En attente
                {% elseif status == 'cancelled' %}Annulé
                {% else %}{{ status }}{% endif %}
            </span>
        </div>
        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 px-6 py-5 text-sm">
            <div>
                <dt class="text-gray-500">Membre</dt>
                <dd class="mt-1 font-medium text-gray-900">
                    {% if order.schoolProfile is defined and order.schoolProfile.profile is defined %}
                        {{ order.schoolProfile.profile.firstName }} {{ order.schoolProfile.profile.lastName }}
                    {% else %}—{% endif %}
                </dd>
            </div>
            <div>
                <dt class="text-gray-500">Montant total</dt>
                <dd class="mt-1 font-bold text-gray-900 text-base">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</dd>
            </div>
            <div>
                <dt class="text-gray-500">Référence interne</dt>
                <dd class="mt-1 text-gray-600 font-mono text-xs">{{ order.id }}</dd>
            </div>
        </dl>
    </div>

    {# Order items #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Articles</h2>
        </div>
        {% if items is empty %}
            <div class="px-6 py-6 text-sm text-gray-400 text-center">Aucun article.</div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Description</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Qté</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">P.U.</th>
                            <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for item in items %}
                            <tr>
                                <td class="py-3.5 pl-6 pr-3 text-sm text-gray-900">{{ item.label ?? item.description ?? '—' }}</td>
                                <td class="px-3 py-3.5 text-sm text-gray-600 text-right">{{ item.quantity ?? 1 }}</td>
                                <td class="px-3 py-3.5 text-sm text-gray-600 text-right">{{ (item.unitAmount / 100)|number_format(2, ',', ' ') }} €</td>
                                <td class="py-3.5 pl-3 pr-6 text-sm font-semibold text-gray-900 text-right">{{ (item.totalAmount / 100)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="bg-gray-50">
                        <tr>
                            <td colspan="3" class="py-3 pl-6 pr-3 text-sm font-semibold text-gray-700 text-right">Total</td>
                            <td class="py-3 pl-3 pr-6 text-sm font-bold text-gray-900 text-right">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        {% endif %}
    </div>

    {# Payment schedules #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Échéancier de paiement</h2>
        </div>
        {% if schedules is empty %}
            <div class="px-6 py-6 text-sm text-gray-400 text-center">Aucune échéance de paiement.</div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Échéance</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Montant</th>
                            <th class="py-3 pl-3 pr-6 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for schedule in schedules %}
                            <tr>
                                <td class="py-3.5 pl-6 pr-3 text-sm text-gray-900">
                                    {{ schedule.dueAt|date('d/m/Y') }}
                                </td>
                                <td class="px-3 py-3.5 text-sm font-semibold text-gray-900 text-right">
                                    {{ (schedule.amount / 100)|number_format(2, ',', ' ') }} €
                                </td>
                                <td class="py-3.5 pl-3 pr-6">
                                    {% set ps = schedule.status.value ?? schedule.status ?? 'pending' %}
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                        {% if ps == 'paid' %}bg-green-50 text-green-700
                                        {% elseif ps == 'pending' %}bg-amber-50 text-amber-700
                                        {% elseif ps == 'failed' %}bg-red-50 text-red-700
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {% if ps == 'paid' %}Payé
                                        {% elseif ps == 'pending' %}À venir
                                        {% elseif ps == 'failed' %}Échoué
                                        {% else %}{{ ps }}{% endif %}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
