{% extends 'layout/school.html.twig' %}

{% block title %}Commandes — {{ team.name }}{% endblock %}

{% block school_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('school_home') }}" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Commandes</h1>
    </div>

    {% if orders is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <p class="text-gray-500 text-sm">Aucune commande trouvée.</p>
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Référence</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Membre</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Montant</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
                            <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for order in orders %}
                            <tr class="hover:bg-gray-50 transition">
                                <td class="py-4 pl-6 pr-3">
                                    <span class="font-mono text-xs text-gray-600">{{ order.invoiceNumber ?? order.id|slice(0, 8) }}</span>
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-900">
                                    {% if order.teamProfile is defined and order.teamProfile.profile is defined %}
                                        {{ order.teamProfile.profile.firstName }} {{ order.teamProfile.profile.lastName }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-3 py-4 text-sm font-semibold text-gray-900">
                                    {{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €
                                </td>
                                <td class="px-3 py-4">
                                    {% set status = order.status.value ?? order.status ?? 'unknown' %}
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                        {% if status == 'paid' %}bg-green-50 text-green-700
                                        {% elseif status == 'pending' %}bg-amber-50 text-amber-700
                                        {% elseif status == 'cancelled' %}bg-red-50 text-red-700
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {% if status == 'paid' %}Payé
                                        {% elseif status == 'pending' %}En attente
                                        {% elseif status == 'cancelled' %}Annulé
                                        {% else %}{{ status }}{% endif %}
                                    </span>
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-500">
                                    {{ order.createdAt|date('d/m/Y') }}
                                </td>
                                <td class="py-4 pl-3 pr-6 text-right">
                                    <a href="{{ path('school_orders_detail', {id: order.id}) }}" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                        Détail
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
