{% extends 'layout/school.html.twig' %}

{% block title %}Paramètres — {{ school.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Paramètres</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Paramètres</h1>

    {% include 'school/settings/_tabs.html.twig' %}

    {# Photo & Logo — upload AJAX indépendant du form #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-6"
         x-data="schoolImages('{{ path('school_settings_image_upload') }}', '{{ path('school_settings_image_delete') }}')">
        <div class="px-6 py-5 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Visuels</h2>
        </div>
        <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-6">

            {# Photo principale #}
            <div>
                <p class="text-sm font-medium text-gray-700 mb-1">Photo principale</p>
                <p class="text-xs text-gray-400 mb-2">Format 16:9 recommandé</p>

                <label x-show="!images.photo.url"
                       class="flex flex-col items-center justify-center h-28 w-full rounded-lg border-2 border-dashed border-gray-200 bg-gray-50 hover:border-indigo-300 hover:bg-indigo-50/50 cursor-pointer transition-colors">
                    <div x-show="images.photo.loading" class="flex flex-col items-center gap-2">
                        <svg class="w-5 h-5 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        <span class="text-xs text-indigo-500">Téléversement…</span>
                    </div>
                    <div x-show="!images.photo.loading" class="flex flex-col items-center gap-1 text-center px-4">
                        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        <span class="text-xs text-gray-400">Cliquer pour choisir</span>
                    </div>
                    <input type="file" class="sr-only" accept="image/*"
                           @change="uploadImage($event, 'photo')" :disabled="images.photo.loading">
                </label>

                <div x-show="images.photo.url" class="relative">
                    <img :src="images.photo.url" alt="Photo"
                         class="w-full h-28 object-contain rounded-lg border border-gray-200 bg-gray-50">
                    <div x-show="images.photo.loading"
                         class="absolute inset-0 flex items-center justify-center rounded-lg bg-white/70">
                        <svg class="w-5 h-5 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                    </div>
                </div>

                <p x-show="images.photo.error" x-text="images.photo.error"
                   class="mt-1 text-xs text-red-600" style="display:none"></p>

                <div x-show="images.photo.url" class="mt-2 flex items-center gap-4" style="display:none">
                    <input type="file" x-ref="photoReplace" class="sr-only" accept="image/*"
                           @change="uploadImage($event, 'photo')">
                    <button type="button" @click="$refs.photoReplace.click()" :disabled="images.photo.loading"
                            class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        Remplacer
                    </button>
                    <button type="button" @click="deleteImage('photo')" :disabled="images.photo.loading"
                            class="inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Supprimer
                    </button>
                </div>
            </div>

            {# Logo #}
            <div>
                <p class="text-sm font-medium text-gray-700 mb-1">Logo</p>
                <p class="text-xs text-gray-400 mb-2">Format carré recommandé</p>

                <label x-show="!images.logo.url"
                       class="flex flex-col items-center justify-center h-28 w-full rounded-lg border-2 border-dashed border-gray-200 bg-gray-50 hover:border-indigo-300 hover:bg-indigo-50/50 cursor-pointer transition-colors">
                    <div x-show="images.logo.loading" class="flex flex-col items-center gap-2">
                        <svg class="w-5 h-5 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        <span class="text-xs text-indigo-500">Téléversement…</span>
                    </div>
                    <div x-show="!images.logo.loading" class="flex flex-col items-center gap-1 text-center px-4">
                        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        <span class="text-xs text-gray-400">Cliquer pour choisir</span>
                    </div>
                    <input type="file" class="sr-only" accept="image/*"
                           @change="uploadImage($event, 'logo')" :disabled="images.logo.loading">
                </label>

                <div x-show="images.logo.url" class="relative">
                    <img :src="images.logo.url" alt="Logo"
                         class="w-full h-28 object-contain rounded-lg border border-gray-200 bg-gray-50 p-2">
                    <div x-show="images.logo.loading"
                         class="absolute inset-0 flex items-center justify-center rounded-lg bg-white/70">
                        <svg class="w-5 h-5 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                    </div>
                </div>

                <p x-show="images.logo.error" x-text="images.logo.error"
                   class="mt-1 text-xs text-red-600" style="display:none"></p>

                <div x-show="images.logo.url" class="mt-2 flex items-center gap-4" style="display:none">
                    <input type="file" x-ref="logoReplace" class="sr-only" accept="image/*"
                           @change="uploadImage($event, 'logo')">
                    <button type="button" @click="$refs.logoReplace.click()" :disabled="images.logo.loading"
                            class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        Remplacer
                    </button>
                    <button type="button" @click="deleteImage('logo')" :disabled="images.logo.loading"
                            class="inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Supprimer
                    </button>
                </div>
            </div>

        </div>
    </div>

    <form method="POST" action="{{ path('school_settings') }}" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('settings_general') }}">

        {# Localisation #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Localisation</h2>
                <p class="text-sm text-gray-500 mt-0.5">La ville est extraite automatiquement de la carte pour construire l'URL publique.</p>
                <p class="text-xs text-amber-600 mt-1 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                    Modifier l'adresse met à jour l'adresse de facturation — pensez à la vérifier dans les <a href="{{ path('school_settings_legal') }}" class="underline hover:text-amber-800 transition">informations légales</a>.
                </p>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div class="flex gap-2">
                    <input type="text" id="address-search" placeholder="Rechercher une adresse…"
                           value="{{ school.addressText ?? '' }}"
                           class="flex-1 block rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <button type="button" id="address-search-btn"
                            class="flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
                        Rechercher
                    </button>
                </div>
                <div id="map" class="rounded-xl border border-gray-200 overflow-hidden" style="height:360px"></div>
                <input type="hidden" id="addressText" name="addressText" value="{{ school.addressText ?? '' }}">
                <input type="hidden" id="addressLat"  name="addressLat"  value="{{ school.addressLat ?? '' }}">
                <input type="hidden" id="addressLng"  name="addressLng"  value="{{ school.addressLng ?? '' }}">
            </div>
        </div>

        {# Informations générales #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Informations générales</h2>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nom de l'école <span class="text-red-500">*</span></label>
                    <input type="text" id="name" name="name" required value="{{ school.name }}"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>
                <div class="sm:w-1/2">
                    <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Identifiant public (slug)</label>
                    <div class="flex gap-2">
                        <input type="text" id="slug" name="slug"
                               value="{{ school.currentSlug ?? suggestedSlug }}"
                               placeholder="{{ suggestedSlug }}"
                               class="flex-1 block rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 font-mono focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                        <button type="button" id="slug-generate"
                                title="Regénérer depuis le nom"
                                class="shrink-0 px-3 py-2.5 rounded-lg border border-gray-300 bg-gray-50 hover:bg-gray-100 text-gray-500 text-xs transition">
                            ↺ Générer
                        </button>
                    </div>
                    {% if school.citySlug and school.currentSlug %}
                    <a id="public-page-link"
                       href="{{ url('app_school_page', {citySlug: school.citySlug, schoolSlug: school.currentSlug}) }}"
                       target="_blank" rel="noopener"
                       class="mt-1 inline-flex items-center gap-1 text-xs text-indigo-500 hover:text-indigo-700 font-mono transition">
                        <span id="public-page-link-text">{{ app.request.schemeAndHttpHost }}/{{ school.citySlug }}/{{ school.currentSlug }}</span>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                    {% endif %}
                    <p class="text-xs text-gray-400">Modifiable — l'ancien identifiant sera conservé comme alias.</p>
                    <input type="hidden" id="citySlug" name="citySlug" value="{{ school.citySlug ?? '' }}">
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label for="websiteUrl" class="block text-sm font-medium text-gray-700 mb-1">Site web</label>
                        <input type="url" id="websiteUrl" name="websiteUrl" value="{{ school.websiteUrl ?? '' }}"
                               placeholder="https://..."
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>
                    <div>
                        <label for="contactEmail" class="block text-sm font-medium text-gray-700 mb-1">Email de contact</label>
                        <input type="email" id="contactEmail" name="contactEmail" value="{{ school.contactEmail ?? '' }}"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>
                </div>
                <div class="sm:w-1/2">
                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Téléphone</label>
                    <input type="tel" id="phone" name="phone" value="{{ school.phone ?? '' }}"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>
            </div>
        </div>

        {# WYSIWYG fields #}
        {% set wysiwygFields = [
            {id: 'description', label: 'Description',   name: 'description',   value: school.description,   hint: 'Présentation de votre école'},
            {id: 'schedule',    label: 'Horaires',       name: 'schedule',      value: school.schedule,      hint: 'Jours et heures d\'ouverture'},
            {id: 'pricing',     label: 'Tarifs',         name: 'pricing',       value: school.pricing,       hint: 'Grille tarifaire'},
            {id: 'readAndCheck',label: 'CGU de l\'élève', name: 'readAndCheck', value: school.readAndCheck,  hint: 'Conditions générales à accepter lors de l\'inscription'},
        ] %}

        {% for field in wysiwygFields %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ field.label }}</h2>
                <p class="text-sm text-gray-500 mt-0.5">{{ field.hint }}</p>
            </div>
            <div class="px-6 py-5">
                <div id="editor-{{ field.id }}" class="rounded-lg border border-gray-300 bg-gray-50" style="font-size:14px;min-height:220px"></div>
                <textarea id="textarea-{{ field.id }}" name="{{ field.name }}" class="hidden">{{ field.value ?? '' }}</textarea>
            </div>
        </div>
        {% endfor %}

        <div class="flex justify-end">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors">
                Enregistrer
            </button>
        </div>
    </form>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
(function () {
    // WYSIWYG editors
    const fields = ['description', 'schedule', 'pricing', 'readAndCheck'];
    const editors = {};

    fields.forEach(function (id) {
        const container = document.getElementById('editor-' + id);
        const textarea  = document.getElementById('textarea-' + id);
        if (!container || !textarea) return;

        const quill = new Quill(container, {
            theme: 'snow',
            modules: { toolbar: [
                [{header: [2, 3, false]}],
                ['bold', 'italic', 'underline'],
                [{list: 'ordered'}, {list: 'bullet'}],
                ['link'],
                ['clean'],
            ]},
        });

        if (textarea.value) {
            quill.root.innerHTML = textarea.value;
        }

        editors[id] = quill;
    });

    document.querySelector('form').addEventListener('submit', function () {
        fields.forEach(function (id) {
            const ta = document.getElementById('textarea-' + id);
            if (ta && editors[id]) {
                ta.value = editors[id].root.innerHTML;
            }
        });
    });

    // Slug preview
    const _baseUrl = {{ app.request.schemeAndHttpHost|json_encode|raw }};
    function updateSlugPreview() {
        const city  = document.getElementById('citySlug').value || '…';
        const slug  = document.getElementById('slug').value || document.getElementById('slug').placeholder || '…';
        const link = document.getElementById('public-page-link');
        if (link && city !== '…' && slug !== '…') {
            const fullUrl = _baseUrl + '/' + city + '/' + slug;
            link.href = fullUrl;
            const txt = document.getElementById('public-page-link-text');
            if (txt) txt.textContent = fullUrl;
            link.style.display = '';
        } else if (link) {
            link.style.display = 'none';
        }
    }
    updateSlugPreview();
    document.getElementById('slug').addEventListener('input', updateSlugPreview);

    // Slug generator
    const slugGenBtn = document.getElementById('slug-generate');
    if (slugGenBtn) {
        slugGenBtn.addEventListener('click', function () {
            const name = (document.getElementById('name').value || '').trim();
            const slug = name.toLowerCase()
                .normalize('NFD').replace(/\p{Diacritic}/gu, '')
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
            document.getElementById('slug').value = slug;
            updateSlugPreview();
        });
    }

    // Map
    (function () {
        const lat0   = parseFloat(document.getElementById('addressLat').value) || 48.8566;
        const lng0   = parseFloat(document.getElementById('addressLng').value) || 2.3522;
        const hasPos = !!document.getElementById('addressLat').value;

        const map = L.map('map').setView([lat0, lng0], hasPos ? 15 : 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors', maxZoom: 19,
        }).addTo(map);

        const marker = L.marker([lat0, lng0], { draggable: true });
        if (hasPos) marker.addTo(map);

        function extractCitySlug(addr) {
            const city = addr?.city || addr?.town || addr?.village || addr?.municipality || addr?.county || '';
            return city.toLowerCase()
                .normalize('NFD').replace(/\p{Diacritic}/gu, '')
                .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        }

        function setPos(lat, lng, label, addr) {
            marker.setLatLng([lat, lng]);
            if (!map.hasLayer(marker)) marker.addTo(map);
            map.setView([lat, lng], 15);
            document.getElementById('addressLat').value = lat.toFixed(7);
            document.getElementById('addressLng').value = lng.toFixed(7);
            if (label) {
                document.getElementById('addressText').value  = label;
                document.getElementById('address-search').value = label;
            }
            if (addr) {
                const cs = extractCitySlug(addr);
                if (cs) { document.getElementById('citySlug').value = cs; updateSlugPreview(); }
            }
        }

        marker.on('dragend', function () {
            const p = marker.getLatLng();
            document.getElementById('addressLat').value = p.lat.toFixed(7);
            document.getElementById('addressLng').value = p.lng.toFixed(7);
            fetch('https://nominatim.openstreetmap.org/reverse?format=json&addressdetails=1&lat=' + p.lat + '&lon=' + p.lng)
                .then(r => r.json()).then(d => {
                    if (d.display_name) {
                        document.getElementById('addressText').value = d.display_name;
                        document.getElementById('address-search').value = d.display_name;
                        const cs = extractCitySlug(d.address);
                        if (cs) { document.getElementById('citySlug').value = cs; updateSlugPreview(); }
                    }
                });
        });

        map.on('click', function (e) { setPos(e.latlng.lat, e.latlng.lng, null, null); });

        document.getElementById('address-search-btn').addEventListener('click', function () {
            const q = document.getElementById('address-search').value.trim();
            if (!q) return;
            fetch('https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&q=' + encodeURIComponent(q) + '&limit=1')
                .then(r => r.json()).then(d => {
                    if (d.length) setPos(parseFloat(d[0].lat), parseFloat(d[0].lon), d[0].display_name, d[0].address);
                    else alert('Adresse introuvable.');
                });
        });

        document.getElementById('address-search').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); document.getElementById('address-search-btn').click(); }
        });
    })();
})();
</script>
<script>
function schoolImages(uploadUrl, deleteUrl) {
    return {
        uploadUrl: uploadUrl,
        deleteUrl: deleteUrl,
        images: {
            photo: {
                url: {{ school.avatarPath ? ('\'/' ~ school.avatarPath ~ '\'')|raw : 'null' }},
                loading: false,
                error: '',
            },
            logo: {
                url: {{ school.logoPath ? ('\'/' ~ school.logoPath ~ '\'')|raw : 'null' }},
                loading: false,
                error: '',
            },
        },
        cropToSquare(file) {
            return new Promise((resolve) => {
                const img = new Image();
                const objUrl = URL.createObjectURL(file);
                img.onload = () => {
                    const size = Math.min(img.width, img.height);
                    const canvas = document.createElement('canvas');
                    canvas.width = size;
                    canvas.height = size;
                    canvas.getContext('2d').drawImage(
                        img,
                        (img.width - size) / 2, (img.height - size) / 2,
                        size, size,
                        0, 0, size, size
                    );
                    URL.revokeObjectURL(objUrl);
                    canvas.toBlob(resolve, 'image/jpeg', 0.92);
                };
                img.src = objUrl;
            });
        },

        async uploadImage(event, field) {
            const file = event.target.files[0];
            if (!file) return;
            this.images[field].loading = true;
            this.images[field].error = '';
            const fd = new FormData();
            let uploadFile = file;
            if (field === 'logo') {
                const blob = await this.cropToSquare(file);
                uploadFile = new File([blob], 'logo.jpg', { type: 'image/jpeg' });
            }
            fd.append('file', uploadFile);
            fd.append('field', field);
            try {
                const res = await fetch(this.uploadUrl, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    this.images[field].url = data.url;
                } else {
                    this.images[field].error = data.error || 'Erreur lors du téléversement.';
                }
            } catch (e) {
                this.images[field].error = 'Erreur réseau.';
            } finally {
                this.images[field].loading = false;
                event.target.value = '';
            }
        },
        async deleteImage(field) {
            this.images[field].loading = true;
            this.images[field].error = '';
            const fd = new FormData();
            fd.append('field', field);
            try {
                const res = await fetch(this.deleteUrl, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    this.images[field].url = null;
                } else {
                    this.images[field].error = data.error || 'Erreur lors de la suppression.';
                }
            } catch (e) {
                this.images[field].error = 'Erreur réseau.';
            } finally {
                this.images[field].loading = false;
            }
        },
    };
}
</script>
{% endblock %}
