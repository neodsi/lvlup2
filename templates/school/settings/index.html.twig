{% extends 'base.html.twig' %}

{% block title %}Paramètres — {{ team.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    {# Header #}
    <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Paramètres</h1>
                <p class="text-sm text-gray-500 mt-0.5">{{ team.name }}</p>
            </div>
            <a href="{{ path('school_settings_season_current') }}"
               class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Saison courante
            </a>
        </div>
    </header>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
                <div class="rounded-lg px-4 py-3 text-sm font-medium
                    {% if label == 'success' %}bg-green-50 text-green-800 border border-green-200
                    {% elseif label == 'error' %}bg-red-50 text-red-800 border border-red-200
                    {% else %}bg-blue-50 text-blue-800 border border-blue-200{% endif %}">
                    {{ message }}
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {# Tabs navigation #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
        <div class="border-b border-gray-200">
            <nav class="-mb-px flex gap-6" aria-label="Onglets">
                <a href="#general"
                   class="tab-link border-b-2 border-indigo-600 text-indigo-600 pb-3 px-1 text-sm font-medium whitespace-nowrap"
                   data-tab="general">
                    Général
                </a>
                <a href="#stripe"
                   class="tab-link border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 pb-3 px-1 text-sm font-medium whitespace-nowrap transition-colors"
                   data-tab="stripe">
                    Stripe
                </a>
                <a href="#saisons"
                   class="tab-link border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 pb-3 px-1 text-sm font-medium whitespace-nowrap transition-colors"
                   data-tab="saisons">
                    Saisons
                </a>
            </nav>
        </div>
    </div>

    {# Tab content #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# Général #}
        <div id="tab-general" class="tab-panel">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
                <div class="px-6 py-5">
                    <h2 class="text-base font-semibold text-gray-900">Informations générales</h2>
                    <p class="text-sm text-gray-500 mt-1">Nom de la structure, coordonnées et autres informations.</p>
                </div>
                <div class="px-6 py-5">
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
                        <div>
                            <dt class="font-medium text-gray-700">Nom</dt>
                            <dd class="mt-1 text-gray-900">{{ team.name }}</dd>
                        </div>
                        <div>
                            <dt class="font-medium text-gray-700">Identifiant</dt>
                            <dd class="mt-1 text-gray-500 font-mono text-xs">{{ team.id }}</dd>
                        </div>
                    </dl>
                </div>
                <div class="px-6 py-4 bg-gray-50 rounded-b-xl">
                    <p class="text-xs text-gray-400">Modification des informations générales disponible prochainement.</p>
                </div>
            </div>
        </div>

        {# Stripe #}
        <div id="tab-stripe" class="tab-panel hidden">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                {# Stripe config card #}
                <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
                    <div class="px-6 py-5">
                        <h2 class="text-base font-semibold text-gray-900">Configuration Stripe</h2>
                        <p class="text-sm text-gray-500 mt-1">Clés API et paramètres de paiement.</p>
                    </div>
                    <div class="px-6 py-5">
                        <p class="text-sm text-gray-500">Les clés Stripe sont configurées via les variables d'environnement du serveur.</p>
                    </div>
                </div>
                {# Quick links #}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
                    <div class="px-6 py-5">
                        <h2 class="text-base font-semibold text-gray-900">Accès rapides</h2>
                    </div>
                    <div class="px-6 py-4">
                        <a href="{{ path('school_settings_stripe_payments') }}"
                           class="flex items-center gap-3 text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                            </svg>
                            Sessions de paiement Stripe
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {# Saisons #}
        <div id="tab-saisons" class="tab-panel hidden">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900">Gestion des saisons</h2>
                <a href="{{ path('school_settings_season_create') }}"
                   class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nouvelle saison
                </a>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100">
                    <p class="text-sm text-gray-500">Accédez à la saison courante ou créez-en une nouvelle.</p>
                </div>
                <div class="px-6 py-8 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Consultez et gérez vos saisons depuis le menu de la saison courante.</p>
                    <a href="{{ path('school_settings_season_current') }}"
                       class="mt-4 inline-flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                        Accéder à la saison courante
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
(function() {
    const links = document.querySelectorAll('.tab-link');
    const panels = document.querySelectorAll('.tab-panel');

    function activate(tab) {
        links.forEach(l => {
            const active = l.dataset.tab === tab;
            l.classList.toggle('border-indigo-600', active);
            l.classList.toggle('text-indigo-600', active);
            l.classList.toggle('border-transparent', !active);
            l.classList.toggle('text-gray-500', !active);
        });
        panels.forEach(p => {
            p.classList.toggle('hidden', p.id !== 'tab-' + tab);
        });
    }

    links.forEach(l => {
        l.addEventListener('click', e => {
            e.preventDefault();
            activate(l.dataset.tab);
            history.replaceState(null, '', l.getAttribute('href'));
        });
    });

    // Restore from hash
    const hash = location.hash.replace('#', '');
    const valid = ['general', 'stripe', 'saisons'];
    activate(valid.includes(hash) ? hash : 'general');
})();
</script>
{% endblock %}
