{% extends 'layout/school.html.twig' %}

{% block title %}Sessions Stripe — {{ team.name }}{% endblock %}

{% block school_content %}

    <header class="bg-white border-b border-gray-200">
        <div class="py-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition-colors">Paramètres</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-900 font-medium">Paiements Stripe</span>
            </nav>
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Sessions de paiement Stripe</h1>
                    <p class="text-sm text-gray-500 mt-0.5">{{ team.name }} — sessions Checkout récentes.</p>
                </div>
                <span class="inline-flex items-center gap-1.5 bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full text-sm font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                    Stripe
                </span>
            </div>
        </div>
    </header>

    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if sessions is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                    </svg>
                    <p class="mt-4 text-sm font-medium text-gray-700">Aucune session Stripe disponible</p>
                    <p class="mt-1 text-sm text-gray-400">Les sessions Checkout apparaîtront ici une fois Stripe configuré.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">ID session</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Montant</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Devise</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Client</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
                            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for session in sessions %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono text-gray-600">{{ session.id ?? '—' }}</span>
                                </td>
                                <td class="px-6 py-4">
                                    {% set status = session.payment_status ?? session.status ?? '' %}
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if status == 'paid' or status == 'complete' %}bg-green-50 text-green-700
                                        {% elseif status == 'open' or status == 'unpaid' %}bg-amber-50 text-amber-700
                                        {% elseif status == 'expired' or status == 'no_payment_required' %}bg-gray-100 text-gray-500
                                        {% else %}bg-blue-50 text-blue-700{% endif %}">
                                        <span class="w-1.5 h-1.5 rounded-full
                                            {% if status == 'paid' or status == 'complete' %}bg-green-400
                                            {% elseif status == 'open' or status == 'unpaid' %}bg-amber-400
                                            {% else %}bg-gray-400{% endif %} inline-block"></span>
                                        {{ status ?: '—' }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">
                                    {% if session.amount_total is defined and session.amount_total is not null %}
                                        {{ (session.amount_total / 100)|number_format(2, ',', ' ') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500 uppercase">
                                    {{ session.currency ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ session.customer_details.email ?? session.customer_email ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {% if session.created is defined %}
                                        {{ session.created|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {% if session.url is defined and session.url %}
                                        <a href="{{ session.url }}" target="_blank" rel="noopener"
                                           class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                                            Ouvrir
                                        </a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ sessions|length }} session{{ sessions|length > 1 ? 's' : '' }}
                </div>
            {% endif %}
        </div>
    </div>

