{% extends 'layout/school.html.twig' %}

{% block title %}Informations légales — Paramètres — {{ school.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition">Paramètres</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Informations légales</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Paramètres</h1>

    {% include 'school/settings/_tabs.html.twig' %}

    <form method="POST" action="{{ path('school_settings_legal') }}" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('settings_legal') }}">

        {# Identité légale #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Identité légale</h2>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div>
                    <label for="companyName" class="block text-sm font-medium text-gray-700 mb-1">Raison sociale</label>
                    <input type="text" id="companyName" name="companyName" value="{{ school.companyName ?? '' }}"
                           class="block w-full sm:w-1/2 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <label for="siret" class="block text-sm font-medium text-gray-700 mb-1">SIRET</label>
                        <input type="text" id="siret" name="siret"
                               value="{{ school.siret ? (school.siret|slice(0,3) ~ ' ' ~ school.siret|slice(3,3) ~ ' ' ~ school.siret|slice(6,3) ~ ' ' ~ school.siret|slice(9)) : '' }}"
                               placeholder="XXX XXX XXX XXXXX" maxlength="17" autocomplete="off"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 font-mono focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>
                    <div>
                        <label for="apeNaf" class="block text-sm font-medium text-gray-700 mb-1">Code APE / NAF</label>
                        <input type="text" id="apeNaf" name="apeNaf" value="{{ school.apeNaf ?? '' }}"
                               placeholder="ex : 8551Z" maxlength="6"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 font-mono focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>
                    <div>
                        <label for="currency" class="block text-sm font-medium text-gray-700 mb-1">Devise</label>
                        <input type="text" id="currency" name="currency" value="EUR" readonly
                               class="block w-full rounded-lg border border-gray-200 bg-gray-100 px-3 py-2.5 text-sm text-gray-500 cursor-not-allowed">
                        <input type="hidden" name="currency" value="EUR">
                    </div>
                </div>
                <div>
                    <label for="iban" class="block text-sm font-medium text-gray-700 mb-1">IBAN</label>
                    <input type="text" id="iban" name="iban" value="{{ school.iban ?? '' }}"
                           placeholder="FR76 XXXX XXXX XXXX XXXX XXXX XXX" maxlength="33" autocomplete="off"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 font-mono focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>
            </div>
        </div>

        {# TVA #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">TVA</h2>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Assujetti à la TVA</p>
                        <p class="text-xs text-gray-500 mt-0.5">Activez si votre structure collecte la TVA.</p>
                    </div>
                    {% set _vatOn = school.isCollectingVat() %}
                    <input type="checkbox" id="isCollectingVat" name="isCollectingVat" value="1"
                           {{ _vatOn ? 'checked' }} class="sr-only">
                    <button type="button" id="vat-toggle" onclick="lvlToggleVat()"
                            style="width:44px;height:24px;border-radius:12px;background:{{ _vatOn ? '#4f46e5' : '#d1d5db' }};position:relative;cursor:pointer;border:none;outline:none;transition:background .2s;flex-shrink:0"
                            aria-checked="{{ _vatOn ? 'true' : 'false' }}" role="switch">
                        <span id="vat-knob"
                              style="width:20px;height:20px;border-radius:50%;background:#fff;position:absolute;top:2px;left:{{ _vatOn ? '22px' : '2px' }};transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.25);pointer-events:none"></span>
                    </button>
                </div>
                <div id="vat-number-field" class="{{ school.isCollectingVat() ? '' : 'hidden' }}">
                    <label for="vatNumber" class="block text-sm font-medium text-gray-700 mb-1">Numéro de TVA intracommunautaire</label>
                    <input type="text" id="vatNumber" name="vatNumber" value="{{ school.vatNumber ?? '' }}"
                           placeholder="FR00 000000000"
                           class="block w-full sm:w-1/2 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 font-mono focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>
            </div>
        </div>

        {# Frais & paiements #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Frais & paiements</h2>
            </div>
            <div class="px-6 py-5 space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Frais de traitement payés par</label>
                    <input type="text" value="L'école" readonly
                           class="block w-full sm:w-1/2 rounded-lg border border-gray-200 bg-gray-100 px-3 py-2.5 text-sm text-gray-500 cursor-not-allowed">
                    <input type="hidden" name="feePaidBy" value="school">
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-700 mb-3">Modes de paiement acceptés</p>

                    {# Build lookup: id → {allowed_for_one_shot, allowed_for_multiple_payments} #}
                    {% set _pm = {} %}
                    {% for m in school.paymentMethods ?? [] %}
                        {% set _pm = _pm|merge({(m.id): m}) %}
                    {% endfor %}

                    {# ── Sur place ── #}
                    <div class="rounded-lg border border-gray-100 bg-gray-50 px-4 pt-3 pb-4 mb-4">
                        <p class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">Sur place</p>
                        <p class="text-xs text-gray-400 mb-3">Paiements encaissés directement à l'école</p>

                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr>
                                        <th class="text-left pb-2 text-xs font-medium text-gray-500 pr-4">Moyen de paiement</th>
                                        <th class="text-center pb-2 text-xs font-medium text-gray-500 px-3 whitespace-nowrap">En une fois</th>
                                        <th class="text-center pb-2 text-xs font-medium text-gray-500 px-3 whitespace-nowrap">En plusieurs fois</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    {% for key, label in {
                                        'voucher_activity':           'Chèques activités',
                                        'card_on_site':               'Carte bancaire',
                                        'voucher_holiday_ancv_paper': 'Chèques vacances ANCV papier',
                                        'sepa_direct_debit':          'Prélèvement SEPA',
                                        'financement_pole_emploi':    'Financement Pôle emploi',
                                        'voucher_holiday_ancv_online':'Chèques e-ANCV',
                                        'coupon_sport':               'Coupon sport',
                                        'bank_transfer':              'Virement bancaire',
                                        'culture_pass':               'Pass culture',
                                        'cash':                       'Espèces',
                                        'check':                      'Chèques',
                                        'other':                      'Autre',
                                    } %}
                                    <tr>
                                        <td class="py-2 pr-4 text-gray-700">{{ label }}</td>
                                        <td class="py-2 px-3 text-center">
                                            <input type="checkbox" name="methods[{{ key }}][one_shot]" value="1"
                                                   {{ (_pm[key] is defined and _pm[key].allowed_for_one_shot) ? 'checked' }}
                                                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        </td>
                                        <td class="py-2 px-3 text-center">
                                            <input type="checkbox" name="methods[{{ key }}][multiple]" value="1"
                                                   {{ (_pm[key] is defined and _pm[key].allowed_for_multiple_payments) ? 'checked' }}
                                                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {# ── En ligne ── #}
                    <div class="rounded-lg border border-gray-100 bg-gray-50 px-4 pt-3 pb-4">
                        <p class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">En ligne</p>
                        <p class="text-xs text-gray-400 mb-3">Paiements via Stripe (nécessite un compte Stripe actif)</p>

                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr>
                                        <th class="text-left pb-2 text-xs font-medium text-gray-500 pr-4">Moyen de paiement</th>
                                        <th class="text-center pb-2 text-xs font-medium text-gray-500 px-3 whitespace-nowrap">En une fois</th>
                                        <th class="text-center pb-2 text-xs font-medium text-gray-500 px-3 whitespace-nowrap">En plusieurs fois</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    {% for key, label in {
                                        'online_card':         'Carte bancaire',
                                        'online_bank_transfer':'Virement bancaire unique',
                                    } %}
                                    <tr>
                                        <td class="py-2 pr-4 text-gray-700">{{ label }}</td>
                                        <td class="py-2 px-3 text-center">
                                            <input type="checkbox" name="methods[{{ key }}][one_shot]" value="1"
                                                   {{ (_pm[key] is defined and _pm[key].allowed_for_one_shot) ? 'checked' }}
                                                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        </td>
                                        <td class="py-2 px-3 text-center">
                                            <input type="checkbox" name="methods[{{ key }}][multiple]" value="1"
                                                   {{ (_pm[key] is defined and _pm[key].allowed_for_multiple_payments) ? 'checked' }}
                                                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        </td>
                                    </tr>
                                    {% endfor %}
                                    <tr>
                                        <td class="py-2 pr-4 text-gray-400 italic">Prélèvement SEPA</td>
                                        <td colspan="2" class="py-2 px-3 text-center text-xs text-gray-400">Bientôt disponible</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Adresse de facturation #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Adresse de facturation</h2>
                <p class="text-sm text-gray-500 mt-0.5">Affichée sur les factures. L'adresse de géolocalisation se configure dans les paramètres généraux.</p>
            </div>
            <div class="px-6 py-5">
                {% if school.addressText %}
                <div class="mb-3">
                    <button type="button" id="btn-copy-address"
                            class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-medium border border-indigo-200 rounded-lg px-3 py-1.5 bg-indigo-50 hover:bg-indigo-100 transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        Utiliser l'adresse postale
                    </button>
                </div>
                {% endif %}
                <textarea id="invoiceAddress" name="invoiceAddress" rows="5"
                          class="block w-full sm:w-2/3 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition" style="resize:vertical">{{ school.invoiceAddress ?? '' }}</textarea>
                <p class="mt-1 text-xs text-gray-400">Mise en forme libre.</p>
            </div>
        </div>

        <div class="flex justify-end">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors">
                Enregistrer
            </button>
        </div>
    </form>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
(function () {
    function formatSiret(v) {
        v = v.replace(/\D/g, '').slice(0, 14);
        let out = '';
        for (let i = 0; i < v.length; i++) {
            if (i === 3 || i === 6 || i === 9) out += ' ';
            out += v[i];
        }
        return out;
    }
    function formatIban(v) {
        v = v.replace(/\s/g, '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 27);
        let out = '';
        for (let i = 0; i < v.length; i++) {
            if (i > 0 && i % 4 === 0) out += ' ';
            out += v[i];
        }
        return out;
    }
    const siretEl = document.getElementById('siret');
    const ibanEl  = document.getElementById('iban');
    if (siretEl) {
        siretEl.value = formatSiret(siretEl.value);
        siretEl.addEventListener('input', function () {
            const pos = this.selectionStart;
            const raw = this.value;
            this.value = formatSiret(raw);
            const added = this.value.length - raw.length;
            this.setSelectionRange(pos + added, pos + added);
        });
    }
    if (ibanEl) {
        ibanEl.value = formatIban(ibanEl.value);
        ibanEl.addEventListener('input', function () {
            const pos = this.selectionStart;
            const raw = this.value;
            this.value = formatIban(raw);
            const added = this.value.length - raw.length;
            this.setSelectionRange(pos + added, pos + added);
        });
    }
})();

const btnCopy = document.getElementById('btn-copy-address');
if (btnCopy) {
    btnCopy.addEventListener('click', function () {
        document.getElementById('invoiceAddress').value = {{ school.addressText|json_encode|raw }};
    });
}

window.lvlToggleVat = function () {
    const input = document.getElementById('isCollectingVat');
    const btn   = document.getElementById('vat-toggle');
    const knob  = document.getElementById('vat-knob');
    input.checked = !input.checked;
    btn.style.background = input.checked ? '#4f46e5' : '#d1d5db';
    btn.setAttribute('aria-checked', input.checked ? 'true' : 'false');
    knob.style.left = input.checked ? '22px' : '2px';
    document.getElementById('vat-number-field').classList.toggle('hidden', !input.checked);
};
</script>
{% endblock %}
