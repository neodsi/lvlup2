{% set _sr = app.request.attributes.get('_route') %}
<div class="border-b border-gray-200 mb-6">
    <nav class="-mb-px flex gap-6">
        <a href="{{ path('school_settings') }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _sr == 'school_settings' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Général
        </a>
        <a href="{{ path('school_settings_legal') }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _sr == 'school_settings_legal' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Informations légales
        </a>
        <a href="{{ path('school_settings_stripe') }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _sr == 'school_settings_stripe' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Stripe
        </a>
    </nav>
</div>
