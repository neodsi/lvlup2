{% extends 'layout/school.html.twig' %}

{% block title %}Saisons — Paramètres — {{ school.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Saisons</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Saisons</h1>
    </div>

    <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold text-gray-900">Gestion des saisons</h2>
        <a href="{{ path('school_settings_season_create') }}"
           class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvelle saison
        </a>
    </div>

    {% if seasons is empty %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-12 text-center">
            <svg class="mx-auto w-12 h-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-sm text-gray-500">Aucune saison. Créez votre première saison.</p>
            <a href="{{ path('school_settings_season_create') }}"
               class="mt-4 inline-flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                Créer une saison
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
    {% else %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" x-data="{ confirmId: null, confirmName: '', confirmToken: '', confirmAction: '' }">
            <ul class="divide-y divide-gray-100">
                {% for season in seasons %}
                    {% set deletable = season.id not in nonDeletableIds %}
                    <li class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-4">
                            <div class="h-9 w-9 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">
                                    {{ season.name }}
                                    {% if season.id == school.currentSeasonId %}
                                        <span class="ml-2 inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Courante</span>
                                    {% endif %}
                                </p>
                                <p class="text-xs text-gray-400 mt-0.5">
                                    {{ season.startAt|date('d/m/Y') }} → {{ season.endAt|date('d/m/Y') }}
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <a href="{{ path('school_settings_season', {id: season.id}) }}"
                               class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                Gérer
                            </a>
                            {% if deletable %}
                                <button type="button"
                                        data-token="{{ csrf_token('season_delete_' ~ season.id) }}"
                                        data-action="{{ path('school_settings_season_delete', {seasonId: season.id}) }}"
                                        @click="confirmId = '{{ season.id }}'; confirmName = '{{ season.name|e('js') }}'; confirmToken = $el.dataset.token; confirmAction = $el.dataset.action"
                                        class="text-xs text-red-400 hover:text-red-600 font-medium transition">
                                    Supprimer
                                </button>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>

            {# Confirmation modal #}
            <div x-show="confirmId !== null"
                 x-transition.opacity
                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4"
                 style="display:none">
                <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6" @click.stop>
                    <h3 class="text-base font-semibold text-gray-900 mb-2">Supprimer la saison</h3>
                    <p class="text-sm text-gray-600 mb-6">
                        Supprimer définitivement <strong x-text="confirmName"></strong> ?
                        Cette action est irréversible.
                    </p>
                    <div class="flex justify-end gap-3">
                        <button type="button" @click="confirmId = null"
                                class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2 rounded-lg border border-gray-200 transition">
                            Annuler
                        </button>
                        <form method="POST" :action="confirmAction">
                            <input type="hidden" name="_token" :value="confirmToken">
                            <button type="submit"
                                    class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition">
                                Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
