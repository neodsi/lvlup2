{% extends 'layout/school.html.twig' %}

{% block title %}Échéanciers — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Échéanciers</span>
{% endblock %}

{% block school_content %}
<div class="py-8"
     x-data="schedulersPage()"
     x-init="init()">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Échéanciers de paiement</h1>
        <button type="button" @click="openCreate()"
                class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvel échéancier
        </button>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        {% if templates is empty %}
            <div class="px-6 py-16 text-center">
                <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <p class="mt-4 text-sm text-gray-500">Aucun modèle d'échéancier pour cette saison.</p>
                <button type="button" @click="openCreate()"
                        class="mt-3 text-sm text-indigo-600 hover:text-indigo-800 font-medium transition">
                    Créer le premier échéancier
                </button>
            </div>
        {% else %}
            <table class="min-w-full divide-y divide-gray-100">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Détails</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-50">
                    {% for tpl in templates %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <span class="text-sm font-medium text-gray-900">{{ tpl.name }}</span>
                            </td>
                            <td class="px-6 py-4">
                                {% if tpl.type.value == 'recurring' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-700">Récurrent</span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">Dates fixes</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">
                                {% if tpl.type.value == 'recurring' %}
                                    {{ tpl.nbPayments }} paiement{{ tpl.nbPayments > 1 ? 's' : '' }}
                                    {% if tpl.intervalDuration %} · tous les {{ tpl.intervalDuration }} j{% endif %}
                                    {% if tpl.dayOfMonth %} · le {{ tpl.dayOfMonth }} du mois{% endif %}
                                    {% if tpl.startsAt %} · dès le {{ tpl.startsAt|date('d/m/Y') }}{% endif %}
                                {% else %}
                                    {% if tpl.fixedDates %}
                                        {{ tpl.fixedDates|length }} date{{ tpl.fixedDates|length > 1 ? 's' : '' }} :
                                        {% for d in tpl.fixedDates|slice(0, 3) %}
                                            <span class="inline-block font-mono bg-gray-100 px-1.5 py-0.5 rounded text-xs">{{ d }}</span>
                                        {% endfor %}
                                        {% if tpl.fixedDates|length > 3 %}
                                            <span class="text-xs text-gray-400">+{{ tpl.fixedDates|length - 3 }}</span>
                                        {% endif %}
                                    {% endif %}
                                    {% if tpl.isFixedFirstDateIsAtAttribution %}
                                        <span class="ml-1 text-xs text-indigo-600">· 1re date à l'attribution</span>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-4">
                                    <button type="button"
                                            @click="openEdit({{ {
                                                id: tpl.id,
                                                name: tpl.name,
                                                type: tpl.type.value,
                                                nbPayments: tpl.nbPayments ?? 2,
                                                intervalDuration: tpl.intervalDuration ?? '',
                                                dayOfMonth: tpl.dayOfMonth ?? '',
                                                startsAt: tpl.startsAt ? tpl.startsAt|date('Y-m-d') : '',
                                                fixedDates: tpl.fixedDates ? tpl.fixedDates|join('\n') : '',
                                                fixedFirstDateIsAtAttribution: tpl.isFixedFirstDateIsAtAttribution
                                            }|json_encode|e('html_attr') }})"
                                            class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                        Modifier
                                    </button>
                                    <button type="button"
                                            data-token="{{ csrf_token('scheduler_delete_' ~ tpl.id) }}"
                                            data-action="{{ path('school_season_payment_scheduler_delete', {id: season.id, templateId: tpl.id}) }}"
                                            @click="openDelete('{{ tpl.id }}', '{{ tpl.name|e('js') }}', $el.dataset.token, $el.dataset.action)"
                                            class="text-xs text-red-400 hover:text-red-600 font-medium transition">
                                        Supprimer
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                {{ templates|length }} modèle{{ templates|length > 1 ? 's' : '' }}
            </div>
        {% endif %}
    </div>

    {# ── Modale création / édition ── #}
    <div x-show="modalOpen"
         x-transition.opacity
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4"
         style="display:none"
         @keydown.escape.window="modalOpen = false">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto" @click.stop>

            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
                <h3 class="text-base font-semibold text-gray-900" x-text="editId ? 'Modifier l\'échéancier' : 'Nouvel échéancier'"></h3>
                <button type="button" @click="modalOpen = false" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <form method="POST" :action="formAction" class="px-6 py-5 space-y-5">

                {# Nom #}
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Nom <span class="text-red-500">*</span></label>
                    <input type="text" name="name" required x-model="form.name"
                           placeholder="Ex : 3 fois sans frais, Paiement mensuel…"
                           class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>

                {# Type #}
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Type d'échéancier</label>
                    <div class="flex gap-3">
                        <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                               :class="form.type === 'recurring' ? 'border-indigo-400 bg-indigo-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                            <input type="radio" name="type" value="recurring" x-model="form.type" class="sr-only">
                            <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                                  :class="form.type === 'recurring' ? 'border-indigo-500 bg-indigo-500' : 'border-gray-300'"></span>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Récurrent</p>
                                <p class="text-xs text-gray-500">Intervalles réguliers</p>
                            </div>
                        </label>
                        <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                               :class="form.type === 'fixed_dates' ? 'border-indigo-400 bg-indigo-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                            <input type="radio" name="type" value="fixed_dates" x-model="form.type" class="sr-only">
                            <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                                  :class="form.type === 'fixed_dates' ? 'border-indigo-500 bg-indigo-500' : 'border-gray-300'"></span>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Dates fixes</p>
                                <p class="text-xs text-gray-500">Dates prédéfinies</p>
                            </div>
                        </label>
                    </div>
                </div>

                {# Section Récurrent #}
                <div x-show="form.type === 'recurring'" class="space-y-4 rounded-lg bg-gray-50 border border-gray-100 p-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Nombre de paiements <span class="text-red-500">*</span></label>
                            <input type="number" name="nbPayments" min="1" max="36" x-model.number="form.nbPayments"
                                   class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/20 transition">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Intervalle (jours)</label>
                            <input type="number" name="intervalDuration" min="1" x-model="form.intervalDuration"
                                   placeholder="Ex : 30"
                                   class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/20 transition">
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Jour du mois</label>
                            <input type="number" name="dayOfMonth" min="1" max="31" x-model="form.dayOfMonth"
                                   placeholder="Ex : 5"
                                   class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/20 transition">
                            <p class="mt-0.5 text-xs text-gray-400">Déclenche le paiement le Nième jour</p>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Date de début</label>
                            <input type="date" name="startsAt" x-model="form.startsAt"
                                   class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/20 transition">
                        </div>
                    </div>
                </div>

                {# Section Dates fixes #}
                <div x-show="form.type === 'fixed_dates'" class="space-y-4 rounded-lg bg-gray-50 border border-gray-100 p-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">
                            Dates de prélèvement <span class="text-red-500">*</span>
                            <span class="ml-1 text-gray-400 font-normal">(une par ligne, format AAAA-MM-JJ)</span>
                        </label>
                        <textarea name="fixedDates" rows="5" x-model="form.fixedDates"
                                  placeholder="2025-09-05&#10;2025-10-05&#10;2025-11-05"
                                  class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-mono text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/20 transition resize-none"></textarea>
                    </div>
                    <label class="flex items-center gap-2.5 cursor-pointer">
                        <input type="checkbox" name="fixedFirstDateIsAtAttribution" value="1"
                               x-model="form.fixedFirstDateIsAtAttribution"
                               class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                        <div>
                            <p class="text-sm font-medium text-gray-700">Première date à l'attribution du forfait</p>
                            <p class="text-xs text-gray-400">Le premier prélèvement se fait immédiatement lors de la validation</p>
                        </div>
                    </label>
                </div>

                <div class="flex items-center justify-end gap-3 pt-2 border-t border-gray-100">
                    <button type="button" @click="modalOpen = false"
                            class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2 rounded-lg border border-gray-200 transition">
                        Annuler
                    </button>
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition"
                            x-text="editId ? 'Enregistrer' : 'Créer l\'échéancier'">
                    </button>
                </div>

            </form>
        </div>
    </div>

    {# ── Modale confirmation suppression ── #}
    <div x-show="deleteConfirmOpen"
         x-transition.opacity
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4"
         style="display:none">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6" @click.stop>
            <h3 class="text-base font-semibold text-gray-900 mb-2">Supprimer l'échéancier</h3>
            <p class="text-sm text-gray-600 mb-6">Supprimer <strong x-text="deleteConfirmName"></strong> ? Cette action est irréversible.</p>
            <div class="flex justify-end gap-3">
                <button type="button" @click="deleteConfirmOpen = false"
                        class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2 rounded-lg border border-gray-200 transition">
                    Annuler
                </button>
                <form method="POST" :action="deleteAction">
                    <input type="hidden" name="_token" :value="deleteToken">
                    <button type="submit"
                            class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition">
                        Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
function schedulersPage() {
    return {
        modalOpen: false,
        editId: null,
        formAction: '{{ path('school_season_payment_schedulers', {id: season.id}) }}',
        form: {
            name: '',
            type: 'recurring',
            nbPayments: 2,
            intervalDuration: '',
            dayOfMonth: '',
            startsAt: '',
            fixedDates: '',
            fixedFirstDateIsAtAttribution: false,
        },
        deleteConfirmOpen: false,
        deleteConfirmName: '',
        deleteToken: '',
        deleteAction: '',

        init() {},

        resetForm() {
            this.form = {
                name: '',
                type: 'recurring',
                nbPayments: 2,
                intervalDuration: '',
                dayOfMonth: '',
                startsAt: '',
                fixedDates: '',
                fixedFirstDateIsAtAttribution: false,
            };
        },

        openCreate() {
            this.editId = null;
            this.resetForm();
            this.formAction = '{{ path('school_season_payment_schedulers', {id: season.id}) }}';
            this.modalOpen = true;
        },

        openEdit(data) {
            const d = typeof data === 'string' ? JSON.parse(data) : data;
            this.editId = d.id;
            this.form = {
                name: d.name,
                type: d.type,
                nbPayments: d.nbPayments || 2,
                intervalDuration: d.intervalDuration || '',
                dayOfMonth: d.dayOfMonth || '',
                startsAt: d.startsAt || '',
                fixedDates: d.fixedDates || '',
                fixedFirstDateIsAtAttribution: !!d.fixedFirstDateIsAtAttribution,
            };
            this.formAction = '{{ path('school_season_payment_scheduler_edit', {id: season.id, templateId: '__TPL__'}) }}'.replace('__TPL__', d.id);
            this.modalOpen = true;
        },

        openDelete(id, name, token, action) {
            this.deleteConfirmName = name;
            this.deleteToken = token;
            this.deleteAction = action;
            this.deleteConfirmOpen = true;
        },
    };
}
</script>
{% endblock %}
