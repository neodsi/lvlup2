{% extends 'layout/school.html.twig' %}

{% block title %}Échéanciers — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ team.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Paiements échelonnés</span>
{% endblock %}

{% block school_content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Paiements échelonnés</h1>
</div>

    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if templates is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucun modèle d'échéancier pour cette saison.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nb paiements</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Intervalle (j)</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Jour du mois</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Début</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Dates fixes</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for template in templates %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-medium text-gray-900">{{ template.name }}</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if template.type.value == 'recurring' %}bg-purple-50 text-purple-700
                                        {% elseif template.type.value == 'fixed' %}bg-blue-50 text-blue-700
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {{ template.type.value }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ template.nbPayments ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ template.intervalDuration ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ template.dayOfMonth ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ template.startsAt ? template.startsAt|date('d/m/Y') : '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {% if template.fixedDates %}
                                        <div class="flex flex-wrap gap-1">
                                            {% for date in template.fixedDates %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded bg-gray-100 text-gray-600 text-xs font-mono">{{ date }}</span>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <span class="text-gray-400">—</span>
                                    {% endif %}
                                    {% if template.isFixedFirstDateIsAtAttribution %}
                                        <span class="ml-1 text-xs text-indigo-600">(1re date à l'attribution)</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ templates|length }} modèle{{ templates|length > 1 ? 's' : '' }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
