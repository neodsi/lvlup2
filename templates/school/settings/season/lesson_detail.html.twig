{% extends 'base.html.twig' %}

{% block title %}{{ lesson.name }} — {{ season.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    {# Header #}
    <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition-colors">Paramètres</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">{{ season.name }}</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_season_lessons', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">Cours</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-900 font-medium">{{ lesson.name }}</span>
            </nav>
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">{{ lesson.name }}</h1>
                    <div class="flex items-center gap-3 mt-1">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                            {{ lesson.type.value }}
                        </span>
                        <span class="text-sm text-gray-500">{{ lesson.startAt|date('d/m/Y H:i') }} — {{ lesson.endAt|date('d/m/Y H:i') }}</span>
                    </div>
                </div>
                <div class="flex gap-2">
                    <a href="{{ path('school_season_lesson_occurences', {id: season.id, lessonId: lesson.id}) }}"
                       class="inline-flex items-center gap-2 text-gray-700 hover:text-gray-900 text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
                        Séances
                    </a>
                    <a href="{{ path('school_season_lesson_participants', {id: season.id, lessonId: lesson.id}) }}"
                       class="inline-flex items-center gap-2 text-gray-700 hover:text-gray-900 text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
                        Participants
                    </a>
                    <a href="{{ path('school_season_lesson_edit', {id: season.id, lessonId: lesson.id}) }}"
                       class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Modifier
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Main details #}
        <div class="lg:col-span-2 space-y-6">

            {# Informations #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Informations</h2>
                </div>
                <dl class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
                    <div>
                        <dt class="font-medium text-gray-700">Nom</dt>
                        <dd class="mt-1 text-gray-900">{{ lesson.name }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Type</dt>
                        <dd class="mt-1 text-gray-900">{{ lesson.type.value }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Début</dt>
                        <dd class="mt-1 text-gray-900">{{ lesson.startAt|date('d/m/Y H:i') }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Fin</dt>
                        <dd class="mt-1 text-gray-900">{{ lesson.endAt|date('d/m/Y H:i') }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Participants maximum</dt>
                        <dd class="mt-1 text-gray-900">{{ lesson.maxParticipants ?? 'Illimité' }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Intervenant (ID)</dt>
                        <dd class="mt-1 text-gray-500 font-mono text-xs">{{ lesson.teacherId ?? '—' }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Salle (ID)</dt>
                        <dd class="mt-1 text-gray-500 font-mono text-xs">{{ lesson.roomId ?? '—' }}</dd>
                    </div>
                    <div>
                        <dt class="font-medium text-gray-700">Adresse (ID)</dt>
                        <dd class="mt-1 text-gray-500 font-mono text-xs">{{ lesson.addressId ?? '—' }}</dd>
                    </div>
                </dl>
            </div>

            {# RRule #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Règle de récurrence (RRule)</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Définit les occurrences automatiques du cours.</p>
                </div>
                <div class="px-6 py-5">
                    <code class="block bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-sm font-mono text-gray-800 break-all">{{ lesson.rrule }}</code>
                    {% if lesson.rruleDayOrder is not null %}
                        <p class="mt-2 text-xs text-gray-400">Ordre du jour : {{ lesson.rruleDayOrder }}</p>
                    {% endif %}
                </div>
            </div>

            {# Associated levels #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Niveaux associés</h2>
                </div>
                <div class="px-6 py-5">
                    {% if lesson.levels is empty %}
                        <p class="text-sm text-gray-400">Aucun niveau associé.</p>
                    {% else %}
                        <div class="flex flex-wrap gap-2">
                            {% for level in lesson.levels %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
                                    {{ level.name }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Associated age groups #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Groupes d'âge associés</h2>
                </div>
                <div class="px-6 py-5">
                    {% if lesson.ageGroups is empty %}
                        <p class="text-sm text-gray-400">Aucun groupe d'âge associé.</p>
                    {% else %}
                        <div class="flex flex-wrap gap-2">
                            {% for group in lesson.ageGroups %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                    {{ group.name }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Associated packages #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Forfaits associés</h2>
                </div>
                <div class="px-6 py-5">
                    {% if lesson.packages is empty %}
                        <p class="text-sm text-gray-400">Aucun forfait associé.</p>
                    {% else %}
                        <div class="flex flex-wrap gap-2">
                            {% for package in lesson.packages %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                                    {{ package.name }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Sidebar #}
        <div class="space-y-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-4 py-4 text-xs text-gray-400 space-y-1">
                <p class="text-sm font-semibold text-gray-700 mb-2">Informations techniques</p>
                <p><span class="font-medium text-gray-500">Créé le :</span> {{ lesson.createdAt|date('d/m/Y H:i') }}</p>
                <p><span class="font-medium text-gray-500">Mis à jour :</span> {{ lesson.updatedAt|date('d/m/Y H:i') }}</p>
                {% if lesson.deletedAt %}
                    <p class="text-red-500"><span class="font-medium">Supprimé le :</span> {{ lesson.deletedAt|date('d/m/Y H:i') }}</p>
                {% endif %}
                <p class="font-mono break-all pt-1">{{ lesson.id }}</p>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-4 py-3 bg-gray-50 border-b border-gray-100">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</p>
                </div>
                <nav class="divide-y divide-gray-50">
                    <a href="{{ path('school_season_lesson_occurences', {id: season.id, lessonId: lesson.id}) }}"
                       class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        Voir les séances
                    </a>
                    <a href="{{ path('school_season_lesson_participants', {id: season.id, lessonId: lesson.id}) }}"
                       class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Voir les participants
                    </a>
                    <a href="{{ path('school_season_lesson_edit', {id: season.id, lessonId: lesson.id}) }}"
                       class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Modifier ce cours
                    </a>
                </nav>
            </div>
        </div>
    </div>
</div>
{% endblock %}
