{% extends 'base.html.twig' %}

{% block title %}Modificateurs de prix — {{ season.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition-colors">Paramètres</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">{{ season.name }}</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-900 font-medium">Modificateurs de prix</span>
            </nav>
            <h1 class="text-2xl font-bold text-gray-900">Modificateurs de prix</h1>
            <p class="text-sm text-gray-500 mt-0.5">Réductions, majorations et autres règles tarifaires.</p>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if modifiers is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucun modificateur de prix pour cette saison.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Valeur</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type de valeur</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Opération</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Conditions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for modifier in modifiers %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-medium text-gray-900">{{ modifier.name }}</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if modifier.type.value == 'discount' %}bg-green-50 text-green-700
                                        {% elseif modifier.type.value == 'surcharge' %}bg-orange-50 text-orange-700
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {{ modifier.type.value }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">
                                    {% if modifier.valueType.value == 'percent' %}
                                        {{ modifier.value }} %
                                    {% else %}
                                        {{ (modifier.value / 100)|number_format(2, ',', ' ') }} €
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ modifier.valueType.value }}
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if modifier.operation.value == 'add' %}bg-blue-50 text-blue-700
                                        {% elseif modifier.operation.value == 'subtract' %}bg-red-50 text-red-700
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {{ modifier.operation.value }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-400">
                                    {% if modifier.terms %}
                                        <span class="text-xs font-mono bg-gray-50 px-2 py-0.5 rounded">{{ modifier.terms|json_encode }}</span>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ modifiers|length }} modificateur{{ modifiers|length > 1 ? 's' : '' }}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
