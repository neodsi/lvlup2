{% extends 'layout/school.html.twig' %}

{% block title %}{{ isEdit ? 'Modifier' : 'Nouveau' }} modificateur — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_season_price_modifiers', {id: season.id}) }}" class="hover:text-gray-700 transition">Frais & Réductions</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ isEdit ? 'Modifier' : 'Nouveau modificateur' }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8 max-w-2xl">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">{{ isEdit ? 'Modifier le modificateur' : 'Nouveau modificateur de prix' }}</h1>

    {% set initValueType = isEdit ? modifier.valueType.value : 'percentage' %}
    {% set initOperation = isEdit ? modifier.operation.value : 'subtract' %}
    {% set initVisibility = isEdit ? modifier.visibility : 'public' %}
    {% set initPackageTypes = isEdit and modifier.terms is not null and modifier.terms.package_types is defined ? modifier.terms.package_types : [] %}

    <form method="POST"
          x-data="priceModifierForm('{{ initValueType }}', '{{ initOperation }}', '{{ initVisibility }}', {{ initPackageTypes | json_encode }})"
          class="space-y-6">

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-5">

            {# Nom #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Nom <span class="text-red-500">*</span></label>
                <input type="text" name="name" required
                       value="{{ isEdit ? modifier.name : '' }}"
                       placeholder="Ex : Réduction fratrie, Frais de dossier tardif…"
                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
            </div>

            {# Description #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Description <span class="text-gray-400 font-normal">(optionnel)</span></label>
                <textarea name="description" rows="2"
                          placeholder="Ex : Appliqué à partir du 2ème élève de la même famille"
                          class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition resize-none">{{ isEdit ? modifier.description : '' }}</textarea>
            </div>

            {# Visibilité #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Visibilité</label>
                <div class="flex gap-3">
                    <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                           :class="visibility === 'public' ? 'border-indigo-400 bg-indigo-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                        <input type="radio" name="visibility" value="public" x-model="visibility" class="sr-only">
                        <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                              :class="visibility === 'public' ? 'border-indigo-500 bg-indigo-500' : 'border-gray-300'"></span>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Public</p>
                            <p class="text-xs text-gray-500">Visible par les familles</p>
                        </div>
                    </label>
                    <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                           :class="visibility === 'private' ? 'border-gray-400 bg-gray-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                        <input type="radio" name="visibility" value="private" x-model="visibility" class="sr-only">
                        <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                              :class="visibility === 'private' ? 'border-gray-500 bg-gray-500' : 'border-gray-300'"></span>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Privé</p>
                            <p class="text-xs text-gray-500">Appliqué manuellement par l'école</p>
                        </div>
                    </label>
                </div>
            </div>

            {# Portée #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Portée <span class="text-red-500">*</span></label>
                <select name="type" required
                        class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="cart" {{ isEdit and modifier.type.value == 'cart' ? 'selected' }}>Panier (appliqué une fois au total)</option>
                    <option value="profile" {{ isEdit and modifier.type.value == 'profile' ? 'selected' }}>Élève (multiplié par le nb d'élèves)</option>
                </select>
            </div>

            {# Limiter à certains forfaits #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Limiter à certains forfaits <span class="text-gray-400 font-normal">(optionnel — tous si rien sélectionné)</span></label>
                <div class="grid grid-cols-2 gap-2">
                    {% set packageOptions = [
                        {value: 'subscription_one_year',     label: 'Abonnement annuel'},
                        {value: 'subscription_one_semester', label: 'Abonnement semestriel'},
                        {value: 'subscription_one_quarter',  label: 'Abonnement trimestriel'},
                        {value: 'subscription_one_month',    label: 'Abonnement mensuel'},
                        {value: 'trial_class',               label: 'Cours d\'essai'},
                        {value: 'a_la_carte',                label: 'À la carte'},
                    ] %}
                    {% for opt in packageOptions %}
                    <label class="flex items-center gap-2.5 rounded-lg border border-gray-200 px-3 py-2.5 cursor-pointer hover:bg-gray-50 transition"
                           :class="packageTypes.includes('{{ opt.value }}') ? 'border-indigo-300 bg-indigo-50' : 'border-gray-200 bg-white'">
                        <input type="checkbox" name="package_types[]" value="{{ opt.value }}"
                               x-model="packageTypes"
                               class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                        <span class="text-sm text-gray-700">{{ opt.label }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>

            {# Opération #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Nature</label>
                <div class="flex gap-3">
                    <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                           :class="operation === 'subtract' ? 'border-green-400 bg-green-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                        <input type="radio" name="operation" value="subtract" x-model="operation" class="sr-only">
                        <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                              :class="operation === 'subtract' ? 'border-green-500 bg-green-500' : 'border-gray-300'"></span>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Réduction</p>
                            <p class="text-xs text-gray-500">Diminue le montant</p>
                        </div>
                    </label>
                    <label class="flex-1 flex items-center gap-3 rounded-lg border px-4 py-3 cursor-pointer transition"
                           :class="operation === 'add' ? 'border-orange-400 bg-orange-50' : 'border-gray-200 bg-white hover:bg-gray-50'">
                        <input type="radio" name="operation" value="add" x-model="operation" class="sr-only">
                        <span class="w-3 h-3 rounded-full border-2 flex-shrink-0 transition"
                              :class="operation === 'add' ? 'border-orange-500 bg-orange-500' : 'border-gray-300'"></span>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Majoration / Frais</p>
                            <p class="text-xs text-gray-500">Augmente le montant</p>
                        </div>
                    </label>
                </div>
            </div>

            {# Valeur #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Type de valeur</label>
                    <select name="valueType" x-model="valueType"
                            class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                        <option value="percentage">Pourcentage (%)</option>
                        <option value="fixed">Montant fixe (€)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">
                        Valeur <span x-text="valueType === 'percentage' ? '(%)' : '(€)'" class="text-gray-400 font-normal"></span>
                    </label>
                    <div class="relative">
                        <input type="number" name="value" required step="0.01" min="0"
                               value="{{ isEdit ? (modifier.value / 100)|number_format(2, '.', '') : '' }}"
                               :placeholder="valueType === 'percentage' ? 'Ex : 10' : 'Ex : 15'"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 pr-10 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-400 pointer-events-none"
                              x-text="valueType === 'percentage' ? '%' : '€'"></span>
                    </div>
                    <p class="mt-1 text-xs text-gray-400" x-show="valueType === 'percentage'">Ex : 10 = 10%</p>
                    <p class="mt-1 text-xs text-gray-400" x-show="valueType === 'fixed'">Ex : 15 = 15,00 €</p>
                </div>
            </div>

        </div>

        <div class="flex items-center gap-3">
            <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition">
                {{ isEdit ? 'Enregistrer' : 'Créer le modificateur' }}
            </button>
            <a href="{{ path('school_season_price_modifiers', {id: season.id}) }}"
               class="text-sm text-gray-500 hover:text-gray-700 transition">Annuler</a>
        </div>

    </form>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
function priceModifierForm(initValueType, initOperation, initVisibility, initPackageTypes) {
    return {
        valueType: initValueType,
        operation: initOperation,
        visibility: initVisibility,
        packageTypes: initPackageTypes,
    };
}
</script>
{% endblock %}
