{% extends 'layout/school.html.twig' %}

{% block title %}Forfaits — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Forfaits</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Forfaits</h1>
    <a href="{{ path('school_season_package_create', {id: season.id}) }}"
       class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Créer un forfait
    </a>
</div>

{% set typeLabels = {
    'subscription_one_year': 'Abonnement annuel',
    'subscription_one_semester': 'Abonnement semestriel',
    'subscription_one_quarter': 'Abonnement trimestriel',
    'subscription_one_month': 'Abonnement mensuel',
    'trial_class': 'Cours d\'essai',
    'a_la_carte': 'À la carte',
    'registration_fee': 'Frais d\'inscription',
} %}
{% set typeColors = {
    'subscription_one_year': 'bg-purple-50 text-purple-700',
    'subscription_one_semester': 'bg-violet-50 text-violet-700',
    'subscription_one_quarter': 'bg-orange-50 text-orange-700',
    'subscription_one_month': 'bg-teal-50 text-teal-700',
    'trial_class': 'bg-green-50 text-green-700',
    'a_la_carte': 'bg-blue-50 text-blue-700',
    'registration_fee': 'bg-amber-50 text-amber-700',
} %}

{% if packages is empty %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-16 text-center">
        <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
        <p class="mt-4 text-sm text-gray-500">Aucun forfait pour cette saison.</p>
        <a href="{{ path('school_season_package_create', {id: season.id}) }}"
           class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Créer le premier forfait
        </a>
    </div>
{% else %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {% for package in packages %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col overflow-hidden hover:shadow-md transition-shadow {{ package.deletedAt ? 'opacity-60' : '' }}">
                <div class="px-5 pt-5 pb-4 flex-1">
                    <div class="flex items-start justify-between gap-2 mb-3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ typeColors[package.type.value] ?? 'bg-gray-100 text-gray-600' }}">
                            {{ typeLabels[package.type.value] ?? package.type.value }}
                        </span>
                        {% if package.deletedAt %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-50 text-red-600">Archivé</span>
                        {% endif %}
                    </div>
                    <h3 class="text-sm font-semibold text-gray-900 leading-snug">{{ package.name }}</h3>

                    <div class="mt-4 space-y-1.5 text-xs text-gray-500">
                        {% if package.classesQty %}
                            <div class="flex items-center gap-2">
                                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                                {{ package.classesQty }} cours
                            </div>
                        {% endif %}
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% if package.validityStartType.value == 'at_attribution' %}Débute à l'attribution{% else %}Date fixe{% endif %}
                        </div>
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {% if package.expirationType.value == 'seasonal' %}Fin de saison{% else %}Date fixe{% endif %}
                        </div>
                        {% if package.expiresAt %}
                            <div class="flex items-center gap-2 text-orange-600">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                                Expire le {{ package.expiresAt|date('d/m/Y') }}
                            </div>
                        {% endif %}
                        <div class="flex items-center gap-2 text-gray-400">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            {{ package.usageCount }} attribution{{ package.usageCount > 1 ? 's' : '' }}
                        </div>
                    </div>
                </div>

                <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between gap-2">
                    <span class="text-base font-bold text-gray-900">{{ (package.price / 100)|number_format(2, ',', ' ') }} €</span>
                    <div class="flex items-center gap-3">
                        <a href="{{ path('school_season_package_edit', {id: season.id, packageId: package.id}) }}"
                           class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">Modifier</a>
                        {% if not package.deletedAt %}
                        <form method="POST" action="{{ path('school_season_package_delete', {id: season.id, packageId: package.id}) }}"
                              onsubmit="return confirm(this.dataset.confirm)">
                            <input type="hidden" name="_token" value="{{ csrf_token('package_delete_' ~ package.id) }}">
                            {% if package.usageCount > 0 %}
                                <button type="submit"
                                        data-confirm="Archiver ce forfait ? Il est assigné à {{ package.usageCount }} élève{{ package.usageCount > 1 ? 's' : '' }}."
                                        class="text-xs text-orange-400 hover:text-orange-600 font-medium transition">Archiver</button>
                            {% else %}
                                <button type="submit"
                                        data-confirm="Supprimer définitivement ce forfait ?"
                                        class="text-xs text-red-400 hover:text-red-600 font-medium transition">Supprimer</button>
                            {% endif %}
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

</div>
{% endblock %}
