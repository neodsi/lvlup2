{% extends 'layout/school.html.twig' %}

{% block title %}Niveaux — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ team.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Niveaux</span>
{% endblock %}

{% block school_content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Niveaux</h1>
</div>

    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

            {# Inline add form #}
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-100">
                <form method="POST" action="{{ path('school_season_levels', {id: season.id}) }}"
                      class="flex items-center gap-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('level_create') }}">
                    <input type="text" name="name" required placeholder="Nom du niveau (ex: Débutant, Intermédiaire…)"
                           class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <button type="submit"
                            class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Ajouter
                    </button>
                </form>
            </div>

            {% if levels is empty %}
                <div class="px-6 py-12 text-center text-sm text-gray-400">
                    Aucun niveau. Utilisez le formulaire ci-dessus pour en ajouter un.
                </div>
            {% else %}
                <ul class="divide-y divide-gray-50">
                    {% for level in levels %}
                        <li class="flex items-center justify-between px-6 py-3.5 hover:bg-gray-50 transition-colors group">
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 text-gray-300 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
                                </svg>
                                <span class="text-sm font-medium text-gray-800">{{ level.name }}</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-xs text-gray-400 font-mono hidden sm:inline">{{ level.id|slice(0, 8) }}…</span>
                                <form method="POST" action="{{ path('school_season_levels', {id: season.id}) }}"
                                      onsubmit="return confirm('Supprimer ce niveau ?')">
                                    <input type="hidden" name="_method" value="DELETE">
                                    <input type="hidden" name="_token" value="{{ csrf_token('level_delete_' ~ level.id) }}">
                                    <input type="hidden" name="levelId" value="{{ level.id }}">
                                    <button type="submit"
                                            class="text-gray-300 hover:text-red-500 transition-colors p-1 rounded"
                                            title="Supprimer">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </form>
                            </div>
                        </li>
                    {% endfor %}
                </ul>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ levels|length }} niveau{{ levels|length > 1 ? 'x' : '' }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
