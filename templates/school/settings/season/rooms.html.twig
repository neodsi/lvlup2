{% extends 'layout/school.html.twig' %}

{% block title %}Salles — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Salles</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Salles</h1>
    <a href="{{ path('school_season_room_create', {id: season.id}) }}"
       class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Créer une salle
    </a>
</div>

{% if rooms is empty %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-16 text-center">
        <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        <p class="mt-4 text-sm text-gray-500">Aucune salle pour cette saison.</p>
        <a href="{{ path('school_season_room_create', {id: season.id}) }}"
           class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Créer la première salle
        </a>
    </div>
{% else %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Salle</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Capacité</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Adresse</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {% for room in rooms %}
                    {% if not room.deletedAt %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ room.name }}</td>
                        <td class="px-6 py-4 text-sm text-gray-500">
                            {% if room.maxCapacity %}
                                <span class="inline-flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    {{ room.maxCapacity }} pers.
                                </span>
                            {% else %}
                                <span class="text-gray-300">—</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500 hidden md:table-cell max-w-xs truncate">
                            {{ room.addressText ?: '—' }}
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('school_season_room_edit', {id: season.id, roomId: room.id}) }}"
                                   class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">Modifier</a>
                                <form method="POST" action="{{ path('school_season_room_delete', {id: season.id, roomId: room.id}) }}"
                                      onsubmit="return confirm('Supprimer cette salle ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('room_delete_' ~ room.id) }}">
                                    <button type="submit" class="text-xs text-red-400 hover:text-red-600 font-medium transition">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
        <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
            {% set active = rooms|filter(r => not r.deletedAt) %}
            {{ active|length }} salle{{ active|length > 1 ? 's' : '' }}
        </div>
    </div>
{% endif %}

</div>
{% endblock %}
