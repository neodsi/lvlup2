{% extends 'layout/school.html.twig' %}

{% block title %}Participants — {{ lesson.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_season_events', {id: season.id}) }}" class="hover:text-gray-700 transition">Cours</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Participants</span>
{% endblock %}

{% block school_content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Participants</h1>
</div>
    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if participants is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucun participant enregistré pour ce cours.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Profil (ID)</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Séance (ID)</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Présence</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Enregistré le</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for participant in participants %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono text-gray-600">{{ participant.schoolProfileId|slice(0, 8) }}…</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono text-gray-400">{{ participant.occurenceId|slice(0, 8) }}…</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if participant.attendanceStatus is defined and participant.attendanceStatus == 'present' %}bg-green-50 text-green-700
                                        {% elseif participant.attendanceStatus is defined and participant.attendanceStatus == 'absent' %}bg-red-50 text-red-600
                                        {% else %}bg-gray-100 text-gray-500{% endif %}">
                                        <span class="w-1.5 h-1.5 rounded-full
                                            {% if participant.attendanceStatus is defined and participant.attendanceStatus == 'present' %}bg-green-400
                                            {% elseif participant.attendanceStatus is defined and participant.attendanceStatus == 'absent' %}bg-red-400
                                            {% else %}bg-gray-400{% endif %} inline-block"></span>
                                        {% if participant.attendanceStatus is defined %}
                                            {% if participant.attendanceStatus == 'present' %}Présent
                                            {% elseif participant.attendanceStatus == 'absent' %}Absent
                                            {% else %}{{ participant.attendanceStatus }}{% endif %}
                                        {% else %}
                                            Non renseigné
                                        {% endif %}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ participant.createdAt|date('d/m/Y H:i') }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ participants|length }} entrée{{ participants|length > 1 ? 's' : '' }} au total
                </div>
            {% endif %}
        </div>
    </div>

{% endblock %}
