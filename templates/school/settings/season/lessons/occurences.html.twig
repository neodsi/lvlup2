{% extends 'base.html.twig' %}

{% block title %}Séances — {{ lesson.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    {# Header #}
    <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition-colors">Paramètres</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">{{ season.name }}</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_season_lessons', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">Cours</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_season_lesson_detail', {id: season.id, lessonId: lesson.id}) }}" class="hover:text-gray-700 transition-colors">{{ lesson.name }}</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-900 font-medium">Séances</span>
            </nav>
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Séances</h1>
                    <p class="text-sm text-gray-500 mt-0.5">{{ lesson.name }}</p>
                </div>
                <div class="flex items-center gap-3 text-sm">
                    {% set cancelledCount = 0 %}
                    {% for o in occurences %}{% if o.isCancelled %}{% set cancelledCount = cancelledCount + 1 %}{% endif %}{% endfor %}
                    <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-xs font-medium">
                        {{ occurences|length }} séance{{ occurences|length > 1 ? 's' : '' }}
                    </span>
                    {% if cancelledCount > 0 %}
                        <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full text-xs font-medium">
                            {{ cancelledCount }} annulée{{ cancelledCount > 1 ? 's' : '' }}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if occurences is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucune séance générée pour ce cours.</p>
                    <p class="mt-1 text-xs text-gray-400">Les séances sont générées automatiquement d'après la RRule.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">#</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Heure</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Participants</th>
                            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for idx, occurence in occurences %}
                            <tr class="hover:bg-gray-50 transition-colors {% if occurence.isCancelled %}opacity-60{% endif %}">
                                <td class="px-6 py-4 text-sm text-gray-400 font-mono">{{ idx + 1 }}</td>
                                <td class="px-6 py-4 text-sm text-gray-900 font-medium">
                                    {{ occurence.occurenceAt|date('d/m/Y') }}
                                    <span class="ml-1 text-xs text-gray-400 capitalize">{{ occurence.occurenceAt|date('l')|lower }}</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ occurence.occurenceAt|date('H:i') }}
                                </td>
                                <td class="px-6 py-4">
                                    {% if occurence.isCancelled %}
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-400 inline-block"></span>
                                            Annulée
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
                                            Planifiée
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    —
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="text-xs text-gray-400 font-mono">{{ occurence.id|slice(0,8) }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ occurences|length }} séance{{ occurences|length > 1 ? 's' : '' }} au total
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
