{% extends 'layout/school.html.twig' %}

{% block title %}Cours — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_season_lessons', {id: season.id}) }}" class="hover:text-gray-700 transition">Cours</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Cours</span>
{% endblock %}

{% block school_content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Cours</h1>
</div>
    {# Add lesson modal #}
    <div id="modal-add-lesson" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900">Nouveau cours</h2>
                <button id="btn-close-modal" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <form method="POST" action="{{ path('school_season_lessons_create', {id: season.id}) }}" class="px-6 py-5 space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('lesson_create') }}">
                <p class="text-xs text-gray-400 mb-4">Les champs marqués <span class="text-red-500 font-medium">*</span> sont obligatoires.</p>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nom du cours <span class="text-red-500">*</span></label>
                    <input type="text" name="name" required
                           class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                           placeholder="Ex: Gym artistique débutant">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Début <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="startAt" required
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fin <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="endAt" required
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Règle de récurrence (RRule)</label>
                    <input type="text" name="rrule"
                           class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                           placeholder="FREQ=WEEKLY;BYDAY=MO;UNTIL=20260630T000000Z">
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" id="btn-cancel-modal"
                            class="text-gray-600 hover:text-gray-800 text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 transition-colors">
                        Annuler
                    </button>
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if lessons is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucun cours pour cette saison.</p>
                    <button type="button" id="btn-add-lesson-empty"
                            class="mt-4 inline-flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                        Ajouter le premier cours
                    </button>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Planning</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Intervenant</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Participants max</th>
                            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for lesson in lessons %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <a href="{{ path('school_season_lesson_detail', {id: season.id, lessonId: lesson.id}) }}"
                                       class="text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
                                        {{ lesson.name }}
                                    </a>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                                        {{ lesson.type.value }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ lesson.startAt|date('d/m/Y H:i') }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ lesson.teacherId ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ lesson.maxParticipants ?? '∞' }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <a href="{{ path('school_season_lesson_occurences', {id: season.id, lessonId: lesson.id}) }}"
                                           class="text-xs text-gray-500 hover:text-gray-700 transition-colors">Séances</a>
                                        <a href="{{ path('school_season_lesson_participants', {id: season.id, lessonId: lesson.id}) }}"
                                           class="text-xs text-gray-500 hover:text-gray-700 transition-colors">Participants</a>
                                        <a href="{{ path('school_season_lesson_detail', {id: season.id, lessonId: lesson.id}) }}"
                                           class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition-colors">Détail</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ lessons|length }} cours au total
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
(function() {
    const modal = document.getElementById('modal-add-lesson');
    const open = () => modal.classList.remove('hidden');
    const close = () => modal.classList.add('hidden');
    document.getElementById('btn-add-lesson')?.addEventListener('click', open);
    document.getElementById('btn-add-lesson-empty')?.addEventListener('click', open);
    document.getElementById('btn-close-modal')?.addEventListener('click', close);
    document.getElementById('btn-cancel-modal')?.addEventListener('click', close);
    modal?.addEventListener('click', e => { if (e.target === modal) close(); });
})();
</script>
{% endblock %}
