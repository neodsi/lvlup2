{% extends 'layout/school.html.twig' %}

{% set isDuplicate = source is defined %}
{% set fe         = isDuplicate ? source : null %}
{% set feMode     = isDuplicate ? parsedMode : 'weekly' %}
{% set feDays     = isDuplicate ? parsedDays : [] %}
{% set feUntil    = isDuplicate ? parsedUntil : season.endAt|date('Y-m-d') %}

{% block title %}{{ isDuplicate ? 'Dupliquer' : 'Nouveau cours' }} — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_season_events', {id: season.id}) }}" class="hover:text-gray-700 transition">Cours</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ isDuplicate ? 'Dupliquer' : 'Nouveau cours' }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">{{ isDuplicate ? 'Dupliquer un cours' : 'Nouveau cours' }}</h1>
</div>

<form method="POST" action="{{ path('school_season_event_create', {id: season.id}) }}"
      class="space-y-6 max-w-2xl"
      x-data="lessonForm({
          mode: '{{ feMode }}',
          days: {{ feDays|json_encode }},
          seasonStart: '{{ season.startAt|date('Y-m-d') }}',
          seasonEnd: '{{ season.endAt|date('Y-m-d') }}',
          roomId: '{{ fe and fe.roomId ? fe.roomId : '' }}',
          roomsData: { {% for room in rooms %}'{{ room.id }}': {{ room.maxCapacity ?? 'null' }}{% if not loop.last %},{% endif %}{% endfor %} }
      })">
    <input type="hidden" name="_token" value="{{ csrf_token('lesson_create') }}">

    {% include 'school/settings/season/lessons/_fields.html.twig' with {
        fe: fe,
        feUntil: feUntil,
        isDuplicate: isDuplicate,
        withBounds: true,
        initMode: feMode
    } %}

    <div class="flex items-center gap-3">
        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors">
            Créer le cours
        </button>
        <a href="{{ path('school_season_events', {id: season.id}) }}"
           class="text-sm text-gray-500 hover:text-gray-700 transition">Annuler</a>
    </div>
</form>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
{{ include('school/settings/season/lessons/_js.html.twig') }}
{% endblock %}
