{% extends 'base.html.twig' %}

{% block title %}Gala — {{ season.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">

    <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('school_settings') }}" class="hover:text-gray-700 transition-colors">Paramètres</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition-colors">{{ season.name }}</a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-900 font-medium">Gala</span>
            </nav>
            <div class="flex items-center justify-between">
                <h1 class="text-2xl font-bold text-gray-900">Participations Gala</h1>
                <div class="flex items-center gap-3">
                    {% set yesCount = 0 %}{% set noCount = 0 %}{% set pendingCount = 0 %}
                    {% for p in participations %}
                        {% if p.participates == true %}{% set yesCount = yesCount + 1 %}
                        {% elseif p.participates == false %}{% set noCount = noCount + 1 %}
                        {% else %}{% set pendingCount = pendingCount + 1 %}{% endif %}
                    {% endfor %}
                    <span class="bg-green-50 text-green-700 px-2.5 py-0.5 rounded-full text-xs font-medium">{{ yesCount }} oui</span>
                    <span class="bg-red-50 text-red-700 px-2.5 py-0.5 rounded-full text-xs font-medium">{{ noCount }} non</span>
                    <span class="bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-full text-xs font-medium">{{ pendingCount }} en attente</span>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            {% if participations is empty %}
                <div class="px-6 py-16 text-center">
                    <svg class="mx-auto w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                    </svg>
                    <p class="mt-4 text-sm text-gray-500">Aucune participation gala enregistrée pour cette saison.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Membre (ID profil)</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Événement (ID)</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Participation</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Notes</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date réponse</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for participation in participations %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono text-gray-600">{{ participation.teamProfileId|slice(0, 8) }}…</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono text-gray-400">{{ participation.eventId|slice(0, 8) }}…</span>
                                </td>
                                <td class="px-6 py-4">
                                    {% if participation.participates == true %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                            Participe
                                        </span>
                                    {% elseif participation.participates == false %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                                            Ne participe pas
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
                                            En attente
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
                                    {{ participation.notes ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ participation.updatedAt|date('d/m/Y H:i') }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ participations|length }} réponse{{ participations|length > 1 ? 's' : '' }} au total
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
