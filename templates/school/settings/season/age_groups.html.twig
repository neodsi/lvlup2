{% extends 'layout/school.html.twig' %}

{% block title %}Groupes d'âge — {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_settings_season', {id: season.id}) }}" class="hover:text-gray-700 transition">Config {{ season.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Groupes d'âge</span>
{% endblock %}

{% block school_content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Groupes d'âge</h1>
</div>

    <div class="py-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

            {# Inline add form #}
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-100">
                <form method="POST" action="{{ path('school_season_age_groups', {id: season.id}) }}"
                      class="flex flex-wrap items-end gap-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('age_group_create') }}">
                    <div class="flex-1 min-w-40">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Nom du groupe <span class="text-red-500">*</span></label>
                        <input type="text" name="name" required placeholder="Ex: Mini (4-6 ans)"
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                    <div class="w-24">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Âge min</label>
                        <input type="number" name="minAge" min="0" max="99" placeholder="—"
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                    <div class="w-24">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Âge max</label>
                        <input type="number" name="maxAge" min="0" max="99" placeholder="—"
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                    <button type="submit"
                            class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Ajouter
                    </button>
                </form>
            </div>

            {% if groups is empty %}
                <div class="px-6 py-12 text-center text-sm text-gray-400">
                    Aucun groupe d'âge. Utilisez le formulaire ci-dessus pour en ajouter un.
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-white">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Âge min</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Âge max</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Tranche</th>
                            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        {% for group in groups %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-medium text-gray-900">{{ group.name }}</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ group.minAge is not null ? group.minAge ~ ' ans' : '—' }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    {{ group.maxAge is not null ? group.maxAge ~ ' ans' : '—' }}
                                </td>
                                <td class="px-6 py-4">
                                    {% if group.minAge is not null and group.maxAge is not null %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                            {{ group.minAge }}–{{ group.maxAge }} ans
                                        </span>
                                    {% elseif group.minAge is not null %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                                            {{ group.minAge }}+ ans
                                        </span>
                                    {% elseif group.maxAge is not null %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                                            Jusqu'à {{ group.maxAge }} ans
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-xs">Tous âges</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <form method="POST" action="{{ path('school_season_age_groups', {id: season.id}) }}"
                                          onsubmit="return confirm('Supprimer ce groupe d\'âge ?')"
                                          class="inline">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <input type="hidden" name="_token" value="{{ csrf_token('age_group_delete_' ~ group.id) }}">
                                        <input type="hidden" name="groupId" value="{{ group.id }}">
                                        <button type="submit"
                                                class="text-gray-300 hover:text-red-500 transition-colors p-1 rounded"
                                                title="Supprimer">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
                    {{ groups|length }} groupe{{ groups|length > 1 ? 's' : '' }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
