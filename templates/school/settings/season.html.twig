{% block scripts %}
{{ parent() }}
<script>
function closuresEditor(initial) {
    var _next = 0;
    function sortByDate(arr) {
        return arr.slice().sort(function(a, b) {
            return (a.start_at || '').localeCompare(b.start_at || '');
        });
    }
    var initialItems = Array.isArray(initial) ? initial.map(function(c) {
        return { label: c.label || '', start_at: c.start_at || '', end_at: c.end_at || '', _idx: _next++ };
    }) : [];
    return {
        items: sortByDate(initialItems),
        syncEnd(item) {
            if (!item.end_at || item.end_at < item.start_at) {
                item.end_at = item.start_at;
            }
        },
        add() {
            this.items.push({ label: '', start_at: '', end_at: '', _idx: _next++ });
        },
        remove(idx) {
            this.items = this.items.filter(function(i) { return i._idx !== idx; });
        },
        serialize() {
            var sorted = sortByDate(this.items);
            this.$refs.closuresInput.value = JSON.stringify(
                sorted.map(function(i) { return { label: i.label, start_at: i.start_at, end_at: i.end_at }; })
            );
        }
    };
}
</script>
<script>
(function () {
    function linkDates(startId, endId) {
        var s = document.getElementById(startId);
        var e = document.getElementById(endId);
        if (!s || !e) return;
        if (s.value) e.min = s.value;
        s.addEventListener('change', function () {
            e.min = s.value;
            if (!e.value || e.value < s.value) e.value = s.value;
        });
    }
    linkDates('startAt', 'endAt');
    linkDates('preRegistrationsStartAt', 'preRegistrationsEndAt');
    linkDates('registrationsStartAt', 'registrationsEndAt');
})();
</script>
<script>
function seasonImages(uploadUrl, deleteUrl) {
    return {
        uploadUrl: uploadUrl,
        deleteUrl: deleteUrl,
        images: {
            planning: {
                url: {{ season.planningImagePath ? ('\'/' ~ season.planningImagePath ~ '\'')|raw : 'null' }},
                loading: false,
                error: '',
            },
            packages: {
                url: {{ season.packagesImagePath ? ('\'/' ~ season.packagesImagePath ~ '\'')|raw : 'null' }},
                loading: false,
                error: '',
            },
        },
        key(field) {
            return field === 'planningImage' ? 'planning' : 'packages';
        },
        async uploadImage(event, field) {
            const file = event.target.files[0];
            if (!file) return;
            const k = this.key(field);
            this.images[k].loading = true;
            this.images[k].error = '';
            const fd = new FormData();
            fd.append('file', file);
            fd.append('field', field);
            try {
                const res = await fetch(this.uploadUrl, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    this.images[k].url = data.url;
                } else {
                    this.images[k].error = data.error || 'Erreur lors du téléversement.';
                }
            } catch (e) {
                this.images[k].error = 'Erreur réseau.';
            } finally {
                this.images[k].loading = false;
                event.target.value = '';
            }
        },
        async deleteImage(field) {
            const k = this.key(field);
            this.images[k].loading = true;
            this.images[k].error = '';
            const fd = new FormData();
            fd.append('field', field);
            try {
                const res = await fetch(this.deleteUrl, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    this.images[k].url = null;
                } else {
                    this.images[k].error = data.error || 'Erreur lors de la suppression.';
                }
            } catch (e) {
                this.images[k].error = 'Erreur réseau.';
            } finally {
                this.images[k].loading = false;
            }
        },
    };
}
</script>
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
(function () {
    const container = document.getElementById('editor-readAndCheck');
    const textarea  = document.getElementById('textarea-readAndCheck');
    if (!container || !textarea) return;
    const quill = new Quill(container, {
        theme: 'snow',
        modules: { toolbar: [
            [{header: [2, 3, false]}],
            ['bold', 'italic', 'underline'],
            [{list: 'ordered'}, {list: 'bullet'}],
            ['link'],
            ['clean'],
        ]},
    });
    if (textarea.value) quill.root.innerHTML = textarea.value;
    textarea.closest('form').addEventListener('submit', function () {
        textarea.value = quill.root.innerHTML;
    });
})();
</script>
