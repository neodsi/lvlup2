{% extends 'layout/school.html.twig' %}

{% block title %}Config {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Config {{ season.name }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Config {{ season.name }}</h1>
</div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Main form #}
        <div class="lg:col-span-2 space-y-6">

            {# Informations générales #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Informations générales</h2>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" class="px-6 py-5 space-y-5">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">

                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nom de la saison <span class="text-red-500">*</span></label>
                        <input type="text" id="name" name="name" value="{{ season.name }}" required
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="startAt" class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
                            <input type="date" id="startAt" name="startAt"
                                   value="{{ season.startAt|date('Y-m-d') }}"
                                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        </div>
                        <div>
                            <label for="endAt" class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
                            <input type="date" id="endAt" name="endAt"
                                   value="{{ season.endAt|date('Y-m-d') }}"
                                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        </div>
                    </div>

                    <div class="pt-2 flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer
                        </button>
                    </div>
                </form>
            </div>

            {# Frais d'inscription #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Frais d'inscription</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Forfait associé aux frais d'inscription de la saison.</p>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" class="px-6 py-5 space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">
                    <div>
                        <label for="registrationFeeId" class="block text-sm font-medium text-gray-700 mb-1">Identifiant du forfait (frais d'inscription)</label>
                        <input type="text" id="registrationFeeId" name="registrationFeeId"
                               value="{{ season.registrationFeeId ?? '' }}"
                               placeholder="UUID du forfait ou vide"
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        <p class="mt-1 text-xs text-gray-400">Laissez vide pour désactiver les frais d'inscription automatiques.</p>
                    </div>
                    <div class="flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer
                        </button>
                    </div>
                </form>
            </div>

            {# Fermetures #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Fermetures</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Périodes de fermeture (vacances, jours fériés…). Format JSON : tableau d'objets <code class="text-xs bg-gray-100 px-1 rounded">{start_at, end_at, label}</code>.</p>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" class="px-6 py-5 space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">
                    <div>
                        <label for="closures" class="block text-sm font-medium text-gray-700 mb-1">Fermetures (JSON)</label>
                        <textarea id="closures" name="closures" rows="8"
                                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                                  placeholder='[{"start_at":"2025-12-22","end_at":"2026-01-05","label":"Vacances de Noël"}]'>{{ season.closures ? (season.closures|json_encode(constant('JSON_PRETTY_PRINT'))) : '[]' }}</textarea>
                    </div>

                    {# Visual preview of closures #}
                    {% if season.closures %}
                        <div class="rounded-lg border border-gray-100 bg-gray-50 divide-y divide-gray-100 overflow-hidden">
                            {% for closure in season.closures %}
                                <div class="flex items-center justify-between px-4 py-2.5 text-sm">
                                    <span class="font-medium text-gray-800">{{ closure.label ?? 'Sans libellé' }}</span>
                                    <span class="text-gray-500 text-xs">
                                        {{ closure.start_at is defined ? closure.start_at : '' }}
                                        {% if closure.end_at is defined %} → {{ closure.end_at }}{% endif %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <div class="flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer les fermetures
                        </button>
                    </div>
                </form>
            </div>

            {# Images #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Images</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Planning et forfaits visuels de la saison.</p>
                </div>
                <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-6">
                    {# Planning image #}
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-2">Image du planning</p>
                        {% if season.planningImagePath %}
                            <img src="{{ asset(season.planningImagePath) }}" alt="Planning" class="w-full rounded-lg border border-gray-200 object-cover h-32">
                            <p class="mt-1 text-xs text-gray-400 truncate">{{ season.planningImagePath }}</p>
                        {% else %}
                            <div class="flex items-center justify-center h-32 rounded-lg border-2 border-dashed border-gray-200 bg-gray-50">
                                <span class="text-sm text-gray-400">Aucune image</span>
                            </div>
                        {% endif %}
                        <label class="mt-3 flex items-center gap-2 text-xs text-indigo-600 cursor-pointer hover:text-indigo-800 transition-colors font-medium">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                            Téléverser une image
                            <input type="file" class="sr-only" accept="image/*">
                        </label>
                    </div>
                    {# Packages image #}
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-2">Image des forfaits</p>
                        {% if season.packagesImagePath %}
                            <img src="{{ asset(season.packagesImagePath) }}" alt="Forfaits" class="w-full rounded-lg border border-gray-200 object-cover h-32">
                            <p class="mt-1 text-xs text-gray-400 truncate">{{ season.packagesImagePath }}</p>
                        {% else %}
                            <div class="flex items-center justify-center h-32 rounded-lg border-2 border-dashed border-gray-200 bg-gray-50">
                                <span class="text-sm text-gray-400">Aucune image</span>
                            </div>
                        {% endif %}
                        <label class="mt-3 flex items-center gap-2 text-xs text-indigo-600 cursor-pointer hover:text-indigo-800 transition-colors font-medium">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                            Téléverser une image
                            <input type="file" class="sr-only" accept="image/*">
                        </label>
                    </div>
                </div>
            </div>
        </div>

        {# Sidebar navigation #}
        <div class="space-y-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-4 py-3 bg-gray-50 border-b border-gray-100">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Navigation saison</p>
                </div>
                <nav class="divide-y divide-gray-50">
                    {% set navItems = [
                        {label: 'Cours & événements', route: 'school_season_lessons', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'},
                        {label: 'Forfaits', route: 'school_season_packages', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'},
                        {label: 'Échéanciers', route: 'school_season_payment_schedulers', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'},
                        {label: 'Modificateurs de prix', route: 'school_season_price_modifiers', icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z'},
                        {label: 'Salles', route: 'school_season_rooms', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'},
                        {label: 'Niveaux', route: 'school_season_levels', icon: 'M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12'},
                        {label: 'Groupes d\'âge', route: 'school_season_age_groups', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0'},
                        {label: 'Adresses', route: 'school_season_addresses', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'},
                        {label: 'Gala', route: 'school_season_gala', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z'},
                        {label: 'Statistiques', route: 'school_settings_season_stats', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'},
                    ] %}
                    {% for item in navItems %}
                        <a href="{{ path(item.route, {id: season.id}) }}"
                           class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors group">
                            <svg class="w-4 h-4 text-gray-400 group-hover:text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ item.icon }}"/>
                            </svg>
                            {{ item.label }}
                            <svg class="w-4 h-4 ml-auto text-gray-300 group-hover:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    {% endfor %}
                </nav>
            </div>

            {# Meta info #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-4 py-4 text-xs text-gray-400 space-y-1">
                <p><span class="font-medium text-gray-500">Créée le :</span> {{ season.createdAt|date('d/m/Y') }}</p>
                <p><span class="font-medium text-gray-500">Mise à jour :</span> {{ season.updatedAt|date('d/m/Y H:i') }}</p>
                <p class="font-mono break-all">{{ season.id }}</p>
            </div>
        </div>
    </div>

</div>
{% endblock %}
