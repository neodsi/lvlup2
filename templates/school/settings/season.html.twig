{% extends 'layout/school.html.twig' %}

{% block title %}Config {{ season.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Config {{ season.name }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Config {{ season.name }}</h1>
</div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Main form #}
        <div class="lg:col-span-2 space-y-6">

            {# Informations générales #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Informations générales</h2>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" class="px-6 py-5 space-y-5">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">
                    <input type="hidden" name="_section" value="general">

                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nom de la saison <span class="text-red-500">*</span></label>
                        <input type="text" id="name" name="name" value="{{ season.name }}" required
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="startAt" class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
                            <input type="date" id="startAt" name="startAt"
                                   value="{{ season.startAt|date('Y-m-d') }}"
                                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                        </div>
                        <div>
                            <label for="endAt" class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
                            <input type="date" id="endAt" name="endAt"
                                   value="{{ season.endAt|date('Y-m-d') }}"
                                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                        </div>
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Notes internes</label>
                        <textarea id="description" name="description" rows="3"
                                  class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
                                  placeholder="Mémos, contraintes, remarques pour l'équipe…">{{ season.description ?? '' }}</textarea>
                    </div>

                    <div class="flex items-center gap-3">
                        <input type="hidden" name="visible" value="0">
                        <input type="checkbox" id="visible" name="visible" value="1" {{ season.visible ? 'checked' : '' }}
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                        <label for="visible" class="text-sm text-gray-700">Saison visible publiquement</label>
                    </div>

                    <div class="pt-2 flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer
                        </button>
                    </div>
                </form>
            </div>

            {# Inscriptions #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Inscriptions</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Périodes d'ouverture et paramètres des inscriptions en ligne.</p>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" class="px-6 py-5 space-y-5">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">
                    <input type="hidden" name="_section" value="registrations">

                    {# Pré-inscriptions #}
                    <div>
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Pré-inscriptions</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="preRegistrationsStartAt" class="block text-sm font-medium text-gray-700 mb-1">Ouverture</label>
                                <input type="date" id="preRegistrationsStartAt" name="preRegistrationsStartAt"
                                       value="{{ season.preRegistrationsStartAt ? season.preRegistrationsStartAt|date('Y-m-d') : '' }}"
                                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                            </div>
                            <div>
                                <label for="preRegistrationsEndAt" class="block text-sm font-medium text-gray-700 mb-1">Fermeture</label>
                                <input type="date" id="preRegistrationsEndAt" name="preRegistrationsEndAt"
                                       value="{{ season.preRegistrationsEndAt ? season.preRegistrationsEndAt|date('Y-m-d') : '' }}"
                                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                            </div>
                        </div>
                    </div>

                    {# Inscriptions #}
                    <div>
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Inscriptions</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="registrationsStartAt" class="block text-sm font-medium text-gray-700 mb-1">Ouverture</label>
                                <input type="date" id="registrationsStartAt" name="registrationsStartAt"
                                       value="{{ season.registrationsStartAt ? season.registrationsStartAt|date('Y-m-d') : '' }}"
                                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                            </div>
                            <div>
                                <label for="registrationsEndAt" class="block text-sm font-medium text-gray-700 mb-1">Fermeture</label>
                                <input type="date" id="registrationsEndAt" name="registrationsEndAt"
                                       value="{{ season.registrationsEndAt ? season.registrationsEndAt|date('Y-m-d') : '' }}"
                                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                            </div>
                        </div>
                    </div>

                    {# Frais d'inscription #}
                    {% set feePackage = (packages is defined ? packages : [])|filter(p => p.type.value == 'registration_fee' and not p.deletedAt)|first %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Forfait frais d'inscription</label>
                            {% if feePackage %}
                                <div class="flex items-center justify-between rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5">
                                    <span class="text-sm text-gray-900">{{ feePackage.name }} — {{ (feePackage.price / 100)|number_format(2, ',', ' ') }} €</span>
                                    <a href="{{ path('school_season_package_edit', {id: season.id, packageId: feePackage.id}) }}"
                                       class="ml-3 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition shrink-0">Modifier</a>
                                </div>
                                <input type="hidden" name="registrationFeeId" value="{{ feePackage.id }}">
                            {% else %}
                                <div class="rounded-lg border border-dashed border-gray-200 bg-gray-50 px-3 py-2.5 flex items-center justify-between">
                                    <span class="text-sm text-gray-400">Aucun forfait frais d'inscription.</span>
                                    <a href="{{ path('school_season_package_create', {id: season.id, type: 'registration_fee'}) }}"
                                       class="ml-3 inline-flex items-center gap-1 text-xs font-medium text-indigo-600 hover:text-indigo-800 transition shrink-0">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                        Créer
                                    </a>
                                </div>
                                <input type="hidden" name="registrationFeeId" value="">
                            {% endif %}
                        </div>
                        <div>
                            <label for="registrationPaymentCondition" class="block text-sm font-medium text-gray-700 mb-1">Condition de facturation</label>
                            <select id="registrationPaymentCondition" name="registrationPaymentCondition"
                                    class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                <option value="">— Non définie —</option>
                                <option value="every_student" {{ season.registrationPaymentCondition == 'every_student' ? 'selected' : '' }}>Tous les élèves</option>
                                <option value="new_student" {{ season.registrationPaymentCondition == 'new_student' ? 'selected' : '' }}>Nouveaux élèves uniquement</option>
                            </select>
                        </div>
                    </div>

                    {# Description publique #}
                    <div>
                        <label for="registrationPublicDescription" class="block text-sm font-medium text-gray-700 mb-1">Description publique (affichée aux élèves)</label>
                        <textarea id="registrationPublicDescription" name="registrationPublicDescription" rows="4"
                                  class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
                                  placeholder="Informations affichées sur la page d'inscription en ligne…">{{ season.registrationPublicDescription ?? '' }}</textarea>
                    </div>

                    <div class="pt-2 flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer
                        </button>
                    </div>
                </form>
            </div>

            {# Fermetures #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200" x-data="closuresEditor({{ season.closures ? (season.closures|json_encode)|e('html_attr') : '[]' }})">
                <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                    <div>
                        <h2 class="text-base font-semibold text-gray-900">Fermetures</h2>
                        <p class="text-sm text-gray-500 mt-0.5">Vacances scolaires, jours fériés, fermetures exceptionnelles.</p>
                    </div>
                    <button type="button" @click="add()"
                            class="flex items-center gap-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Ajouter
                    </button>
                </div>
                <form method="POST" action="{{ path('school_settings_season', {id: season.id}) }}" @submit="serialize()">
                    <input type="hidden" name="_token" value="{{ csrf_token('season_' ~ season.id) }}">
                    <input type="hidden" name="_section" value="closures">
                    <input type="hidden" name="closures" x-ref="closuresInput">

                    {# Liste des fermetures #}
                    <div class="px-6 py-5 space-y-3">
                        <template x-if="items.length === 0">
                            <div class="py-6 text-center text-sm text-gray-400">
                                Aucune fermeture renseignée. Cliquez sur « Ajouter » pour en créer une.
                            </div>
                        </template>
                        <template x-for="(item, index) in items" :key="item._idx">
                            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 space-y-3">
                                <div>
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Libellé</label>
                                    <input type="text" x-model="item.label" placeholder="Ex : Vacances de Noël"
                                           class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                </div>
                                <div class="flex items-end gap-3">
                                    <div class="flex-1">
                                        <label class="block text-xs font-medium text-gray-500 mb-1">Début</label>
                                        <input type="date" x-model="item.start_at" @change="syncEnd(item)"
                                               class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                    </div>
                                    <div class="flex-1">
                                        <label class="block text-xs font-medium text-gray-500 mb-1">Fin</label>
                                        <input type="date" x-model="item.end_at" :min="item.start_at"
                                               class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                                    </div>
                                    <button type="button" @click="remove(item._idx)"
                                            class="flex items-center justify-center w-9 h-9 rounded-lg bg-red-50 text-red-500 hover:bg-red-100 transition flex-shrink-0">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </div>
                            </div>
                        </template>
                    </div>

                    <div class="px-6 py-4 border-t border-gray-100 flex justify-end">
                        <button type="submit"
                                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
                            Enregistrer les fermetures
                        </button>
                    </div>
                </form>
            </div>

            {# Images #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200"
                 x-data="seasonImages('{{ path('school_settings_season_image_upload', {id: season.id}) }}', '{{ path('school_settings_season_image_delete', {id: season.id}) }}')">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="text-base font-semibold text-gray-900">Images</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Planning et forfaits visuels de la saison.</p>
                </div>
                <div class="px-6 py-5">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

                        {# Planning image #}
                        <div>
                            <p class="text-sm font-medium text-gray-700 mb-2">Image du planning</p>

                            {# Dropzone — affiché sans image #}
                            <label x-show="!images.planning.url"
                                   class="flex flex-col items-center justify-center h-36 rounded-lg border-2 border-dashed border-gray-200 bg-gray-50 hover:border-indigo-300 hover:bg-indigo-50/50 cursor-pointer transition-colors">
                                <div x-show="images.planning.loading" class="flex flex-col items-center gap-2">
                                    <svg class="w-6 h-6 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                                    <span class="text-xs text-indigo-500">Téléversement…</span>
                                </div>
                                <div x-show="!images.planning.loading" class="flex flex-col items-center gap-1.5 text-center px-4">
                                    <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                                    <span class="text-xs text-gray-400">Cliquer pour choisir</span>
                                </div>
                                <input type="file" class="sr-only" accept="image/*"
                                       @change="uploadImage($event, 'planningImage')"
                                       :disabled="images.planning.loading">
                            </label>

                            {# Aperçu — affiché avec image #}
                            <div x-show="images.planning.url" class="relative">
                                <img :src="images.planning.url" alt="Planning"
                                     class="w-full rounded-lg border border-gray-200 object-cover h-36">
                                <div x-show="images.planning.loading"
                                     class="absolute inset-0 flex items-center justify-center rounded-lg bg-white/70">
                                    <svg class="w-6 h-6 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                                </div>
                            </div>

                            {# Erreur #}
                            <p x-show="images.planning.error" x-text="images.planning.error"
                               class="mt-1.5 text-xs text-red-600" style="display:none"></p>

                            {# Actions Remplacer / Supprimer #}
                            <div x-show="images.planning.url" class="mt-2 flex items-center gap-4" style="display:none">
                                <input type="file" x-ref="planningReplace" class="sr-only" accept="image/*"
                                       @change="uploadImage($event, 'planningImage')">
                                <button type="button"
                                        @click="$refs.planningReplace.click()"
                                        :disabled="images.planning.loading"
                                        class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                                    Remplacer
                                </button>
                                <button type="button"
                                        @click="deleteImage('planningImage')"
                                        :disabled="images.planning.loading"
                                        class="inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    Supprimer
                                </button>
                            </div>
                        </div>

                        {# Packages image #}
                        <div>
                            <p class="text-sm font-medium text-gray-700 mb-2">Image des forfaits</p>

                            {# Dropzone — affiché sans image #}
                            <label x-show="!images.packages.url"
                                   class="flex flex-col items-center justify-center h-36 rounded-lg border-2 border-dashed border-gray-200 bg-gray-50 hover:border-indigo-300 hover:bg-indigo-50/50 cursor-pointer transition-colors">
                                <div x-show="images.packages.loading" class="flex flex-col items-center gap-2">
                                    <svg class="w-6 h-6 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                                    <span class="text-xs text-indigo-500">Téléversement…</span>
                                </div>
                                <div x-show="!images.packages.loading" class="flex flex-col items-center gap-1.5 text-center px-4">
                                    <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                                    <span class="text-xs text-gray-400">Cliquer pour choisir</span>
                                </div>
                                <input type="file" class="sr-only" accept="image/*"
                                       @change="uploadImage($event, 'packagesImage')"
                                       :disabled="images.packages.loading">
                            </label>

                            {# Aperçu — affiché avec image #}
                            <div x-show="images.packages.url" class="relative">
                                <img :src="images.packages.url" alt="Forfaits"
                                     class="w-full rounded-lg border border-gray-200 object-cover h-36">
                                <div x-show="images.packages.loading"
                                     class="absolute inset-0 flex items-center justify-center rounded-lg bg-white/70">
                                    <svg class="w-6 h-6 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                                </div>
                            </div>

                            {# Erreur #}
                            <p x-show="images.packages.error" x-text="images.packages.error"
                               class="mt-1.5 text-xs text-red-600" style="display:none"></p>

                            {# Actions Remplacer / Supprimer #}
                            <div x-show="images.packages.url" class="mt-2 flex items-center gap-4" style="display:none">
                                <input type="file" x-ref="packagesReplace" class="sr-only" accept="image/*"
                                       @change="uploadImage($event, 'packagesImage')">
                                <button type="button"
                                        @click="$refs.packagesReplace.click()"
                                        :disabled="images.packages.loading"
                                        class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                                    Remplacer
                                </button>
                                <button type="button"
                                        @click="deleteImage('packagesImage')"
                                        :disabled="images.packages.loading"
                                        class="inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    Supprimer
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

