{% set _mr = app.request.attributes.get('_route') %}
{% set _mt = app.request.attributes.get('type') %}
{% set _sp = (season is defined and season) ? {season: season.id} : {} %}
<div class="border-b border-gray-200 mb-6">
    <nav class="-mb-px flex gap-6">
        <a href="{{ path('school_members_list', {type: 'students'}|merge(_sp)) }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _mr == 'school_members_list' and _mt == 'students' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Élèves
        </a>
        <a href="{{ path('school_members_list', {type: 'teachers'}|merge(_sp)) }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _mr == 'school_members_list' and _mt == 'teachers' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Professeurs
        </a>
        <a href="{{ path('school_members_list', {type: 'admins'}|merge(_sp)) }}"
           class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                  {{ _mr == 'school_members_list' and _mt == 'admins' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
            Admins
        </a>
    </nav>
</div>
