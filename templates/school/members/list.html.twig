{% extends 'layout/school.html.twig' %}

{% block title %}Membres — {{ team.name }}{% endblock %}

{% set _typeLabel %}{% if type == 'students' %}Élèves{% elseif type == 'teachers' %}Professeurs{% elseif type == 'admins' %}Admins{% else %}Membres{% endif %}{% endset %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ team.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
{% if season %}
<a href="{{ path('school_members_list', {type: 'students', season: season.id}) }}" class="hover:text-gray-700 transition">Membres · {{ season.name }}</a>
{% else %}
<a href="{{ path('school_members_list', {type: 'students'}) }}" class="hover:text-gray-700 transition">Membres</a>
{% endif %}
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ _typeLabel }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Membres{% if season %} · {{ season.name }}{% endif %}</h1>
        <a href="{{ path('school_members_create', {type: type != 'all' ? type : 'students'}) }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter
        </a>
    </div>

    {% include 'school/members/_tabs.html.twig' %}

    <div class="mb-4 flex items-center gap-3">
        <div class="relative flex-1 max-w-sm">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
            <input type="search" id="member-search" placeholder="Rechercher…"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 py-2.5 pl-9 pr-4 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
        </div>
        <span class="text-sm text-gray-400">{{ members|length }} membre{{ members|length > 1 ? 's' }}</span>
    </div>

    {% if members is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="text-gray-500 text-sm">Aucun membre dans cette catégorie.</p>
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100" id="members-table">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Naissance</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Genre</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Téléphone</th>
                            {% if season %}
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Inscription</th>
                            {% endif %}
                            <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for member in members %}
                            {% set tps = tpsMap[member.id] ?? null %}
                            <tr class="hover:bg-gray-50 transition member-row">
                                <td class="py-3.5 pl-6 pr-3">
                                    <div class="flex items-center gap-3">
                                        {% if member.profile.avatarPath %}
                                            <img src="{{ member.profile.avatarPath | imagine_filter('profile_avatar') }}" alt="" class="h-8 w-8 rounded-full object-cover shrink-0">
                                        {% else %}
                                            <span class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-sm shrink-0">
                                                {{ member.profile.firstName|first|upper }}
                                            </span>
                                        {% endif %}
                                        <div>
                                            <p class="font-medium text-gray-900 text-sm member-name">{{ member.profile.firstName }} {{ member.profile.lastName }}</p>
                                            {% if member.profile.user %}
                                                <p class="text-xs text-gray-400">{{ member.profile.user.email }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td class="px-3 py-3.5 text-sm text-gray-600 whitespace-nowrap">
                                    {{ member.profile.dob ? member.profile.dob|date('d/m/Y') : '—' }}
                                </td>
                                <td class="px-3 py-3.5 text-sm text-gray-600">
                                    {% if member.profile.gender %}
                                        {% if member.profile.gender.value == 'male' %}♂{% elseif member.profile.gender.value == 'female' %}♀{% else %}—{% endif %}
                                    {% else %}—{% endif %}
                                </td>
                                <td class="px-3 py-3.5 text-sm text-gray-600">
                                    {{ member.profile.phone ?? '—' }}
                                </td>
                                {% if season %}
                                <td class="px-3 py-3.5">
                                    {% if tps %}
                                        {% set rs = tps.registrationStatus.value %}
                                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                            {% if rs == 'registered' %}bg-green-50 text-green-700
                                            {% elseif rs == 'pre_registered' %}bg-amber-50 text-amber-700
                                            {% elseif rs == 'trial_class' %}bg-blue-50 text-blue-700
                                            {% else %}bg-gray-100 text-gray-500{% endif %}">
                                            {% if rs == 'registered' %}Inscrit
                                            {% elseif rs == 'pre_registered' %}Pré-inscrit
                                            {% elseif rs == 'trial_class' %}Cours d'essai
                                            {% else %}Non inscrit{% endif %}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-300 text-xs">—</span>
                                    {% endif %}
                                </td>
                                {% endif %}
                                <td class="py-3.5 pl-3 pr-6 text-right">
                                    <a href="{{ path('school_member_detail', {id: member.id}) }}" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">Voir</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>

<script>
(function() {
    const input = document.getElementById('member-search');
    if (!input) return;
    input.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        document.querySelectorAll('.member-row').forEach(function(row) {
            const name = row.querySelector('.member-name')?.textContent.toLowerCase() ?? '';
            row.style.display = (!q || name.includes(q)) ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
