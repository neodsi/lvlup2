{% extends 'layout/school.html.twig' %}

{% block title %}Membres — {{ team.name }}{% endblock %}

{% block school_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# Header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="{{ path('school_home') }}" class="hover:text-indigo-600 transition">{{ team.name }}</a>
                <span>/</span>
                <span class="text-gray-700 font-medium">
                    {% if type == 'students' %}Élèves
                    {% elseif type == 'teachers' %}Professeurs
                    {% elseif type == 'admins' %}Administrateurs
                    {% else %}Membres{% endif %}
                </span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">
                {% if type == 'students' %}Élèves
                {% elseif type == 'teachers' %}Professeurs
                {% elseif type == 'admins' %}Administrateurs
                {% else %}Membres{% endif %}
            </h1>
        </div>
        <a href="{{ path('school_members_create', {type: type}) }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter
        </a>
    </div>

    {# Type tabs #}
    <div class="border-b border-gray-200 mb-6">
        <nav class="-mb-px flex gap-6">
            {% for t, label in {students: 'Élèves', teachers: 'Professeurs', admins: 'Admins'} %}
                <a href="{{ path('school_members_list', {type: t}) }}"
                   class="pb-3 px-1 text-sm font-medium whitespace-nowrap border-b-2 transition-colors
                       {% if type == t %}border-indigo-600 text-indigo-600{% else %}border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300{% endif %}">
                    {{ label }}
                </a>
            {% endfor %}
        </nav>
    </div>

    {# Search #}
    <div class="mb-4">
        <div class="relative max-w-sm">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
            <input
                type="search"
                id="member-search"
                placeholder="Rechercher un membre..."
                class="block w-full rounded-lg border border-gray-300 bg-white py-2.5 pl-9 pr-4 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
            >
        </div>
    </div>

    {# Table #}
    {% if members is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="text-gray-500 text-sm">Aucun membre dans cette catégorie.</p>
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100" id="members-table">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date de naissance</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Téléphone</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                            <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for member in members %}
                            <tr class="hover:bg-gray-50 transition member-row">
                                <td class="py-4 pl-6 pr-3">
                                    <div class="flex items-center gap-3">
                                        <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-sm shrink-0">
                                            {{ member.profile.firstName|first|upper }}
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900 text-sm member-name">{{ member.profile.firstName }} {{ member.profile.lastName }}</p>
                                            {% if member.profile.user is defined %}
                                                <p class="text-xs text-gray-400">{{ member.profile.user.email }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-600">
                                    {{ member.profile.dob ? member.profile.dob|date('d/m/Y') : '—' }}
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-600">
                                    {{ member.profile.phone ?? '—' }}
                                </td>
                                <td class="px-3 py-4">
                                    {% if member.registrationStatus is defined %}
                                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                            {% if member.registrationStatus.value == 'registered' %}bg-green-50 text-green-700
                                            {% elseif member.registrationStatus.value == 'pre_registered' %}bg-amber-50 text-amber-700
                                            {% else %}bg-gray-100 text-gray-600{% endif %}">
                                            {% if member.registrationStatus.value == 'registered' %}Inscrit
                                            {% elseif member.registrationStatus.value == 'pre_registered' %}Pré-inscrit
                                            {% else %}{{ member.registrationStatus.value }}{% endif %}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-xs">—</span>
                                    {% endif %}
                                </td>
                                <td class="py-4 pl-3 pr-6 text-right">
                                    <a href="#" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">Voir</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>

<script>
(function() {
    const input = document.getElementById('member-search');
    if (!input) return;
    input.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        document.querySelectorAll('.member-row').forEach(function(row) {
            const name = row.querySelector('.member-name')?.textContent.toLowerCase() ?? '';
            row.style.display = (!q || name.includes(q)) ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
