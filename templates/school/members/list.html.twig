{% extends 'layout/school.html.twig' %}

{% block title %}Membres — {{ school.name }}{% endblock %}

{% set _typeLabel %}{% if type == 'students' %}Élèves{% elseif type == 'teachers' %}Professeurs{% elseif type == 'admins' %}Admins{% else %}Membres{% endif %}{% endset %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
{% if season %}
<a href="{{ path('school_members_list', {type: 'students', season: season.id}) }}" class="hover:text-gray-700 transition">Membres · {{ season.name }}</a>
{% else %}
<a href="{{ path('school_members_list', {type: 'students'}) }}" class="hover:text-gray-700 transition">Membres</a>
{% endif %}
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ _typeLabel }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Membres{% if season %} · {{ season.name }}{% endif %}</h1>
        <a href="{{ path('school_members_create', {type: type != 'all' ? type : 'students'}) }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter
        </a>
    </div>

    {% include 'school/members/_tabs.html.twig' %}

    {# ── Filtres ── #}
    <div class="mb-4">
        <form method="get" action="{{ path('school_members_list', {type: type}) }}" id="filter-form">
            {% if season %}<input type="hidden" name="season" value="{{ season.id }}">{% endif %}

            <div class="flex flex-wrap gap-2 items-center">

                {# Recherche #}
                <div class="relative">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
                    <input type="search" name="q" value="{{ filters.q }}" placeholder="Rechercher…" id="filter-search"
                           class="block w-56 rounded-lg border border-gray-300 bg-gray-50 py-2 pl-9 pr-3 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                </div>

                {% if season %}

                {# Cours / activité #}
                {% if allActivities|length > 0 %}
                <select name="activity" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="">Toutes activités</option>
                    {% for act in allActivities %}
                    <option value="{{ act.id }}" {{ filters.activity == act.id ? 'selected' }}>{{ act.name }}</option>
                    {% endfor %}
                </select>
                {% endif %}

                {# Statut inscription #}
                <select name="registration_status" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.registration_status == '' ? 'selected' }}>Tous statuts</option>
                    <option value="accepted"  {{ filters.registration_status == 'accepted'  ? 'selected' }}>Accepté</option>
                    <option value="waiting"   {{ filters.registration_status == 'waiting'   ? 'selected' }}>En attente</option>
                    <option value="refused"   {{ filters.registration_status == 'refused'   ? 'selected' }}>Refusé</option>
                    <option value="suspended" {{ filters.registration_status == 'suspended' ? 'selected' }}>Suspendu</option>
                </select>

                {# Abonnement spécifique #}
                {% if allPackages|length > 0 %}
                <select name="package_id" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.package_id == '' ? 'selected' }}>Tous abonnements</option>
                    {% for pkg in allPackages %}
                    <option value="{{ pkg.id }}" {{ filters.package_id == pkg.id ? 'selected' }}>{{ pkg.name }}</option>
                    {% endfor %}
                </select>
                {% endif %}

                {# Type d'abonnement #}
                <select name="package_type" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.package_type == '' ? 'selected' }}>Tous types</option>
                    <option value="a_la_carte"                {{ filters.package_type == 'a_la_carte'                ? 'selected' }}>À la carte</option>
                    <option value="subscription_one_semester" {{ filters.package_type == 'subscription_one_semester' ? 'selected' }}>Abonnement semestre</option>
                    <option value="subscription_one_year"     {{ filters.package_type == 'subscription_one_year'     ? 'selected' }}>Abonnement annuel</option>
                    <option value="trial_class"               {{ filters.package_type == 'trial_class'               ? 'selected' }}>Cours d'essai</option>
                </select>

                {# Statut paiement #}
                <select name="payment_status" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.payment_status == '' ? 'selected' }}>Tous paiements</option>
                    <option value="paid"           {{ filters.payment_status == 'paid'           ? 'selected' }}>Payé</option>
                    <option value="partially_paid" {{ filters.payment_status == 'partially_paid' ? 'selected' }}>Partiel</option>
                    <option value="unpaid"         {{ filters.payment_status == 'unpaid'         ? 'selected' }}>Impayé</option>
                    <option value="overpaid"       {{ filters.payment_status == 'overpaid'       ? 'selected' }}>Surpayé</option>
                </select>

                {% endif %}{# end if season #}

                {# Compte #}
                <select name="has_user" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.has_user == '' ? 'selected' }}>Tous comptes</option>
                    <option value="yes" {{ filters.has_user == 'yes' ? 'selected' }}>Compte créé</option>
                    <option value="no"  {{ filters.has_user == 'no'  ? 'selected' }}>Sans compte</option>
                </select>

                {# Blessure #}
                <select name="has_injury" class="rounded-lg border border-gray-300 bg-gray-50 py-2 pl-3 pr-8 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    <option value="" {{ filters.has_injury == '' ? 'selected' }}>Toutes blessures</option>
                    <option value="yes" {{ filters.has_injury == 'yes' ? 'selected' }}>Avec avertissement</option>
                    <option value="no"  {{ filters.has_injury == 'no'  ? 'selected' }}>Sans avertissement</option>
                </select>

                {# Compteur + reset #}
                <span class="text-sm text-gray-400 ml-1">{{ members|length }} membre{{ members|length > 1 ? 's' }}</span>

                {% if activeFilterCount > 0 %}
                <a href="{{ path('school_members_list', {type: type, season: season ? season.id : null}) }}"
                   class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-700 transition border border-red-200 rounded-full px-2 py-1">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    Réinitialiser ({{ activeFilterCount }})
                </a>
                {% endif %}
            </div>
        </form>
    </div>

    {# ── Table ── #}
    {% if members is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="text-gray-500 text-sm">Aucun membre{% if activeFilterCount > 0 %} correspondant aux filtres{% endif %}.</p>
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100 text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-5 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Nom</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Contact</th>
                            {% if season %}
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Inscription</th>
                            {% endif %}
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Adhésion</th>
                            {% if season %}
                            {% if allActivities|length > 0 %}
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Activités</th>
                            {% endif %}
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Abonnements</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Total dû</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Restant</th>
                            <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Payé</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Statut</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Date paiement</th>
                            {% endif %}
                            <th class="py-3 pl-3 pr-5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for member in members %}
                            {% set fin      = financialMap[member.id] ?? null %}
                            {% set pkgs     = packagesMap[member.id] ?? 0 %}
                            {% set rs       = member.status ? member.status.value : null %}
                            {% set actIds   = [] %}
                            {% set lastPaid = lastPaymentDateMap[member.id] ?? null %}

                            <tr class="hover:bg-gray-50 transition">

                                {# Nom + naissance #}
                                <td class="py-3 pl-5 pr-3 whitespace-nowrap">
                                    <div class="flex items-center gap-2.5">
                                        {% if member.profile.avatarPath %}
                                            <img src="{{ member.profile.avatarPath | imagine_filter('profile_avatar') }}" alt="" class="h-8 w-8 rounded-full object-cover shrink-0">
                                        {% else %}
                                            <span class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-xs shrink-0">
                                                {{ member.profile.firstName|first|upper }}
                                            </span>
                                        {% endif %}
                                        <div>
                                            <p class="font-medium text-gray-900">{{ member.profile.firstName }} {{ member.profile.lastName }}</p>
                                            {% if member.profile.dob %}
                                                <p class="text-xs text-gray-400">{{ member.profile.dob|date('d/m/Y') }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>

                                {# Contact #}
                                <td class="px-3 py-3 whitespace-nowrap">
                                    <div class="flex flex-col gap-0.5">
                                        {% if member.profile.phone %}
                                            <button type="button" onclick="navigator.clipboard.writeText('{{ member.profile.phone }}')" title="Copier {{ member.profile.phone }}"
                                                    class="flex items-center gap-1 text-xs text-gray-600 hover:text-indigo-600 transition w-fit">
                                                <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                                {{ member.profile.phone }}
                                            </button>
                                        {% endif %}
                                        {% if member.profile.user %}
                                            <button type="button" onclick="navigator.clipboard.writeText('{{ member.profile.user.email }}')" title="Copier {{ member.profile.user.email }}"
                                                    class="flex items-center gap-1 text-xs text-gray-500 hover:text-indigo-600 transition w-fit">
                                                <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                                {{ member.profile.user.email }}
                                            </button>
                                        {% endif %}
                                        {% if not member.profile.phone and not member.profile.user %}—{% endif %}
                                    </div>
                                </td>

                                {% if season %}

                                {# Statut inscription #}
                                <td class="px-3 py-3 whitespace-nowrap">
                                    {% if rs %}
                                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                            {% if rs == 'accepted' %}bg-green-50 text-green-700
                                            {% elseif rs == 'waiting' %}bg-amber-50 text-amber-700
                                            {% elseif rs == 'refused' %}bg-red-50 text-red-700
                                            {% elseif rs == 'suspended' %}bg-gray-100 text-gray-500
                                            {% else %}bg-gray-100 text-gray-400{% endif %}">
                                            {% if rs == 'accepted' %}Accepté
                                            {% elseif rs == 'waiting' %}En attente
                                            {% elseif rs == 'refused' %}Refusé
                                            {% elseif rs == 'suspended' %}Suspendu
                                            {% else %}{{ rs }}{% endif %}
                                        </span>
                                    {% else %}<span class="text-gray-300 text-xs">—</span>{% endif %}
                                </td>

                                {% endif %}

                                {# Date d'adhésion #}
                                <td class="px-3 py-3 whitespace-nowrap text-xs text-gray-500">
                                    {{ member.createdAt|date('d/m/Y') }}
                                </td>

                                {% if season %}

                                {# Activités #}
                                {% if allActivities|length > 0 %}
                                <td class="px-3 py-3 whitespace-nowrap">
                                    {% if actIds|length > 0 %}
                                        <div class="relative group inline-flex">
                                            <span class="inline-flex items-center rounded-full bg-indigo-50 text-indigo-700 text-xs font-medium px-2 py-0.5 cursor-default">
                                                {{ actIds|length }}
                                            </span>
                                        </div>
                                    {% else %}<span class="text-gray-300 text-xs">—</span>{% endif %}
                                </td>
                                {% endif %}

                                {# Abonnements #}
                                <td class="px-3 py-3 whitespace-nowrap">
                                    {% if pkgs > 0 %}
                                        <span class="inline-flex items-center rounded-full bg-purple-50 text-purple-700 text-xs font-medium px-2 py-0.5">
                                            {{ pkgs }}
                                        </span>
                                    {% else %}<span class="text-gray-300 text-xs">—</span>{% endif %}
                                </td>

                                {# Total dû #}
                                <td class="px-3 py-3 text-right whitespace-nowrap text-gray-700">
                                    {% if fin %}{{ (fin.total / 100)|number_format(2, ',', ' ') }} €{% else %}<span class="text-gray-300">—</span>{% endif %}
                                </td>

                                {# Restant #}
                                <td class="px-3 py-3 text-right whitespace-nowrap {% if fin and fin.left > 0 %}text-red-600 font-medium{% else %}text-gray-500{% endif %}">
                                    {% if fin %}{{ (fin.left / 100)|number_format(2, ',', ' ') }} €{% else %}<span class="text-gray-300">—</span>{% endif %}
                                </td>

                                {# Payé #}
                                <td class="px-3 py-3 text-right whitespace-nowrap text-green-700">
                                    {% if fin %}{{ (fin.paid / 100)|number_format(2, ',', ' ') }} €{% else %}<span class="text-gray-300">—</span>{% endif %}
                                </td>

                                {# Statut paiement #}
                                <td class="px-3 py-3 whitespace-nowrap">
                                    {% if fin and fin.status %}
                                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                            {% if fin.status == 'paid' %}bg-green-50 text-green-700
                                            {% elseif fin.status == 'partially_paid' %}bg-amber-50 text-amber-700
                                            {% elseif fin.status == 'unpaid' %}bg-red-50 text-red-700
                                            {% else %}bg-blue-50 text-blue-700{% endif %}">
                                            {% if fin.status == 'paid' %}Payé
                                            {% elseif fin.status == 'partially_paid' %}Partiel
                                            {% elseif fin.status == 'unpaid' %}Impayé
                                            {% else %}Surpayé{% endif %}
                                        </span>
                                    {% else %}<span class="text-gray-300 text-xs">—</span>{% endif %}
                                </td>

                                {# Date paiement #}
                                <td class="px-3 py-3 whitespace-nowrap text-xs text-gray-600">
                                    {{ lastPaid ? lastPaid|date('d/m/Y') : '—' }}
                                </td>

                                {% endif %}{# end if season #}

                                {# Actions #}
                                <td class="py-3 pl-3 pr-5 text-right whitespace-nowrap">
                                    <a href="{{ path('school_member_detail', {id: member.id}) }}" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">Voir</a>
                                </td>

                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>

<script>
(function () {
    document.querySelectorAll('#filter-form select').forEach(function (sel) {
        sel.addEventListener('change', function () {
            document.getElementById('filter-form').submit();
        });
    });

    var searchInput = document.getElementById('filter-search');
    var searchTimer;
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function () {
                document.getElementById('filter-form').submit();
            }, 500);
        });
    }
})();
</script>

{% endblock %}
