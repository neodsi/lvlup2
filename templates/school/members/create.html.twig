{% extends 'layout/school.html.twig' %}

{% set typeLabel = type == 'students' ? 'élève' : (type == 'teachers' ? 'professeur' : 'administrateur') %}
{% block title %}Ajouter un {{ typeLabel }} — {{ school.name }}{% endblock %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_members_list', {type: type}) }}" class="hover:text-gray-700 transition">
    {% if type == 'students' %}Élèves{% elseif type == 'teachers' %}Professeurs{% else %}Admins{% endif %}
</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Ajouter</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Ajouter un {{ typeLabel }}</h1>

    {% include 'components/_flash.html.twig' %}

    <form method="POST" action="{{ path('school_members_create', {type: type}) }}" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('create_member') }}">

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Coordonnées</h2>
                <p class="text-xs text-gray-400 mt-0.5">
                    La personne recevra un e-mail pour
                    {% if type == 'students' %}créer son compte et compléter son profil.{% else %}accéder à son espace.{% endif %}
                    Si un compte existe déjà pour cet e-mail, il sera simplement rattaché à l'école.
                </p>
            </div>
            <div class="px-6 py-5">
                <label for="member_email" class="block text-xs text-gray-500 mb-1">
                    Adresse e-mail <span class="text-red-500">*</span>
                </label>
                <input id="member_email" type="email" name="email" required
                       value="{{ email ?? '' }}"
                       autocomplete="off"
                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Note interne</h2>
                <p class="text-xs text-gray-400 mt-0.5">Visible uniquement par les administrateurs.</p>
            </div>
            <div class="px-6 py-5">
                <textarea name="note" rows="3" maxlength="500"
                          placeholder="Note interne…"
                          class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">{{ note ?? '' }}</textarea>
            </div>
        </div>

        <div class="flex items-center justify-between">
            <a href="{{ path('school_members_list', {type: type}) }}"
               class="text-sm text-gray-500 hover:text-gray-700 transition">Annuler</a>
            <button type="submit"
                    class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                Ajouter
            </button>
        </div>
    </form>
</div>
{% endblock %}
