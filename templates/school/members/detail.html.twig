{% extends 'layout/school.html.twig' %}

{% block title %}{{ member.profile.firstName }} {{ member.profile.lastName }} — {{ school.name }}{% endblock %}

{% set _listType  = member.role.value == 'teacher' ? 'teachers' : (member.role.value == 'school' ? 'admins' : 'students') %}
{% set _listLabel = member.role.value == 'teacher' ? 'Professeurs' : (member.role.value == 'school' ? 'Admins' : 'Élèves') %}
{% set _roleLabel = member.role.value == 'student' ? 'Élève' : (member.role.value == 'teacher' ? 'Professeur' : 'Administrateur') %}

{% block breadcrumb %}
<a href="{{ path('school_home') }}" class="hover:text-gray-700 transition">{{ school.name }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('school_members_list', {type: _listType}) }}" class="hover:text-gray-700 transition">{{ _listLabel }}</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ member.profile.firstName }} {{ member.profile.lastName }}</span>
{% endblock %}

{% block school_content %}
<div class="py-8">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">{{ member.profile.firstName }} {{ member.profile.lastName }}</h1>

    {# email is in the form (used on create) but not editable here #}
    {{ form_start(form, {'action': path('school_member_edit', {'id': member.id})}) }}
    {% do form.email.setRendered() %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left: avatar + badges #}
        <div class="lg:col-span-1 space-y-4">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col items-center text-center">
                {% if member.profile.avatarPath %}
                    <img src="{{ member.profile.avatarPath | imagine_filter('profile_avatar') }}" alt="" class="h-20 w-20 rounded-full object-cover border-2 border-gray-200 mb-3">
                {% else %}
                    <span class="h-20 w-20 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-2xl mb-3">
                        {{ member.profile.firstName|first|upper }}
                    </span>
                {% endif %}

                <p class="font-semibold text-gray-900 text-lg">{{ member.profile.firstName }} {{ member.profile.lastName }}</p>
                {% if member.profile.user %}
                    <p class="text-xs text-gray-400 mt-0.5">{{ member.profile.user.email }}</p>
                {% endif %}

                <span class="mt-3 inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold
                    {% if member.role.value == 'student' %}bg-blue-50 text-blue-700
                    {% elseif member.role.value == 'teacher' %}bg-purple-50 text-purple-700
                    {% elseif member.role.value == 'school' %}bg-amber-50 text-amber-700
                    {% else %}bg-indigo-50 text-indigo-700{% endif %}">
                    {{ _roleLabel | trim }}
                </span>

                <span class="mt-2 inline-flex items-center rounded-full px-3 py-1 text-xs font-medium
                    {% if member.status.value == 'accepted' %}bg-green-50 text-green-700
                    {% elseif member.status.value == 'waiting' %}bg-amber-50 text-amber-700
                    {% elseif member.status.value == 'refused' %}bg-red-50 text-red-700
                    {% else %}bg-gray-100 text-gray-500{% endif %}">
                    {% if member.status.value == 'accepted' %}Actif
                    {% elseif member.status.value == 'waiting' %}En attente
                    {% elseif member.status.value == 'refused' %}Refusé
                    {% else %}{{ member.status.value }}{% endif %}
                </span>

                <p class="mt-4 text-xs text-gray-400">Membre depuis le {{ member.createdAt|date('d/m/Y') }}</p>
            </div>

            {# Note interne #}
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="px-5 py-4 border-b border-gray-100">
                    <p class="text-sm font-semibold text-gray-700">Note interne</p>
                    <p class="text-xs text-gray-400">Visible admins uniquement</p>
                </div>
                <div class="px-5 py-4">
                    {{ form_widget(form.note) }}
                    <div class="mt-1 text-xs text-red-500">{{ form_errors(form.note) }}</div>
                </div>
            </div>
        </div>

        {# Right: info + saison #}
        <div class="lg:col-span-2 space-y-4">

            {# Informations personnelles #}
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h2 class="text-sm font-semibold text-gray-900">Informations personnelles</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <p class="text-xs text-gray-400 mb-4">Les champs marqués <span class="text-red-500 font-medium">*</span> sont obligatoires.</p>
                    {% if member.profile.user %}
                    <div>
                        <p class="block text-xs text-gray-500 mb-1">E-mail</p>
                        <p class="block w-full rounded-lg border border-gray-200 bg-gray-100 px-3 py-2.5 text-sm text-gray-500 select-all">{{ member.profile.user.email }}</p>
                    </div>
                    {% endif %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="{{ form.firstName.vars.id }}" class="block text-xs text-gray-500 mb-1">Prénom <span class="text-red-500">*</span></label>
                            {{ form_widget(form.firstName) }}
                            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.firstName) }}</div>
                        </div>
                        <div>
                            <label for="{{ form.lastName.vars.id }}" class="block text-xs text-gray-500 mb-1">Nom <span class="text-red-500">*</span></label>
                            {{ form_widget(form.lastName) }}
                            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.lastName) }}</div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div>
                            {{ form_label(form.dob) }}
                            {{ form_widget(form.dob) }}
                            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.dob) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.gender) }}
                            {{ form_widget(form.gender) }}
                            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.gender) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.phone) }}
                            {{ form_widget(form.phone) }}
                            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.phone) }}</div>
                        </div>
                    </div>
                    <div>
                        {{ form_label(form.addressText) }}
                        {{ form_widget(form.addressText) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.addressText) }}</div>
                    </div>
                </div>
            </div>

            {# Tailles — élèves uniquement #}
            {% if member.role.value == 'student' %}
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
                    <h2 class="text-sm font-semibold text-gray-900">Tailles</h2>
                    <span class="text-xs text-gray-400">galas &amp; certains cours</span>
                </div>
                <div class="px-6 py-4 grid grid-cols-3 gap-4 text-sm">
                    <div>
                        <p class="text-xs text-gray-500 mb-0.5">Haut</p>
                        <p class="font-medium text-gray-900">{{ member.profile.sizeTop ?: '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 mb-0.5">Bas</p>
                        <p class="font-medium text-gray-900">{{ member.profile.sizeBottom ?: '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 mb-0.5">Pointure</p>
                        <p class="font-medium text-gray-900">{{ member.profile.sizeShoe ?: '—' }}</p>
                    </div>
                </div>
            </div>
            {% endif %}

            {# Saison actuelle #}
            {% if season and member.role.value == 'student' %}
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h2 class="text-sm font-semibold text-gray-900">Saison {{ season.name }}</h2>
                </div>
                <div class="px-6 py-5 space-y-5">

                    <div class="sm:w-1/2">
                        {{ form_label(form.registrationStatus) }}
                        {{ form_widget(form.registrationStatus) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.registrationStatus) }}</div>
                    </div>

                    {# Consentements #}
                    <div>
                        <p class="text-xs font-medium text-gray-500 mb-2">Consentements signés</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            {% for choice in form.accepted %}
                            <label for="{{ choice.vars.id }}" class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 bg-white hover:bg-gray-50 cursor-pointer select-none transition-colors [&:has(input:checked)]:border-indigo-300 [&:has(input:checked)]:bg-indigo-50">
                                {{ form_widget(choice, {attr: {class: 'peer sr-only'}}) }}
                                <span class="h-4 w-4 shrink-0 rounded border-2 border-gray-300 bg-white flex items-center justify-center transition-colors peer-checked:bg-indigo-600 peer-checked:border-indigo-600">
                                    <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                </span>
                                <span class="text-sm text-gray-700 leading-tight">{{ choice.vars.label }}</span>
                            </label>
                            {% endfor %}
                        </div>
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.accepted) }}</div>
                    </div>

                    {# Contact d'urgence #}
                    <div>
                        <p class="text-xs font-medium text-gray-500 mb-2">Contact d'urgence</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                {{ form_label(form.emergencyName) }}
                                {{ form_widget(form.emergencyName) }}
                                <div class="mt-1 text-xs text-red-500">{{ form_errors(form.emergencyName) }}</div>
                            </div>
                            <div>
                                {{ form_label(form.emergencyRelationship) }}
                                {{ form_widget(form.emergencyRelationship) }}
                                <div class="mt-1 text-xs text-red-500">{{ form_errors(form.emergencyRelationship) }}</div>
                            </div>
                            <div>
                                {{ form_label(form.emergencyEmail) }}
                                {{ form_widget(form.emergencyEmail) }}
                                <div class="mt-1 text-xs text-red-500">{{ form_errors(form.emergencyEmail) }}</div>
                            </div>
                            <div>
                                {{ form_label(form.emergencyPhone) }}
                                {{ form_widget(form.emergencyPhone) }}
                                <div class="mt-1 text-xs text-red-500">{{ form_errors(form.emergencyPhone) }}</div>
                            </div>
                        </div>
                    </div>

                    {# Avertissement blessure #}
                    <div>
                        {{ form_label(form.injuryWarning) }}
                        {{ form_widget(form.injuryWarning) }}
                        <div class="mt-1 text-xs text-red-500">{{ form_errors(form.injuryWarning) }}</div>
                    </div>

                </div>
            </div>
            {% endif %}

            <div class="flex items-center justify-between">
                <button type="button" onclick="document.getElementById('modal-delete-member').classList.remove('hidden')"
                        class="inline-flex items-center gap-2 text-sm font-medium text-red-600 hover:text-red-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Supprimer ce membre
                </button>
                <button type="submit"
                        class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                    Enregistrer
                </button>
            </div>

        </div>
    </div>
    {{ form_end(form) }}

</div>

{# Modal suppression #}
<div id="modal-delete-member" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="document.getElementById('modal-delete-member').classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
        <div class="flex items-start gap-4">
            <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-full bg-red-100">
                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </div>
            <div class="flex-1">
                <h3 class="text-base font-semibold text-gray-900">Supprimer ce membre ?</h3>
                <p class="mt-1 text-sm text-gray-500">
                    <strong>{{ member.profile.firstName }} {{ member.profile.lastName }}</strong> sera retiré(e) de l'école. Cette action est irréversible.
                </p>
            </div>
        </div>
        <div class="mt-6 flex gap-3 justify-end">
            <button type="button" onclick="document.getElementById('modal-delete-member').classList.add('hidden')"
                    class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                Annuler
            </button>
            <form method="post" action="{{ path('school_member_delete', {id: member.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_member_' ~ member.id) }}">
                <button type="submit"
                        class="px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors">
                    Supprimer définitivement
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
