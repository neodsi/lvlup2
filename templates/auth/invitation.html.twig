{% extends 'layout/auth.html.twig' %}

{% block title %}Invitation — LVL UP{% endblock %}

{% block heading %}
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-slate-900">
        Vous avez une invitation
    </h2>
{% endblock %}

{% block content %}
    {# Invitation card #}
    <div class="mb-6 rounded-lg bg-indigo-50 border border-indigo-200 p-5 text-center">
        {% if school %}
            <p class="text-sm text-slate-600 mb-1">Vous avez été invité(e) à rejoindre</p>
            <p class="text-xl font-bold text-slate-900">{{ school.name }}</p>
        {% endif %}
        {% if invite.role is defined %}
            <span class="mt-2 inline-block rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold px-3 py-1">
                {% if invite.role.value == 'admin' %}
                    Administrateur
                {% elseif invite.role.value == 'teacher' %}
                    Professeur
                {% elseif invite.role.value == 'student' %}
                    Élève
                {% else %}
                    {{ invite.role.value }}
                {% endif %}
            </span>
        {% endif %}
        {% if invite.expiresAt %}
            <p class="mt-3 text-xs text-slate-500">
                Expire le {{ invite.expiresAt|date('d/m/Y') }}
            </p>
        {% endif %}
    </div>

    {% if app.user %}
        {# User is logged in: show accept form #}
        <form method="post" action="{{ path('app_invitation', {token: invite.token}) }}" class="space-y-4">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('invitation_accept_' ~ invite.token) }}">

            <p class="text-sm text-slate-600 text-center">
                Connecté en tant que <strong>{{ app.user.email }}</strong>
            </p>

            <button
                type="submit"
                class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 active:bg-indigo-700 transition"
            >
                Accepter l'invitation
            </button>
        </form>
    {% else %}
        {# User is not logged in: show login / signup options #}
        <p class="text-sm text-slate-600 text-center mb-5">
            Pour accepter cette invitation, connectez-vous ou créez un compte.
        </p>

        <div class="space-y-3">
            <a
                href="{{ path('app_login') }}?_target_path={{ app.request.uri | url_encode }}"
                class="flex w-full justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 transition"
            >
                Se connecter
            </a>

            <a
                href="{{ path('app_signup') }}?_target_path={{ app.request.uri | url_encode }}"
                class="flex w-full justify-center rounded-lg border border-indigo-600 bg-white px-4 py-2.5 text-sm font-semibold text-indigo-600 shadow-sm hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 transition"
            >
                Créer un compte
            </a>
        </div>
    {% endif %}
{% endblock %}
