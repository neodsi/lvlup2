{% extends 'layout/auth.html.twig' %}

{% block title %}Mot de passe oublié — LvlUp{% endblock %}

{% block heading %}
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-slate-900">
        Réinitialiser le mot de passe
    </h2>
    <p class="mt-2 text-center text-sm text-slate-600">
        Saisissez votre e-mail, nous vous enverrons un lien de réinitialisation.
    </p>
{% endblock %}

{% block content %}
    <form method="post" action="{{ path('app_reset_password') }}" class="space-y-5">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

        <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
                Adresse e-mail
            </label>
            <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                autofocus
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition"
                placeholder="vous@exemple.com"
            >
        </div>

        <button
            type="submit"
            class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 active:bg-indigo-700 transition"
        >
            Envoyer le lien
        </button>
    </form>

    <p class="mt-6 text-center text-sm text-slate-500">
        <a href="{{ path('app_login') }}" class="font-semibold text-indigo-600 hover:text-indigo-500 transition">
            Retour à la connexion
        </a>
    </p>
{% endblock %}
