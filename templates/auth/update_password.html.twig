{% extends 'layout/auth.html.twig' %}

{% block title %}Nouveau mot de passe — LVL UP{% endblock %}

{% block heading %}
<div class="mb-8 text-center">
    <h1 class="text-2xl font-bold text-gray-900">Nouveau mot de passe</h1>
    <p class="mt-1.5 text-sm text-gray-500">Choisissez un mot de passe sécurisé pour votre compte.</p>
</div>
{% endblock %}

{% block content %}
{{ form_start(form, { attr: { class: 'space-y-4' } }) }}
    {{ form_widget(form.token) }}

    <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Nouveau mot de passe</label>
        <div class="relative">
            {{ form_widget(form.password, { attr: {
                id: 'new_password',
                class: 'block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 pr-10 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition',
                placeholder: '••••••••'
            }}) }}
            <button type="button" onclick="togglePwd('new_password')"
                    class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 transition">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
            </button>
        </div>
        <div class="mt-1 text-xs text-red-600">{{ form_errors(form.password) }}</div>
    </div>

    <button type="submit"
            class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 transition">
        Enregistrer le mot de passe
    </button>

{{ form_end(form) }}
{% endblock %}

{% block scripts %}
<script>
function togglePwd(id) {
    const el = document.getElementById(id);
    el.type = el.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}
