{% extends 'layout/auth.html.twig' %}

{% block title %}Nouveau mot de passe — LVL UP{% endblock %}

{% block heading %}
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-slate-900">
        Choisir un nouveau mot de passe
    </h2>
{% endblock %}

{% block content %}
    {{ form_start(form) }}
        {{ form_widget(form.token) }}

        <div>
            {{ form_label(form.password) }}
            {{ form_widget(form.password) }}
            <div class="mt-1 text-xs text-red-500">{{ form_errors(form.password) }}</div>
        </div>

        <button
            type="submit"
            class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 active:bg-indigo-700 transition"
        >
            Enregistrer le mot de passe
        </button>
    {{ form_end(form) }}
{% endblock %}
