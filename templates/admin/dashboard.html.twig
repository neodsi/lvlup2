{% extends 'layout/admin.html.twig' %}

{% block title %}Administration — LvlUp{% endblock %}

{% block admin_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Administration</h1>
        <p class="text-sm text-gray-500 mt-0.5">Vue d'ensemble de la plateforme</p>
    </div>

    {# Stats cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">Écoles totales</p>
                <div class="h-9 w-9 rounded-lg bg-indigo-50 flex items-center justify-center">
                    <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
            </div>
            <p class="mt-3 text-4xl font-bold text-gray-900">{{ totalTeams }}</p>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">Utilisateurs totaux</p>
                <div class="h-9 w-9 rounded-lg bg-green-50 flex items-center justify-center">
                    <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
            </div>
            <p class="mt-3 text-4xl font-bold text-gray-900">{{ totalUsers }}</p>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-500">Écoles en attente</p>
                <div class="h-9 w-9 rounded-lg bg-amber-50 flex items-center justify-center">
                    <svg class="h-5 w-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <p class="mt-3 text-4xl font-bold text-gray-900">
                {% set waitingCount = 0 %}
                {% for row in teamsByStatus %}
                    {% if row.status is defined and row.status.value == 'waiting' %}
                        {% set waitingCount = row.cnt %}
                    {% endif %}
                {% endfor %}
                {{ waitingCount }}
            </p>
        </div>

    </div>

    {# Status breakdown #}
    {% if teamsByStatus|length > 0 %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-8">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">Écoles par statut</h2>
            </div>
            <div class="divide-y divide-gray-100">
                {% for row in teamsByStatus %}
                    <div class="flex items-center justify-between px-6 py-3 text-sm">
                        <div class="flex items-center gap-2">
                            {% set s = row.status.value ?? row.status ?? 'unknown' %}
                            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                {% if s == 'active' %}bg-green-50 text-green-700
                                {% elseif s == 'waiting' %}bg-amber-50 text-amber-700
                                {% elseif s == 'refused' %}bg-red-50 text-red-700
                                {% else %}bg-gray-100 text-gray-600{% endif %}">
                                {% if s == 'active' %}Actif
                                {% elseif s == 'waiting' %}En attente
                                {% elseif s == 'refused' %}Refusé
                                {% else %}{{ s }}{% endif %}
                            </span>
                        </div>
                        <span class="font-semibold text-gray-900">{{ row.cnt }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Quick links #}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="{{ path('app_admin_schools') }}" class="group flex items-center gap-4 bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:border-indigo-300 hover:shadow-md transition">
            <div class="h-10 w-10 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-sm text-gray-900 group-hover:text-indigo-600 transition">Gérer les écoles</p>
                <p class="text-xs text-gray-400">Approuver, refuser, consulter</p>
            </div>
            <svg class="h-4 w-4 text-gray-300 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a href="{{ path('app_admin_users') }}" class="group flex items-center gap-4 bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:border-indigo-300 hover:shadow-md transition">
            <div class="h-10 w-10 rounded-lg bg-green-50 flex items-center justify-center shrink-0">
                <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-sm text-gray-900 group-hover:text-indigo-600 transition">Gérer les utilisateurs</p>
                <p class="text-xs text-gray-400">Rechercher, usurper une identité</p>
            </div>
            <svg class="h-4 w-4 text-gray-300 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
    </div>

</div>
{% endblock %}
