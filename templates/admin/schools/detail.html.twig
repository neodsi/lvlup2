{% extends 'layout/admin.html.twig' %}

{% block title %}{{ school.name }} — Administration{% endblock %}

{% block breadcrumb %}
<a href="{{ path('app_admin') }}" class="hover:text-gray-700 transition">Tableau de bord</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<a href="{{ path('app_admin_schools') }}" class="hover:text-gray-700 transition">Écoles</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">{{ school.name }}</span>
{% endblock %}

{% block admin_content %}
<div class="py-8">

    {# School header card #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 px-6 py-5 border-b border-gray-100">
            <div class="flex items-center gap-4">
                <div class="h-14 w-14 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-2xl shrink-0">
                    {{ school.name|first|upper }}
                </div>
                <div>
                    <h1 class="text-xl font-bold text-gray-900">{{ school.name }}</h1>
                    <p class="text-xs text-gray-400 font-mono">{{ school.id }}</p>
                </div>
            </div>
            {% set s = school.status.value ?? school.status ?? 'unknown' %}
            <span class="self-start sm:self-auto inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold
                {% if s == 'accepted' %}bg-green-50 text-green-700
                {% elseif s == 'waiting' %}bg-amber-50 text-amber-700
                {% elseif s == 'refused' %}bg-red-50 text-red-700
                {% elseif s == 'disabled' %}bg-gray-100 text-gray-500
                {% else %}bg-gray-100 text-gray-600{% endif %}">
                {% if s == 'accepted' %}Actif
                {% elseif s == 'waiting' %}En attente
                {% elseif s == 'refused' %}Refusé
                {% elseif s == 'disabled' %}Désactivé
                {% else %}{{ s }}{% endif %}
            </span>
        </div>

        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 px-6 py-5 text-sm">
            <div>
                <dt class="text-gray-500">Type</dt>
                <dd class="mt-1 font-medium text-gray-900">
                    {% set t = school.type ?? '' %}
                    {% if t == 'school' %}École
                    {% elseif t == 'independent_teacher' %}Prof. indépendant
                    {% elseif t == 'association' %}Association
                    {% elseif t != '' %}{{ t }}
                    {% else %}—{% endif %}
                </dd>
            </div>
            <div>
                <dt class="text-gray-500">Créée le</dt>
                <dd class="mt-1 font-medium text-gray-900">{{ school.createdAt|date('d/m/Y') }}</dd>
            </div>
            {% if school.invoicePrefix %}
                <div>
                    <dt class="text-gray-500">Préfixe facture</dt>
                    <dd class="mt-1 font-medium text-gray-900 font-mono">{{ school.invoicePrefix }}</dd>
                </div>
            {% endif %}
            {% if school.invoiceAddress %}
                <div class="col-span-2 sm:col-span-3">
                    <dt class="text-gray-500">Adresse de facturation</dt>
                    <dd class="mt-1 text-gray-900 whitespace-pre-line">{{ school.invoiceAddress }}</dd>
                </div>
            {% endif %}
        </dl>
    </div>

    {# Members list from school_profile_seasons #}
    {% if members is not empty %}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Membres <span class="text-sm font-normal text-gray-400">({{ members|length }})</span></h2>
        </div>
        <div class="divide-y divide-gray-50">
            {% for m in members %}
                {% set p = m.profile %}
                <div class="flex items-center justify-between gap-4 px-6 py-3">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="h-9 w-9 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-sm shrink-0">
                            {{ p and p.user ? p.user.email|first|upper : '?' }}
                        </span>
                        <div class="min-w-0">
                            {% if p %}
                                <p class="text-sm font-medium text-gray-900 truncate">{{ p.firstName }} {{ p.lastName }}</p>
                                {% if p.user %}<p class="text-xs text-gray-400 truncate">{{ p.user.email }}</p>{% endif %}
                            {% else %}
                                <p class="text-sm text-gray-400 italic">Profil supprimé</p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center gap-2 shrink-0 flex-wrap">
                        {% if m.isOwner %}
                            <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-700 border border-blue-200">Owner</span>
                        {% endif %}
                        {% for role in m.roles %}
                            {% if not (m.isOwner and role == 'school') %}
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium border
                                    {% if role == 'school' %}bg-blue-50 text-blue-700 border-blue-200
                                    {% elseif role == 'teacher' %}bg-purple-50 text-purple-700 border-purple-200
                                    {% else %}bg-green-50 text-green-700 border-green-200{% endif %}">
                                    {% if role == 'school' %}Admin
                                    {% elseif role == 'teacher' %}Professeur
                                    {% else %}Élève{% endif %}
                                </span>
                            {% endif %}
                        {% endfor %}
                        {% if m.seasonName %}
                            <span class="text-xs text-gray-400">{{ m.seasonName }}</span>
                        {% endif %}
                        {% if p and p.user and is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_impersonate', {userId: p.user.id}) }}"
                               class="inline-flex items-center gap-1 text-xs font-medium text-amber-600 hover:text-amber-800 border border-amber-200 hover:bg-amber-50 px-2 py-1 rounded-lg transition">
                                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                Impersonner
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Status change — one form per status, no form class #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">Statut</h2>
        </div>
        <div class="px-6 py-5 flex flex-wrap gap-3">
            {% set statusLabels = {accepted: 'Activer', waiting: 'Mettre en attente', refused: 'Refuser', disabled: 'Désactiver'} %}
            {% set current = school.status.value ?? '' %}
            {% for sv, label in statusLabels %}
                {% if sv == current %}
                    <span class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-medium cursor-default
                        {% if sv == 'accepted' %}bg-green-600 text-white border-green-600
                        {% elseif sv == 'waiting' %}bg-amber-500 text-white border-amber-500
                        {% elseif sv == 'refused' %}bg-red-600 text-white border-red-600
                        {% else %}bg-gray-500 text-white border-gray-500{% endif %}">
                        {{ label }}
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </span>
                {% else %}
                    <form method="post" action="{{ path('app_admin_school_status', {id: school.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('school_status_' ~ school.id) }}">
                        <input type="hidden" name="status" value="{{ sv }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-medium transition
                            {% if sv == 'accepted' %}border-green-300 text-green-700 hover:bg-green-50
                            {% elseif sv == 'waiting' %}border-amber-300 text-amber-700 hover:bg-amber-50
                            {% elseif sv == 'refused' %}border-red-300 text-red-700 hover:bg-red-50
                            {% else %}border-gray-300 text-gray-600 hover:bg-gray-50{% endif %}">
                            {{ label }}
                        </button>
                    </form>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# Delete — only if no members #}
    {% if canDelete and is_granted('ROLE_ADMIN') %}
    <div class="px-1 mb-5">
        <p class="text-xs text-gray-400 mb-2">Aucun membre ni historique — cette école peut être supprimée définitivement.</p>
        <button type="button"
                onclick="document.getElementById('modal-delete-school').classList.remove('hidden')"
                class="inline-flex items-center gap-2 border border-red-200 bg-red-50 hover:bg-red-100 text-red-700 text-sm font-medium px-4 py-2 rounded-lg transition">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Supprimer l'école
        </button>
    </div>

    <div id="modal-delete-school" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="document.getElementById('modal-delete-school').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-full bg-red-100">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </div>
                <div class="flex-1">
                    <h3 class="text-base font-semibold text-gray-900">Supprimer {{ school.name }} ?</h3>
                    <p class="mt-1 text-sm text-gray-500">Cette action est irréversible.</p>
                </div>
            </div>
            <div class="mt-6 flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('modal-delete-school').classList.add('hidden')"
                        class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                    Annuler
                </button>
                <form method="post" action="{{ path('app_admin_school_delete', {id: school.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_school_' ~ school.id) }}">
                    <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors">
                        Supprimer définitivement
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
