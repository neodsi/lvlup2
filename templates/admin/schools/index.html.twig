{% extends 'layout/admin.html.twig' %}
{% from '_macros/badges.html.twig' import role_count_badge %}

{% block title %}Écoles — Administration{% endblock %}

{% block breadcrumb %}
<a href="{{ path('app_admin') }}" class="hover:text-gray-700 transition">Tableau de bord</a>
<svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
<span class="text-gray-700 font-medium">Écoles</span>
{% endblock %}

{% block admin_content %}
<div class="py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Écoles</h1>
    </div>

    {# Status filter #}
    <div class="flex flex-wrap gap-2 mb-6">
        <a href="{{ path('app_admin_schools') }}" class="inline-flex items-center rounded-full px-3 py-1.5 text-xs font-medium border transition
            {{ not statusFilter ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-600 border-gray-300 hover:border-indigo-300' }}">
            Tous
        </a>
        {% for status in statuses %}
            <a href="{{ path('app_admin_schools', {status: status.value}) }}" class="inline-flex items-center rounded-full px-3 py-1.5 text-xs font-medium border transition
                {{ statusFilter == status.value ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-600 border-gray-300 hover:border-indigo-300' }}">
                {% if status.value == 'accepted' %}Actif
                {% elseif status.value == 'waiting' %}En attente
                {% elseif status.value == 'refused' %}Refusé
                {% elseif status.value == 'disabled' %}Désactivé
                {% else %}{{ status.value }}{% endif %}
            </a>
        {% endfor %}
    </div>

    {% if schools is empty %}
        <div class="rounded-xl border border-gray-200 bg-white p-12 text-center">
            <p class="text-gray-500 text-sm">Aucune école trouvée.</p>
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">École</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Propriétaire</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Membres</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Créée le</th>
                            <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for school in schools %}
                            <tr class="hover:bg-gray-50 transition">
                                <td class="py-4 pl-6 pr-3">
                                    <div class="flex items-center gap-3">
                                        <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-sm shrink-0">
                                            {{ school.name|first|upper }}
                                        </div>
                                        <div>
                                            <p class="font-medium text-sm text-gray-900">{{ school.name }}</p>
                                            <p class="text-xs text-gray-400 font-mono">{{ school.id|slice(0, 8) }}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-600">
                                    {% set t = school.type ?? '' %}
                                    {% if t == 'school' %}École
                                    {% elseif t == 'independent_teacher' %}Prof. indépendant
                                    {% elseif t == 'association' %}Association
                                    {% elseif t != '' %}{{ t }}
                                    {% else %}—{% endif %}
                                </td>
                                <td class="px-3 py-4">
                                    {% set owner = ownersBySchool[school.id] ?? null %}
                                    {% if owner %}
                                        <div class="flex items-center gap-2">
                                            <span class="h-7 w-7 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-semibold text-xs shrink-0">
                                                {{ owner.user ? owner.user.email|first|upper : '?' }}
                                            </span>
                                            <div class="min-w-0">
                                                <p class="text-xs font-medium text-gray-800 truncate">{{ owner.firstName }} {{ owner.lastName }}</p>
                                                {% if owner.user %}
                                                    <p class="text-xs text-gray-400 truncate">{{ owner.user.email }}</p>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% else %}
                                        <span class="text-xs text-gray-400">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-3 py-4">
                                    {% set counts = memberCounts[school.id] ?? {} %}
                                    {% set total = (counts.student ?? 0) + (counts.teacher ?? 0) + (counts.school ?? 0) %}
                                    {% if total == 0 %}
                                        <span class="text-xs text-gray-400">—</span>
                                    {% else %}
                                        <div class="flex items-center gap-1.5 flex-wrap">
                                            {% if counts.student ?? 0 %}{{ role_count_badge('student', counts.student) }}{% endif %}
                                            {% if counts.teacher ?? 0 %}{{ role_count_badge('teacher', counts.teacher) }}{% endif %}
                                            {% if counts.school ?? 0 %}{{ role_count_badge('school', counts.school) }}{% endif %}
                                        </div>
                                    {% endif %}
                                </td>
                                <td class="px-3 py-4">
                                    {% set s = school.status.value ?? school.status ?? 'unknown' %}
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                        {% if s == 'accepted' %}bg-green-50 text-green-700
                                        {% elseif s == 'waiting' %}bg-amber-50 text-amber-700
                                        {% elseif s == 'refused' %}bg-red-50 text-red-700
                                        {% elseif s == 'disabled' %}bg-gray-100 text-gray-500
                                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                                        {% if s == 'accepted' %}Actif
                                        {% elseif s == 'waiting' %}En attente
                                        {% elseif s == 'refused' %}Refusé
                                        {% elseif s == 'disabled' %}Désactivé
                                        {% else %}{{ s }}{% endif %}
                                    </span>
                                </td>
                                <td class="px-3 py-4 text-sm text-gray-500">{{ school.createdAt|date('d/m/Y') }}</td>
                                <td class="py-4 pl-3 pr-6 text-right">
                                    <a href="{{ path('app_admin_school_detail', {id: school.id}) }}" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                        Détail
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
