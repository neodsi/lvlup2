{% extends 'layout/public.html.twig' %}

{% block title %}Logiciel de gestion pour école de danse | LVL UP{% endblock %}

{% block head %}
{% set _seoTitle = 'Logiciel de gestion pour école de danse | LVL UP' %}
{% set _seoDesc = 'Gérez votre école de danse facilement avec LVL UP : inscriptions en ligne, paiements automatisés et planning centralisé. Démo gratuite.' %}
{% set _canonicalUrl = url('app_home') %}
{% set _ogImage = absolute_url(asset('assets/screen-fr.jpg')) %}
<meta name="description" content="{{ _seoDesc }}">
<link rel="canonical" href="{{ _canonicalUrl }}">
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ _seoTitle }}">
<meta property="og:description" content="{{ _seoDesc }}">
<meta property="og:url" content="{{ _canonicalUrl }}">
<meta property="og:image" content="{{ _ogImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="LVL UP – Logiciel de gestion pour école de danse">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ _seoTitle }}">
<meta name="twitter:description" content="{{ _seoDesc }}">
<meta name="twitter:image" content="{{ _ogImage }}">
<meta name="twitter:image:alt" content="LVL UP – Logiciel de gestion pour école de danse">
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "LVL UP",
    "url": "{{ _canonicalUrl }}",
    "description": "{{ _seoDesc }}",
    "publisher": {
        "@type": "Organization",
        "name": "LVL UP",
        "url": "{{ _canonicalUrl }}",
        "logo": {
            "@type": "ImageObject",
            "url": "{{ absolute_url(asset('assets/logo_lvl_up.png')) }}"
        }
    },
    "potentialAction": {
        "@type": "SearchAction",
        "target": {
            "@type": "EntryPoint",
            "urlTemplate": "{{ url('app_school_directory') }}?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
    }
}
</script>
{% endblock %}

{% block public_content %}

{# ── Hero ── #}
<section class="relative min-h-screen flex items-center pt-16 overflow-hidden" style="background-image:url('/assets/auth.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(15,10,40,0.1) 0%, rgba(15,10,40,0.5) 40%, rgba(15,10,40,0.88) 65%);"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-24 w-full flex justify-end">
        <div class="max-w-xl">
            <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight mb-6">
                Gérez votre <br>école de danse<br>sans stress
            </h1>
            <p class="text-lg text-white/80 mb-10">
                <strong class="text-white">Automatisez</strong> les inscriptions, les paiements et les plannings pour
                <strong class="text-white">gagner plusieurs heures</strong> chaque semaine
            </p>
            <a href="#fonctions"
               class="inline-flex items-center gap-2 btn-demo text-white font-semibold px-6 py-3 rounded-lg text-sm">
                Découvrir les fonctionnalités
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </a>
        </div>
    </div>
</section>

{# ── Fonctionnalités ── #}
