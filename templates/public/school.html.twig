{% extends 'layout/public.html.twig' %}

{% set _city = school.citySlug ? school.citySlug|replace({'-': ' '})|title : '' %}
{% set _seoTitle = school.name ~ (_city ? ' — ' ~ _city : '') ~ ' · LVL UP' %}
{% set _seoBaseDesc = school.description
    ? school.description|striptags|trim|slice(0, 135)
    : ('Découvrez ' ~ school.name ~ (_city ? ', à ' ~ _city : '') ~ '. Inscriptions, forfaits et planning.') %}
{% set _seoDesc = 'Propulsé par LVL UP — ' ~ _seoBaseDesc %}
{% set _seoImage = school.avatarPath
    ? school.avatarPath|imagine_filter('school_photo_main')
    : (school.logoPath ? school.logoPath|imagine_filter('school_logo') : null) %}
{% set _canonicalUrl = url('app_school_page', {citySlug: school.citySlug, schoolSlug: school.currentSlug}) %}

{% block title %}{{ _seoTitle }}{% endblock %}

{% block head %}
<meta name="description" content="{{ _seoDesc }}">
<link rel="canonical" href="{{ _canonicalUrl }}">
<meta name="robots" content="index, follow">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ _seoTitle }}">
<meta property="og:description" content="{{ _seoDesc }}">
<meta property="og:url" content="{{ _canonicalUrl }}">
<meta name="subject" content="{{ school.name }}{% if _city %} — École de danse à {{ _city }}{% endif %}">
<meta name="classification" content="Sport, Danse, École{% if _city %}, {{ _city }}{% endif %}">
<meta name="category" content="École de danse">
{% set _ogImage = _seoImage ? absolute_url(_seoImage) : absolute_url(asset('assets/screen-fr.jpg')) %}
<meta property="og:image" content="{{ _ogImage }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ _seoTitle }}">
<meta name="twitter:description" content="{{ _seoDesc }}">
<meta name="twitter:image" content="{{ _ogImage }}">
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "SportsClub",
    "name": "{{ school.name|e('js') }}"
    {% if school.description %}, "description": "{{ school.description|striptags|trim|slice(0, 200)|e('js') }}"{% endif %}
    {% if school.addressText %}, "address": { "@type": "PostalAddress", "addressLocality": "{{ _city|e('js') }}", "streetAddress": "{{ school.addressText|e('js') }}" }{% endif %}
    {% if school.addressLat and school.addressLng %}, "geo": { "@type": "GeoCoordinates", "latitude": {{ school.addressLat }}, "longitude": {{ school.addressLng }} }{% endif %}
    {% if school.phone %}, "telephone": "{{ school.phone|e('js') }}"{% endif %}
    {% if school.contactEmail %}, "email": "{{ school.contactEmail|e('js') }}"{% endif %}
    {% if school.websiteUrl %}, "url": "{{ school.websiteUrl|e('js') }}"{% endif %}
    {% if _seoImage %}, "image": "{{ absolute_url(_seoImage) }}"{% endif %}
    , "sameAs": ["{{ _canonicalUrl }}"]
}
</script>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% if school.addressLat and school.addressLng %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
{% endif %}
<style>
    .prose h2 { font-size: 1.05rem; font-weight: 600; margin-bottom: .5rem; margin-top: 1.25rem; }
    .prose h3 { font-size: 1rem; font-weight: 600; margin-bottom: .4rem; margin-top: 1rem; }
    .prose p  { margin-bottom: .6rem; line-height: 1.65; }
    .prose ul { list-style: disc; padding-left: 1.4rem; margin-bottom: .6rem; }
    .prose ol { list-style: decimal; padding-left: 1.4rem; margin-bottom: .6rem; }
    .prose li { margin-bottom: .2rem; }
    .prose strong { font-weight: 600; }
    .prose em { font-style: italic; }
    .prose a { color: #4f46e5; text-decoration: underline; }
    .img-zoomable { cursor: zoom-in; transition: opacity .15s; }
    .img-zoomable:hover { opacity: .92; }
</style>
{% endblock %}

{% block public_content %}
<div x-data="pageData()">

{# ── Hero ── #}
<div class="relative{% if school.avatarPath %} bg-gray-900{% else %} bg-gradient-to-br from-indigo-900 to-indigo-700{% endif %} overflow-hidden pt-16" style="min-height:300px">
    {% if school.avatarPath %}
    <img src="{{ school.avatarPath | imagine_filter('school_photo_main') }}" alt="{{ school.name }}"
         class="absolute inset-0 w-full h-full object-cover opacity-40">
    {% endif %}
    <div class="relative z-10 px-4 sm:px-8 py-12 flex flex-col items-center text-center" style="min-height:236px;justify-content:center">
        {% if school.logoPath %}
        <img src="{{ school.logoPath | imagine_filter('school_logo') }}" alt="Logo {{ school.name }}"
             class="h-20 w-20 rounded-xl object-contain bg-white/10 border border-white/20 p-2 mb-5 shadow-lg">
        {% endif %}
        <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">{{ school.name }}</h1>
        {% if _city %}
        <p class="mt-1 text-sm text-white/50 font-medium">{{ _city }}</p>
        {% endif %}
        {% if school.addressText %}
        <p class="mt-2 text-sm text-white/70 flex items-center gap-1.5 justify-center max-w-md">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {{ school.addressText }}
        </p>
        {% endif %}
    </div>
</div>

{# ── Contact bar ── #}
{% if school.phone or school.contactEmail or school.websiteUrl %}
<div class="bg-white border-b border-gray-200 px-4 sm:px-8 py-3 sticky top-16 z-[100] shadow-sm">
    <div class="max-w-5xl mx-auto flex flex-wrap items-center gap-x-6 gap-y-2 justify-center text-sm">
        <span class="font-semibold text-gray-900 mr-2">{{ school.name }}</span>
        {% if school.phone %}
        <a href="tel:{{ school.phone|replace({' ': ''}) }}" class="flex items-center gap-1.5 text-gray-600 hover:text-indigo-600 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {{ school.phone }}
        </a>
        {% endif %}
        {% if school.contactEmail %}
        <a href="mailto:{{ school.contactEmail }}" class="flex items-center gap-1.5 text-gray-600 hover:text-indigo-600 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {{ school.contactEmail }}
        </a>
        {% endif %}
        {% if school.websiteUrl %}
        <a href="{{ school.websiteUrl }}" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-gray-600 hover:text-indigo-600 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            {{ school.websiteUrl|replace({'https://': '', 'http://': ''})|trim('/') }}
        </a>
        {% endif %}
    </div>
</div>
{% endif %}

{# ── Main content ── #}
<main class="max-w-5xl mx-auto px-4 sm:px-8 py-10 space-y-10">

    {# Description + Map côte à côte #}
    {% if school.description and school.addressLat and school.addressLng %}
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-6">
        <section class="flex flex-col">
            <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">À propos</p>
            <div class="bg-white rounded-2xl border border-gray-200 p-6 prose text-sm text-gray-700 shadow-sm flex-1">
                {{ school.description|raw }}
            </div>
        </section>
        <section class="flex flex-col">
            <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Nous trouver</p>
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm flex-1 isolate" style="min-height:280px">
                <div id="public-map" style="height:100%;min-height:280px"></div>
            </div>
            {% if school.addressText %}
            <p class="mt-2 text-xs text-gray-500 leading-snug flex items-start gap-1">
                <svg class="w-3.5 h-3.5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                {{ school.addressText }}
            </p>
            {% endif %}
        </section>
    </div>
    {% elseif school.description %}
    <section>
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">À propos</p>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 prose text-sm text-gray-700 shadow-sm">
            {{ school.description|raw }}
        </div>
    </section>
    {% endif %}

    {# Saisons #}
    {% if seasonData is not empty %}
    <section>
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Inscriptions &amp; saisons</p>
        <div class="space-y-4">
            {% for item in seasonData %}
            {% set season = item.season %}
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">

                <div class="px-5 py-4 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center gap-3 justify-between">
                    <div>
                        <h2 class="font-semibold text-gray-900">{{ season.name }}</h2>
                        <p class="text-xs text-gray-400 mt-0.5">
                            Du {{ season.startAt|date('d/m/Y') }} au {{ season.endAt|date('d/m/Y') }}
                        </p>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                        {% if item.regOpen %}
                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                            Inscriptions ouvertes
                        </span>
                        {% elseif item.preRegOpen %}
                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                            Pré-inscriptions ouvertes
                        </span>
                        {% elseif season.registrationsStartAt and season.registrationsStartAt > date() %}
                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                            Inscriptions le {{ season.registrationsStartAt|date('d/m/Y') }}
                        </span>
                        {% endif %}
                        {% if item.regOpen or item.preRegOpen %}
                        <a href="#"
                           class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold transition">
                            S'inscrire
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </a>
                        {% endif %}
                    </div>
                </div>

                {% if season.registrationPublicDescription %}
                <div class="px-5 py-3 border-b border-gray-100 text-sm text-gray-600 prose">
                    {{ season.registrationPublicDescription|raw }}
                </div>
                {% endif %}

                <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">
                    {% if item.packages is not empty %}
                    <div class="px-5 py-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Forfaits</p>
                        <div class="space-y-2">
                            {% for pkg in item.packages %}
                            <div class="flex items-center justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="text-sm font-medium text-gray-900 truncate">{{ pkg.name }}</p>
                                    <p class="text-xs text-gray-400">
                                        {% if pkg.type.value == 'subscription_one_year' %}Abonnement annuel
                                        {% elseif pkg.type.value == 'subscription_one_semester' %}Abonnement semestriel
                                        {% elseif pkg.type.value == 'trial_class' %}Cours d'essai
                                        {% elseif pkg.type.value == 'a_la_carte' %}À la carte
                                        {% elseif pkg.type.value == 'registration_fee' %}Frais d'inscription
                                        {% else %}{{ pkg.type.value }}{% endif %}
                                        {% if pkg.classesQty %} · {{ pkg.classesQty }} cours{% endif %}
                                    </p>
                                </div>
                                <span class="shrink-0 text-sm font-semibold text-indigo-600">{{ (pkg.price / 100)|number_format(2, ',', ' ') }} €</span>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    {% if item.events is not empty %}
                    <div class="px-5 py-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Cours &amp; activités</p>
                        <div class="space-y-1.5">
                            {% for event in item.events %}
                            <div class="flex items-center gap-2">
                                <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium
                                    {% if event.type.value == 'lesson' %}bg-indigo-50 text-indigo-700
                                    {% elseif event.type.value == 'stage' %}bg-purple-50 text-purple-700
                                    {% elseif event.type.value == 'gala' %}bg-pink-50 text-pink-700
                                    {% elseif event.type.value == 'workshop' %}bg-amber-50 text-amber-700
                                    {% else %}bg-gray-100 text-gray-600{% endif %}">
                                    {% if event.type.value == 'lesson' %}Cours
                                    {% elseif event.type.value == 'stage' %}Stage
                                    {% elseif event.type.value == 'gala' %}Gala
                                    {% elseif event.type.value == 'workshop' %}Atelier
                                    {% else %}{{ event.type.value }}{% endif %}
                                </span>
                                <span class="text-sm text-gray-800 truncate">{{ event.name }}</span>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>

                {% if season.planningImagePath or season.packagesImagePath %}
                <div class="border-t border-gray-100 grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">
                    {% if season.planningImagePath %}
                    <div class="p-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Planning</p>
                        <div class="relative group">
                            <img src="{{ season.planningImagePath | imagine_filter('season_planning') }}"
                                 alt="Planning {{ season.name }}"
                                 @click="openLightbox('{{ absolute_url(asset(season.planningImagePath)) }}', 'Planning {{ season.name|e('js') }}')"
                                 class="w-full rounded-lg object-cover img-zoomable">
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition pointer-events-none">
                                <span class="bg-black/50 text-white rounded-full p-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                                </span>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    {% if season.packagesImagePath %}
                    <div class="p-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Forfaits</p>
                        <div class="relative group">
                            <img src="{{ season.packagesImagePath | imagine_filter('season_packages') }}"
                                 alt="Forfaits {{ season.name }}"
                                 @click="openLightbox('{{ absolute_url(asset(season.packagesImagePath)) }}', 'Forfaits {{ season.name|e('js') }}')"
                                 class="w-full rounded-lg object-cover img-zoomable">
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition pointer-events-none">
                                <span class="bg-black/50 text-white rounded-full p-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                                </span>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                {% if season.closures is not empty %}
                <div class="px-5 py-3 bg-gray-50 border-t border-gray-100">
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Fermetures</p>
                    <div class="flex flex-wrap gap-2">
                        {% for closure in season.closures %}
                        {% set _dates = '' %}
                        {% if closure.start_at is defined and closure.start_at %}
                            {% set _dates = closure.start_at|date('d/m/Y') %}
                            {% if closure.end_at is defined and closure.end_at and closure.end_at != closure.start_at %}
                                {% set _dates = _dates ~ ' → ' ~ closure.end_at|date('d/m/Y') %}
                            {% endif %}
                        {% endif %}
                        <span class="inline-flex flex-col rounded-lg px-3 py-1.5 text-xs bg-white border border-gray-200 text-gray-700 leading-tight">
                            <span class="font-medium">{{ closure.label ?? 'Fermeture' }}</span>
                            {% if _dates %}<span class="text-gray-400 mt-0.5">{{ _dates }}</span>{% endif %}
                        </span>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

            </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {# Horaires + Tarifs côte à côte #}
    {% if school.schedule or school.pricing %}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {% if school.schedule %}
        <section class="flex flex-col">
            <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Horaires</p>
            <div class="bg-white rounded-2xl border border-gray-200 p-6 prose text-sm text-gray-700 shadow-sm flex-1">
                {{ school.schedule|raw }}
            </div>
        </section>
        {% endif %}
        {% if school.pricing %}
        <section class="flex flex-col">
            <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Tarifs</p>
            <div class="bg-white rounded-2xl border border-gray-200 p-6 prose text-sm text-gray-700 shadow-sm flex-1">
                {{ school.pricing|raw }}
            </div>
        </section>
        {% endif %}
    </div>
    {% endif %}

    {# Moyens de paiement #}
    {% set _pmLabels = {
        'voucher_activity':            'Chèques activités',
        'card_on_site':                'Carte bancaire',
        'voucher_holiday_ancv_paper':  'Chèques vacances ANCV',
        'sepa_direct_debit':           'Prélèvement SEPA',
        'financement_pole_emploi':     'Pôle emploi',
        'voucher_holiday_ancv_online': 'Chèques e-ANCV',
        'coupon_sport':                'Coupon sport',
        'bank_transfer':               'Virement',
        'culture_pass':                'Pass culture',
        'cash':                        'Espèces',
        'check':                       'Chèques',
        'online_card':                 'Carte en ligne',
        'online_bank_transfer':        'Virement en ligne',
        'other':                       'Autre',
    } %}
    {% set _enabledMethods = [] %}
    {% for m in school.paymentMethods ?? [] %}
        {% if m.allowed_for_one_shot or m.allowed_for_multiple_payments %}
            {% set _enabledMethods = _enabledMethods|merge([m.id]) %}
        {% endif %}
    {% endfor %}
    {% if _enabledMethods is not empty %}
    <section>
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Moyens de paiement</p>
        <div class="bg-white rounded-2xl border border-gray-200 px-6 py-5 shadow-sm">
            <div class="flex flex-wrap gap-2">
                {% for id in _enabledMethods %}
                <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm bg-gray-50 text-gray-700 border border-gray-200">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {{ _pmLabels[id] ?? id }}
                </span>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    {# Carte & adresse (standalone si pas de description) #}
    {% if school.addressLat and school.addressLng and not school.description %}
    <section>
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-3">Nous trouver</p>
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm isolate">
            <div id="public-map" style="height:360px"></div>
            {% if school.addressText %}
            <div class="px-5 py-3.5 flex items-start gap-2 border-t border-gray-100">
                <svg class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <p class="text-sm text-gray-600">{{ school.addressText }}</p>
            </div>
            {% endif %}
        </div>
    </section>
    {% endif %}

    {# CGU #}
    {% if school.readAndCheck %}
    <div class="text-center pb-2">
        <button type="button" @click="$dispatch('open-cgu')"
                class="text-sm text-gray-400 hover:text-indigo-600 underline transition">
            Consulter les conditions d'utilisation
        </button>
    </div>
    {% endif %}

</main>

{# ── Mentions légales ── #}
{% if school.companyName or school.siret or school.apeNaf or school.vatNumber or school.invoiceAddress %}
<div class="border-t border-gray-100 bg-gray-50 px-4 sm:px-8 py-6">
    <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Informations légales</p>
        <dl class="flex flex-wrap gap-x-8 gap-y-2 text-xs text-gray-500">
            {% if school.companyName %}
            <div class="flex gap-1.5">
                <dt class="text-gray-400">Raison sociale</dt>
                <dd class="font-medium text-gray-600">{{ school.companyName }}</dd>
            </div>
            {% endif %}
            {% if school.siret %}
            <div class="flex gap-1.5">
                <dt class="text-gray-400">SIRET</dt>
                <dd class="font-medium text-gray-600 font-mono">{{ school.siret[0:3] ~ ' ' ~ school.siret[3:3] ~ ' ' ~ school.siret[6:3] ~ ' ' ~ school.siret[9:5] }}</dd>
            </div>
            {% endif %}
            {% if school.apeNaf %}
            <div class="flex gap-1.5">
                <dt class="text-gray-400">Code APE</dt>
                <dd class="font-medium text-gray-600 font-mono">{{ school.apeNaf }}</dd>
            </div>
            {% endif %}
            {% if school.isCollectingVat and school.vatNumber %}
            <div class="flex gap-1.5">
                <dt class="text-gray-400">N° TVA</dt>
                <dd class="font-medium text-gray-600 font-mono">{{ school.vatNumber }}</dd>
            </div>
            {% endif %}
            {% if school.invoiceAddress %}
            <div class="flex gap-1.5 w-full sm:w-auto">
                <dt class="text-gray-400 shrink-0">Siège social</dt>
                <dd class="font-medium text-gray-600">{{ school.invoiceAddress }}</dd>
            </div>
            {% endif %}
        </dl>
    </div>
</div>
{% endif %}

{# ── Lightbox ── #}
<div x-show="lightboxSrc"
     x-transition.opacity
     @keydown.escape.window="closeLightbox()"
     @click="closeLightbox()"
     class="fixed inset-0 z-[9998] flex items-center justify-center bg-black/90 p-4"
     style="display:none">
    <button type="button" @click="closeLightbox()"
            class="absolute top-4 right-4 text-white/70 hover:text-white transition z-10">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <img :src="lightboxSrc" :alt="lightboxAlt"
         @click.stop
         class="max-w-full max-h-full object-contain rounded-lg shadow-2xl">
</div>

{# ── CGU modal ── #}
{% if school.readAndCheck %}
<div x-data="{ open: false }" @open-cgu.window="open = true">
    <div x-show="open" class="fixed inset-0 z-[9999] flex items-center justify-center p-2 sm:p-4" style="display:none">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @click="open = false"></div>
        <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-6xl h-[96vh] overflow-hidden flex flex-col">
            <div class="px-8 py-5 border-b border-gray-100 flex items-center justify-between shrink-0">
                <h3 class="text-base font-semibold text-gray-900">Conditions d'utilisation</h3>
                <button type="button" @click="open = false" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="px-8 py-7 overflow-y-auto prose prose-sm text-gray-700 flex-1 max-w-none">
                {{ school.readAndCheck|raw }}
            </div>
        </div>
    </div>
</div>
{% endif %}

</div>{# end x-data="pageData()" #}
{% endblock %}

{% block scripts %}
{{ parent() }}
{% if school.addressLat and school.addressLng %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    const lat = {{ school.addressLat }};
    const lng = {{ school.addressLng }};
    const map = L.map('public-map', { zoomControl: true, scrollWheelZoom: false }).setView([lat, lng], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors', maxZoom: 19,
    }).addTo(map);
    L.marker([lat, lng]).addTo(map);
})();
</script>
{% endif %}
<script>
function pageData() {
    return {
        lightboxSrc: null,
        lightboxAlt: '',
        openLightbox(src, alt) {
            this.lightboxSrc = src;
            this.lightboxAlt = alt || '';
        },
        closeLightbox() {
            this.lightboxSrc = null;
            this.lightboxAlt = '';
        },
    };
}
</script>
{% endblock %}
