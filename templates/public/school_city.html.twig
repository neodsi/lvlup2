{% extends 'layout/public.html.twig' %}

{% block title %}Écoles de danse à {{ cityName }} | LVL UP{% endblock %}

{% block head %}
{% set _seoTitle = 'Écoles de danse à ' ~ cityName ~ ' · LVL UP' %}
{% set _seoDesc = 'Découvrez ' ~ total ~ ' école' ~ (total > 1 ? 's' : '') ~ ' de danse à ' ~ cityName ~ '. Programmes, inscriptions et tarifs disponibles sur LVL UP.' %}
{% set _canonicalUrl = url('app_school_directory_city', {citySlug: citySlug}) %}
<meta name="description" content="{{ _seoDesc }}">
<link rel="canonical" href="{{ _canonicalUrl }}">
<meta name="robots" content="index, follow">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ _seoTitle }}">
<meta property="og:description" content="{{ _seoDesc }}">
<meta property="og:url" content="{{ _canonicalUrl }}">
<meta property="og:image" content="{{ absolute_url(asset('assets/screen-fr.jpg')) }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ _seoTitle }}">
<meta name="twitter:description" content="{{ _seoDesc }}">
<meta name="twitter:image" content="{{ absolute_url(asset('assets/screen-fr.jpg')) }}">
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Écoles de danse à {{ cityName|e('js') }}",
    "description": "{{ _seoDesc|e('js') }}",
    "url": "{{ _canonicalUrl }}"
    {% if schools|length > 0 %}
    , "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": {{ total }},
        "itemListElement": [
            {% for school in schools %}
            {
                "@type": "ListItem",
                "position": {{ loop.index + (pagination.currentPage - 1) * pagination.itemsPerPage }},
                "name": "{{ school.name|e('js') }}",
                "url": "{{ url('app_school_page', {citySlug: school.citySlug, schoolSlug: school.currentSlug}) }}"
            }{{ not loop.last ? ',' : '' }}
            {% endfor %}
        ]
    }
    {% endif %}
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Écoles de danse", "item": "{{ url('app_school_directory') }}" },
        { "@type": "ListItem", "position": 2, "name": "{{ cityName|e('js') }}", "item": "{{ _canonicalUrl }}" }
    ]
}
</script>
<meta name="subject" content="Écoles de danse à {{ cityName }}">
<meta name="classification" content="Sport, Danse, Annuaire, {{ cityName }}">
<meta name="geo.placename" content="{{ cityName }}">
<meta name="geo.region" content="FR">
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-hover:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
    #map .leaflet-popup-content { font-size: .8rem; }
</style>
{% endblock %}

{% block public_content %}
{# ── Layout split ── #}
<div class="pt-16 flex flex-col md:flex-row md:h-[calc(100vh-4rem)] md:overflow-hidden">

    {# ── Colonne gauche : header + liste ── #}
    <section class="md:w-[45%] md:overflow-y-auto flex flex-col" aria-label="Écoles de danse à {{ cityName }}">

        {# En-tête ville #}
        <div class="px-4 pt-5 pb-3 bg-white border-b border-gray-100">
            <nav aria-label="Fil d'ariane" class="flex items-center gap-1.5 text-xs text-gray-400 mb-3">
                <a href="{{ path('app_school_directory') }}" class="hover:text-gray-600 transition">Écoles de danse</a>
                <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-gray-700 font-medium">{{ cityName }}</span>
            </nav>
            <h1 class="text-2xl font-bold text-gray-900">Écoles de danse à {{ cityName }}</h1>
            <p class="mt-1 text-sm text-gray-500">
                {{ total }} école{{ total > 1 ? 's' : '' }} référencée{{ total > 1 ? 's' : '' }}
            </p>
        </div>

        {# Barre de recherche rapide (autre ville) #}
        <div class="px-4 py-3 bg-white border-b border-gray-100">
            <form method="GET" action="{{ path('app_school_directory') }}" role="search">
                <div class="flex gap-2">
                    <div class="relative flex-1">
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                        </svg>
                        <input type="search" name="q"
                               placeholder="Autre ville ou nom d'école…"
                               aria-label="Rechercher une école de danse"
                               class="block w-full rounded-lg border border-gray-300 bg-gray-50 pl-9 pr-3 py-2 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
                    </div>
                    <button type="submit"
                            class="shrink-0 px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition">
                        Chercher
                    </button>
                </div>
            </form>
        </div>

        {# Liste des écoles #}
        <div class="px-4 py-4 flex-1">
            <ul class="space-y-2" role="list">
                {% for school in schools %}
                {% set _city = school.citySlug ? school.citySlug|replace({'-': ' '})|title : null %}
                <li>
                    <article class="card-hover bg-white rounded-xl border border-gray-100 transition"
                             data-school-slug="{{ school.currentSlug }}">
                        <a href="{{ path('app_school_page', {citySlug: school.citySlug, schoolSlug: school.currentSlug}) }}"
                           class="flex items-start gap-3 p-3">
                            <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-gray-100 flex items-center justify-center">
                                {% if school.logoPath %}
                                <img src="{{ school.logoPath|imagine_filter('school_logo') }}"
                                     alt="{{ school.name }}" class="w-full h-full object-cover" loading="lazy">
                                {% elseif school.avatarPath %}
                                <img src="{{ school.avatarPath|imagine_filter('school_photo_main') }}"
                                     alt="{{ school.name }}" class="w-full h-full object-cover" loading="lazy">
                                {% else %}
                                <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                </svg>
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <h2 class="text-sm font-semibold text-gray-900 truncate">{{ school.name }}</h2>
                                {% if school.addressText %}
                                <p class="text-xs text-gray-400 mt-0.5 flex items-center gap-1 truncate">
                                    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    {{ school.addressText }}
                                </p>
                                {% elseif _city %}
                                <p class="text-xs text-gray-400 mt-0.5 flex items-center gap-1">
                                    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    {{ _city }}
                                </p>
                                {% endif %}
                                {% if school.description %}
                                <p class="text-xs text-gray-500 mt-1 line-clamp-2">{{ school.description|striptags|trim|slice(0, 130) }}</p>
                                {% endif %}
                            </div>
                            <svg class="shrink-0 w-4 h-4 text-gray-300 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </a>
                    </article>
                </li>
                {% endfor %}
            </ul>

            <div class="mt-4">
                {% include 'components/_pagination.html.twig' with { pagination: pagination } %}
            </div>
        </div>

    </section>

    {# ── Carte OSM ── #}
    <div class="h-72 md:h-auto md:flex-1 isolate">
        <div id="map" class="w-full h-full"></div>
    </div>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
window.SCHOOLS_MAP_DATA = {{ mapJson|raw }};

(function () {
    const map = L.map('map', { zoomControl: true });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
        maxZoom: 19
    }).addTo(map);

    const markerMap = {};
    const bounds   = [];

    (window.SCHOOLS_MAP_DATA || []).forEach(s => {
        if (!s.lat || !s.lng) return;
        const marker = L.marker([s.lat, s.lng]);
        marker.bindPopup(
            '<div style="min-width:140px;font-family:sans-serif">' +
            '<strong style="font-size:.85rem">' + s.name + '</strong>' +
            (s.addr ? '<br><span style="font-size:.75rem;color:#6b7280">' + s.addr + '</span>' : '') +
            '<br><a href="' + s.url + '" style="font-size:.75rem;color:#4f46e5;font-weight:600;margin-top:4px;display:inline-block">Voir l\'école →</a>' +
            '</div>'
        );
        marker.addTo(map);
        markerMap[s.slug] = marker;
        bounds.push([s.lat, s.lng]);
    });

    if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 });
    } else {
        map.setView([46.603354, 1.888334], 6);
    }

    document.querySelectorAll('[data-school-slug]').forEach(card => {
        card.addEventListener('mouseenter', () => {
            const slug = card.dataset.schoolSlug;
            if (markerMap[slug]) {
                markerMap[slug].openPopup();
                map.panTo(markerMap[slug].getLatLng(), { animate: true });
            }
        });
    });
}());
</script>
{% endblock %}
